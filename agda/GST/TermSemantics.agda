sbSemLift :
  {Пғ : Sb}
  {О“ О“' О“'' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  вҰғ _ : x # О“ вҰ„
  вҰғ _ : x' # О“' вҰ„
  (q : О“' вҠўЛў Пғ вҲ¶ О“)
  (q' : О“' вЁҹ x' вҲ¶ A вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ О“ вЁҹ x вҲ¶ A)
  (рқ“ј : вҲЈ рқ“” О“' вҠҷ О“'' вҲЈ)
