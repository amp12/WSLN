    (рқ“®вӮҒ , рқ“®вӮӮ)
  where
  рқ“®вӮҒ :  рқ“” О“ вҠҷ О“'' вҲӢ
    вҹҰ вҠўЛўExt (sbUpdate#{a = рқҗҜ x'} Пғ it) (wkSb q) вҹ§ЛўвӮҖ (рқ“ј , рқ“Ә)
    ~ вҹҰ q вҹ§ЛўвӮҖ рқ“ј
  рқ“®вӮҒ = ~Trans (рқ“” О“ вҠҷ О“'')
    (irrelSemЛў
      (вҠўЛўExt (sbUpdate# Пғ it) (wkSb q))
      (wkSb q)
      (~Symm Sb[ О“ ] (sbUpdate# Пғ it))
      (рқ“ј , рқ“Ә))
