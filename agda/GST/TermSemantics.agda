        (Var (isInNew refl)))
    (Var (isInNew refl))
    (:=Eq{f = Пғ} x)
    (рқ“ј , рқ“Ә)

sbSem :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {a : Tm}
  (p : О“' вҠўЛў Пғ вҲ¶ О“)
  (q : О“ вҠў a вҲ¶ A)
  вҶ’ ----------------------------------------
  рқ“” О“' вҹ¶^ рқ““ A вҲӢ вҹҰ sbвҠў p q вҹ§ ~ вҹҰ q вҹ§ вҲҳ вҹҰ p вҹ§Лў

sbSem{Пғ}{О“} p (Var{x = x} q)
  rewrite вҖҝunit (Пғ x) вҰғ вүӨrefl вҰ„ = sbSemVar{О“ = О“} p q
sbSem{Пғ}{О“}{О“'} p (Lam{A}{B}{b}{x} q x#) {О“''} рқ“ј {О“'''} (r , рқ“Ә) = рқ“®
  where
  S : Fsetрқ”ё
  S = supp (Пғ * b , О“')

  x' : рқ”ё
  x' = new S

  x'#b : x' # Пғ * b
  x'#b = вҲүвҲӘвӮҒ (newвҲү S)

  instance
    _ : x' # О“'
    _ = вҲүвҲӘвӮӮ (newвҲү S)

  p' : О“' вЁҹ x' вҲ¶ A вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ О“ вЁҹ x вҲ¶ A
  p' = liftSb p

  q' : О“' вЁҹ x' вҲ¶ A вҠў (Пғ * b) [ x' ] вҲ¶ B
  q' = subst (О» c вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c вҲ¶ B)
    (sbUpdate[] Пғ x (рқҗҜ x') b x#)
    (sbвҠў (liftSb p) q)

  рқ“®вӮҒ : рқ““ B вҠҷ О“''' вҲӢ
      вҹҰ q' вҹ§вӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә)
      ~
      вҹҰ sbвҠў p' q вҹ§вӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә)
  рқ“®вӮҒ = irrelSem
    q'
    (sbвҠў p' q)
    (symm (sbUpdate[] Пғ x (рқҗҜ x') b x#))
    (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә)

  рқ“®вӮӮ : рқ““ B вҠҷ О“''' вҲӢ
    вҹҰ sbвҠў p' q вҹ§вӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә)
    ~
    вҹҰ q вҹ§вӮҖ (вҹҰ p' вҹ§ЛўвӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә))
  рқ“®вӮӮ = sbSem p' q (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә)

  рқ“®вӮғ : рқ““ B вҠҷ О“''' вҲӢ
    вҹҰ q вҹ§вӮҖ (вҹҰ p' вҹ§ЛўвӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә))
    ~
    вҹҰ q вҹ§вӮҖ (вҹҰ p вҹ§ЛўвӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј) , рқ“Ә)
  рқ“®вӮғ = hom вҹҰ q вҹ§ вӮҒ sbSemLift p p' (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј) рқ“Ә

  рқ“®вӮ„ :  рқ““ B вҠҷ О“''' вҲӢ
    вҹҰ q вҹ§вӮҖ (вҹҰ p вҹ§ЛўвӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј) , рқ“Ә)
    ~
    вҹҰ q вҹ§вӮҖ (рқ“” О“ вҠҷвҖІ r вӮҖ вҹҰ p вҹ§ЛўвӮҖ рқ“ј , рқ“Ә)
  рқ“®вӮ„ = hom вҹҰ q вҹ§ вӮҒ (ntl вҹҰ p вҹ§Лў r рқ“ј , ~Refl (рқ““ A вҠҷ О“''') рқ“Ә)

  рқ“® : рқ““ B вҠҷ О“''' вҲӢ
      вҹҰ q' вҹ§вӮҖ (рқ“” О“' вҠҷвҖІ r вӮҖ рқ“ј , рқ“Ә)
      ~ вҹҰ q вҹ§вӮҖ (рқ“” О“ вҠҷвҖІ r вӮҖ вҹҰ p вҹ§ЛўвӮҖ рқ“ј , рқ“Ә)
  рқ“® = ~Trans (рқ““ B вҠҷ О“''') рқ“®вӮҒ
    (~Trans (рқ““ B вҠҷ О“''') рқ“®вӮӮ
      (~Trans (рқ““ B вҠҷ О“''') рқ“®вӮғ рқ“®вӮ„))

sbSem p (App{A}{B} qвӮҖ qвӮҒ) рқ“ј = hom-ev^вӮҒ{A}{B}
  (вҹҰ sbвҠў p qвӮҖ вҹ§вӮҖ рқ“ј)
  (вҹҰ qвӮҖ вҹ§вӮҖ (вҹҰ p вҹ§ЛўвӮҖ рқ“ј))
  (вҹҰ sbвҠў p qвӮҒ вҹ§вӮҖ рқ“ј)
  (вҹҰ qвӮҒ вҹ§вӮҖ (вҹҰ p вҹ§ЛўвӮҖ рқ“ј))
  (sbSem p qвӮҖ рқ“ј)
  (sbSem p qвӮҒ рқ“ј)

sbSem _ Zero _ = refl

sbSem{О“ = О“} p (Succ q) рқ“ј
  rewrite sbSem{О“ = О“} p q рқ“ј = refl

sbSem p (Nrec{C} qвӮҖ qвӮҒ qвӮӮ) рқ“ј = nrecвӮӮ{C}
  (вҹҰ sbвҠў p qвӮӮ вҹ§вӮҖ рқ“ј)
  (вҹҰ qвӮӮ вҹ§вӮҖ (вҹҰ p вҹ§ЛўвӮҖ рқ“ј))
  (sbSem p qвӮҖ рқ“ј)
  (sbSem p qвӮҒ рқ“ј)
  (sbSem p qвӮӮ рқ“ј)

