----------------------------------------------------------------------
-- Presheaf semantics of terms
----------------------------------------------------------------------
infix 1 вҹҰ_вҹ§
вҹҰ_вҹ§ :
  {О“ : Cx}
  {a : Tm}
  {A : Ty}
  (_ : О“ вҠў a вҲ¶ A)
  вҶ’ ---------------
  в„қ^[ рқ“” О“ вҹ¶ рқ““ A ]

nrecвӮҒ :
  {C : Ty}
  {О“ : Cx}
  (_ : вҲЈ рқ““ C вҠҷ О“ вҲЈ)
  (_ : вҲЈ рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷ О“ вҲЈ)
  (_ : вҲЈ рқ““ рқҗҚрқҗҡрқҗӯ вҠҷ О“ вҲЈ)
  вҶ’ ---------------------------
  вҲЈ рқ““ C вҠҷ О“ вҲЈ

nrecвӮҒ рқ“¬вӮҖ _ (mkвҲЈNormвҲЈ _ Zero) = рқ“¬вӮҖ
nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ _ (Succ q)) =
  hom ev^ вӮҖ
    (hom ev^ вӮҖ (рқ“¬вӮҠ , mkвҲЈNormвҲЈ _ q) ,
     nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ _ q))
nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ _ (Neu q)) =
  вҶ‘вӮҖ{C} (Nrec (вҶ“вӮҖвҠў рқ“¬вӮҖ) (вҶ“вӮҖвҠў рқ“¬вӮҠ) q)

hom-ev^вӮҒ :
  {A B : Ty}
  {О“ : Cx}
  (рқ“Ҝ рқ“Ҝ' : вҲЈ рқ““ (A вҮ’ B) вҠҷ О“ вҲЈ)
  (рқ“Ә рқ“Ә' : вҲЈ рқ““ A вҠҷ О“ вҲЈ)
  (_ : рқ““ (A вҮ’ B) вҠҷ О“ вҲӢ рқ“Ҝ ~ рқ“Ҝ')
  (_ : рқ““ A вҠҷ О“ вҲӢ рқ“Ә ~ рқ“Ә')
  вҶ’ -----------------------------------------------
  рқ““ B вҠҷ О“ вҲӢ hom ev^ вӮҖ (рқ“Ҝ , рқ“Ә) ~ hom ev^ вӮҖ (рқ“Ҝ' , рқ“Ә')

hom-ev^вӮҒ рқ“Ҝ рқ“Ҝ' рқ“Ә рқ“Ә' e e' =
  _вӮҒ_ (hom (ev^)) {рқ“Ҝ , рқ“Ә} {рқ“Ҝ' , рқ“Ә'} (e , e')

nrecвӮӮ :
  {C : Ty}
  {О“ : Cx}
  {рқ“¬вӮҖ рқ“¬вӮҖ' : вҲЈ рқ““ C вҠҷ О“ вҲЈ}
  {рқ“¬вӮҠ рқ“¬вӮҠ' : вҲЈ рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷ О“ вҲЈ}
  (рқ“Ә рқ“Ә' : вҲЈ рқ““ рқҗҚрқҗҡрқҗӯ вҠҷ О“ вҲЈ)
  (_ : рқ““ C вҠҷ О“ вҲӢ рқ“¬вӮҖ ~ рқ“¬вӮҖ')
  (_ : рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷ О“ вҲӢ рқ“¬вӮҠ ~ рқ“¬вӮҠ')
  (_ : рқ““ рқҗҚрқҗҡрқҗӯ вҠҷ О“ вҲӢ рқ“Ә ~ рқ“Ә')
  вҶ’ ----------------------------------------------
  рқ““ C вҠҷ О“ вҲӢ nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ рқ“Ә ~ nrecвӮҒ{C} рқ“¬вӮҖ' рқ“¬вӮҠ' рқ“Ә'

nrecвӮӮ (mkвҲЈNormвҲЈ рқҗірқҗһрқҗ«рқҗЁ Zero) (mkвҲЈNormвҲЈ _ Zero) e _ refl = e
nrecвӮӮ{C}{О“}{рқ“¬вӮҠ = рқ“¬вӮҠ}{рқ“¬вӮҠ'}
  (mkвҲЈNormвҲЈ (рқҗ¬рқҗ®рқҗңрқҗң a) (Succ q))
  (mkвҲЈNormвҲЈ _ (Succ q')) eвӮҖ eвӮҒ refl =
  let
    рқ“Ә : вҲЈ Norm рқҗҚрқҗҡрқҗӯ вҠҷ О“ вҲЈ
    рқ“Ә = mkвҲЈNormвҲЈ a q
    рқ“Ә' : вҲЈ Norm рқҗҚрқҗҡрқҗӯ вҠҷ О“ вҲЈ
    рқ“Ә' = mkвҲЈNormвҲЈ a q'
  in
  hom-ev^вӮҒ{C}{C}
    (hom ev^ вӮҖ (рқ“¬вӮҠ , рқ“Ә))
    (hom ev^ вӮҖ (рқ“¬вӮҠ' , рқ“Ә'))
    _
    _
    (hom-ev^вӮҒ{рқҗҚрқҗҡрқҗӯ}{C вҮ’ C} рқ“¬вӮҠ рқ“¬вӮҠ' рқ“Ә рқ“Ә' eвӮҒ refl)
    (nrecвӮӮ{C} рқ“Ә рқ“Ә' eвӮҖ eвӮҒ refl)

nrecвӮӮ{C}{О“}{рқ“¬вӮҖ}{рқ“¬вӮҖ'}{рқ“¬вӮҠ}{рқ“¬вӮҠ'}
  (mkвҲЈNormвҲЈ a (Neu q))
  (mkвҲЈNormвҲЈ a (Neu q')) eвӮҖ eвӮҒ refl =
  hom (вҶ‘ C) вӮҒ e
  where
  e : рқҗ§рқҗ«рқҗһрқҗң (вҶ“вӮҖ C рқ“¬вӮҖ) (вҶ“вӮҖ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) рқ“¬вӮҠ) a вүЎ
      рқҗ§рқҗ«рқҗһрқҗң (вҶ“вӮҖ C рқ“¬вӮҖ') (вҶ“вӮҖ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) рқ“¬вӮҠ') a
  e rewrite hom (вҶ“ C) вӮҒ eвӮҖ
    | _вӮҒ_ (hom (вҶ“ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C))) {x = рқ“¬вӮҠ}{рқ“¬вӮҠ'} eвӮҒ = refl

nrecвӮғ :
  {C : Ty}
  {О“ О“' : Cx}
  (рқ“¬вӮҖ : вҲЈ рқ““ C вҠҷ О“ вҲЈ)
  (рқ“¬вӮҠ : вҲЈ рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷ О“ вҲЈ)
  (рқ“Ә : вҲЈ рқ““ рқҗҚрқҗҡрқҗӯ вҠҷ О“ вҲЈ)
  (p : вҲЈ О“' вҶ’бөЈ О“ вҲЈ)
  вҶ’ ----------------------------
  рқ““ C вҠҷ О“' вҲӢ
  nrecвӮҒ{C}
    (рқ““ C вҠҷвҖІ p вӮҖ рқ“¬вӮҖ)
    (рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷвҖІ p вӮҖ рқ“¬вӮҠ)
    (рқ““ рқҗҚрқҗҡрқҗӯ вҠҷвҖІ p вӮҖ рқ“Ә)
  ~
  рқ““ C вҠҷвҖІ p вӮҖ (nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ рқ“Ә)

nrecвӮғ{C}{О“' = О“'} рқ“¬вӮҖ _ (mkвҲЈNormвҲЈ _ Zero) p =
  ~Refl (рқ““ C вҠҷ О“') (рқ““ C вҠҷвҖІ p вӮҖ рқ“¬вӮҖ)
nrecвӮғ{C}{О“}{О“'} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ (рқҗ¬рқҗ®рқҗңрқҗң a) (Succ q)) p =
  ~Trans (рқ““ C вҠҷ О“')
    (hom-ev^вӮҒ{C}{C}
      (hom ev^ вӮҖ (рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷвҖІ p вӮҖ рқ“¬вӮҠ , _))
      (рқ““ (C вҮ’ C) вҠҷвҖІ p вӮҖ (hom ev^ вӮҖ (рқ“¬вӮҠ , mkвҲЈNormвҲЈ a q)))
      (nrecвӮҒ {C}
        (рқ““ C вҠҷвҖІ p вӮҖ рқ“¬вӮҖ)
        (рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) вҠҷвҖІ p вӮҖ рқ“¬вӮҠ)
        (рқ““ рқҗҚрқҗҡрқҗӯ вҠҷвҖІ p вӮҖ (mkвҲЈNormвҲЈ a q)))
      (рқ““ C вҠҷвҖІ p вӮҖ nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ _ q))
      (ntl ev^ p (рқ“¬вӮҠ , mkвҲЈNormвҲЈ a q))
      (nrecвӮғ{C} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ a q) p))
    (ntl ev^ p
      (hom ev^ вӮҖ (рқ“¬вӮҠ , mkвҲЈNormвҲЈ a q) ,
       nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ a q)))

nrecвӮғ{C}{О“' = О“'} рқ“¬вӮҖ рқ“¬вӮҠ (mkвҲЈNormвҲЈ a (Neu q)) p = ~Trans (рқ““ C вҠҷ О“')
  (hom (вҶ‘ C) вӮҒ congвӮғ рқҗ§рқҗ«рқҗһрқҗң
    (ntl (вҶ“ C) p рқ“¬вӮҖ)
    (ntl (вҶ“ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C)) p рқ“¬вӮҠ)
    refl)
  (ntl (вҶ‘ C) p
    (mkвҲЈNeutвҲЈ (рқҗ§рқҗ«рқҗһрқҗң (вҶ“вӮҖ C рқ“¬вӮҖ) (вҶ“вӮҖ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C) рқ“¬вӮҠ) a)
              (Nrec (вҶ“вӮҖвҠў рқ“¬вӮҖ) (вҶ“вӮҖвҠў рқ“¬вӮҠ) q)))

вҹҰрқҗірқҗһрқҗ«рқҗЁвҹ§ : вҲҖ{О“} вҶ’ в„қ^[ рқ“” О“ вҹ¶ Norm рқҗҚрқҗҡрқҗӯ ]

hom вҹҰрқҗірқҗһрқҗ«рқҗЁвҹ§ {О“} вӮҖ _ = mkвҲЈNormвҲЈ рқҗірқҗһрқҗ«рқҗЁ Zero
hom вҹҰрқҗірқҗһрқҗ«рқҗЁвҹ§ вӮҒ _ = refl
ntl вҹҰрқҗірқҗһрқҗ«рқҗЁвҹ§ _ _ = refl

вҹҰрқҗ¬рқҗ®рқҗңрқҗңвҹ§ : в„қ^[ Norm рқҗҚрқҗҡрқҗӯ вҹ¶ Norm рқҗҚрқҗҡрқҗӯ ]

hom вҹҰрқҗ¬рқҗ®рқҗңрқҗңвҹ§ вӮҖ mkвҲЈNormвҲЈ a q = mkвҲЈNormвҲЈ (рқҗ¬рқҗ®рқҗңрқҗң a) (Succ q)
hom вҹҰрқҗ¬рқҗ®рқҗңрқҗңвҹ§ вӮҒ refl = refl
ntl вҹҰрқҗ¬рқҗ®рқҗңрқҗңвҹ§ _ _ = refl


вҹҰрқҗ§рқҗ«рқҗһрқҗңвҹ§ : вҲҖ{C} вҶ’ в„қ^[ рқ““ C Г—^ (рқ““ (рқҗҚрқҗҡрқҗӯ вҮ’ C вҮ’ C)) Г—^ рқ““ рқҗҚрқҗҡрқҗӯ вҹ¶ рқ““ C ]

hom (вҹҰрқҗ§рқҗ«рқҗһрқҗңвҹ§{C}) вӮҖ ((рқ“¬вӮҖ , рқ“¬вӮҠ) , рқ“Ә) = nrecвӮҒ{C} рқ“¬вӮҖ рқ“¬вӮҠ рқ“Ә
_вӮҒ_ (hom (вҹҰрқҗ§рқҗ«рқҗһрқҗңвҹ§{C})) {_ , рқ“Ә} {_ , рқ“Ә'} ((eвӮҒ , eвӮӮ) , eвӮғ) =
  nrecвӮӮ{C} рқ“Ә рқ“Ә' eвӮҒ eвӮӮ eвӮғ
ntl (вҹҰрқҗ§рқҗ«рқҗһрқҗңвҹ§{C}) p ((рқ“¬вӮҖ , рқ“¬вӮҠ) , рқ“Ә) = nrecвӮғ {C} рқ“¬вӮҖ рқ“¬вӮҠ рқ“Ә p

вҹҰ Var q вҹ§ = val q
вҹҰ Lam q x# вҹ§ = cur^ вҹҰ q вҹ§
вҹҰ App qвӮҖ qвӮҒ вҹ§ = ev^ вҲҳ pair^ вҹҰ qвӮҖ вҹ§ вҹҰ qвӮҒ вҹ§
вҹҰ_вҹ§{О“ } Zero = вҹҰрқҗірқҗһрқҗ«рқҗЁвҹ§{О“}
вҹҰ Succ q вҹ§ = вҹҰрқҗ¬рқҗ®рқҗңрқҗңвҹ§ вҲҳ вҹҰ q вҹ§
вҹҰ Nrec{C} qвӮҖ qвӮҒ qвӮӮ вҹ§ =
  вҹҰрқҗ§рқҗ«рқҗһрқҗңвҹ§{C} вҲҳ pair^ (pair^ вҹҰ qвӮҖ вҹ§ вҹҰ qвӮҒ вҹ§) вҹҰ qвӮӮ вҹ§

infix 0 вҹҰ_вҹ§вӮҖ
вҹҰ_вҹ§вӮҖ :
  {О“ О“' : Cx}
  {a : Tm}
  {A : Ty}
  (_ : О“ вҠў a вҲ¶ A)
  (_ : вҲЈ рқ“” О“ вҠҷ О“' вҲЈ)
  вҶ’ ----------------
  вҲЈ рқ““ A вҠҷ О“' вҲЈ

вҹҰ q вҹ§вӮҖ рқ“ј = hom вҹҰ q вҹ§ вӮҖ рқ“ј

----------------------------------------------------------------------
-- Semantics of renaming
----------------------------------------------------------------------
вҹҰrnвҹ§ :
  {О“ О“' О“'' : Cx}
  {A : Ty}
  {a : Tm}
  (p : в„қ[ О“' вҹ¶ О“ ])
  (рқ“ј : вҲЈ рқ“” О“' вҠҷ О“'' вҲЈ)
  (q : О“ вҠў a вҲ¶ A)
  вҶ’ ----------------------------------------------
  рқ““ A вҠҷ О“'' вҲӢ вҹҰ rnвҠў (pf p) q вҹ§вӮҖ рқ“ј ~ вҹҰ q вҹ§вӮҖ (p вҠҡ рқ“ј)

rnSem :
  {О“ О“' О“'' : Cx}
  {A A' : Ty}
  {a a' : Tm}
  (p : в„қ[ О“' вҹ¶ О“ ])
  (рқ“ј : вҲЈ рқ“” О“' вҠҷ О“'' вҲЈ)
  (q : О“ вҠў a вҲ¶ A)
  (q' : О“' вҠў a' вҲ¶ A')
  (_ : rn p * a вүЎ a')
  (e : A вүЎ A')
  вҶ’ --------------------------------------------
  рқ““ A' вҠҷ О“'' вҲӢ вҹҰ q' вҹ§вӮҖ рқ“ј ~
  subst (О» X вҶ’ вҲЈ рқ““ X вҠҷ О“'' вҲЈ) e (вҹҰ q вҹ§вӮҖ (p вҠҡ рқ“ј))

вҹҰrnвҹ§ p рқ“ј q = rnSem p рқ“ј q (rnвҠў (pf p) q) refl refl

rnSem{О“}{О“'}{О“''} p рқ“ј
  (Lam{A}{B}{b}{x} q x#)
  (Lam{x = x'} q' x'#)
  refl e {О“'''} (p' , рқ“Ә)
  with refl вҶҗ ПҖвӮӮ (вҮ’inj e)
  rewrite ! вҰғ !вүЎ вҰ„ e refl = ~Trans (рқ““ B вҠҷ О“''')
    (rnSem p'' (рқ“” О“' вҠҷвҖІ p' вӮҖ рқ“ј , рқ“Ә) q q' e' refl)
    (hom вҹҰ q вҹ§ вӮҒ рқ“®)
  where
  p'' : вҲЈ (О“' вЁҹ x' вҲ¶ A) вҶ’бөЈ (О“ вЁҹ x вҲ¶ A) вҲЈ
  p'' = p вӢү[ x , x' ] A

  e' : rn p'' * (b [ x ]) вүЎ (rn p * b)[ x' ]
  e' = rnUpdate[] (rn p) x x' b x#

  рқ“® : рқ“” (О“ вЁҹ x вҲ¶ A) вҠҷ О“''' вҲӢ
    p'' вҠҡ (рқ“” О“' вҠҷвҖІ p' вӮҖ рқ“ј , рқ“Ә) ~ (рқ“” О“ вҠҷвҖІ p' вӮҖ (p вҠҡ рқ“ј) , рқ“Ә)
  рқ“® = ~Trans (рқ“” (О“ вЁҹ x вҲ¶ A) вҠҷ О“''')
    (renUpdate p (рқ“” О“' вҠҷвҖІ p' вӮҖ рқ“ј) рқ“Ә)
    (ntlвҠҡ p p' рқ“ј , ~Refl (рқ““ A вҠҷ О“''') рқ“Ә)

rnSem p рқ“ј (Var q) (Var q') refl refl = renVal p рқ“ј q q'

rnSem{О“'' = О“''}{B} p рқ“ј
  (App{A = A} qвӮҖ qвӮҒ) (App{A = A'} qвӮҖ' qвӮҒ') refl refl
  with refl вҶҗ svTy qвӮҒ' (rnвҠў (pf p) qвӮҒ) =
  hom-ev^вӮҒ{A}{B}
    (вҹҰ qвӮҖ' вҹ§вӮҖ рқ“ј)
    (вҹҰ qвӮҖ вҹ§вӮҖ (p вҠҡ рқ“ј))
    (вҹҰ qвӮҒ' вҹ§вӮҖ рқ“ј)
    (вҹҰ qвӮҒ вҹ§вӮҖ (p вҠҡ рқ“ј))
    (rnSem p рқ“ј qвӮҖ qвӮҖ' refl refl)
    (rnSem p рқ“ј qвӮҒ qвӮҒ' refl refl)

rnSem _ _ Zero Zero refl refl = refl

rnSem p рқ“ј (Succ q) (Succ q') refl refl =
  cong рқҗ¬рқҗ®рқҗңрқҗң (rnSem p рқ“ј q q' refl refl)

rnSem{О“'' = О“''}{C} p рқ“ј
  (Nrec qвӮҖ qвӮҒ qвӮӮ) (Nrec qвӮҖ' qвӮҒ' qвӮӮ') refl refl = nrecвӮӮ{C}
  (вҹҰ qвӮӮ' вҹ§вӮҖ рқ“ј)
  (вҹҰ qвӮӮ вҹ§вӮҖ (p вҠҡ рқ“ј))
  (rnSem p рқ“ј qвӮҖ qвӮҖ' refl refl)
  (rnSem p рқ“ј qвӮҒ qвӮҒ' refl refl)
  (rnSem p рқ“ј qвӮӮ qвӮӮ' refl refl)

-- The semantics of terms is proof irrelevant
irrelSem :
  {О“ О“' : Cx}
  {A : Ty}
  {a a' : Tm}
  (q : О“ вҠў a вҲ¶ A)
  (q' : О“ вҠў a' вҲ¶ A)
  (_ : a вүЎ a')
  (рқ“ј : вҲЈ рқ“” О“ вҠҷ О“' вҲЈ)
  вҶ’ ------------------------------
  рқ““ A вҠҷ О“' вҲӢ вҹҰ q вҹ§вӮҖ рқ“ј ~ вҹҰ q' вҹ§вӮҖ рқ“ј

irrelSem{О“}{О“'}{A}{a} q q' refl рқ“ј  =
