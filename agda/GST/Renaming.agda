module GST.Renaming where

open import Prelude
open import WSLN

open import GST.Syntax
open import GST.Context
open import GST.TypeSystem
open import GST.WellScoped
open import GST.Setoid

----------------------------------------------------------------------
-- Well-typed renaming
----------------------------------------------------------------------
infix 4 _вКҐ ≥_вИґ_
data _вКҐ ≥_вИґ_ (ќУ' : Cx) : Rn вЖТ Cx вЖТ Set where
  вЧЗ :
    {ѕБ : Rn}
    вЖТ ------------
    ќУ' вКҐ ≥ ѕБ вИґ вЧЗ
  [] :
    {ќУ : Cx}
    {ѕБ : Rn}
    {A : Ty}
    {x : рЭФЄ}
    в¶Г _ : x # ќУ в¶Д
    (qвВА : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
    (qвВБ : (ѕБ x , A) isIn ќУ')
    вЖТ ----------------------
    ќУ' вКҐ ≥ ѕБ вИґ (ќУ в®Я x вИґ A)

[]вВА :
  {ќУ ќУ' : Cx}
  {ѕБ : Rn}
  {A : Ty}
  {x : рЭФЄ}
  в¶Г _ : x # ќУ в¶Д
  (_ : ќУ' вКҐ ≥ ѕБ вИґ (ќУ в®Я x вИґ A))
  вЖТ -------------------------
  ќУ' вКҐ ≥ ѕБ вИґ ќУ

[]вВА ([] q _) = q

[]вВБ :
  {ќУ ќУ' : Cx}
  {ѕБ : Rn}
  {A : Ty}
  {x : рЭФЄ}
  в¶Г _ : x # ќУ в¶Д
  (_ : ќУ' вКҐ ≥ ѕБ вИґ (ќУ в®Я x вИґ A))
  вЖТ -------------------------
  (ѕБ x , A) isIn ќУ'

[]вВБ ([] _ q) = q

----------------------------------------------------------------------
-- Setoid of renamings of variables in a given context
----------------------------------------------------------------------
infix 1 Rn[_]
Rn[_] : Cx вЖТ Setd

вИ£ Rn[ ќУ ] вИ£ = Rn
Rn[ ќУ ] вИЛ ѕБ ~ ѕБ' = вИА x вЖТ x вИИ dom ќУ вЖТ ѕБ x вЙ° ѕБ' x
~Refl Rn[ ќУ ] _ _ _ = refl
~Symm Rn[ ќУ ] e x r = symm (e x r )
~Trans Rn[ ќУ ] e e' x r = trans (e x r) (e' x r)

rnUpdate# :
  {ќУ : Cx}
  {x x' : рЭФЄ}
  (ѕБ : Rn)
  (_ : x # ќУ)
  вЖТ --------------------------
  Rn[ ќУ ] вИЛ  ѕБ ~ (ѕБ вИШ/ x := x')

rnUpdate# {x = x} _ x#ќУ y yвИИќУ with x вЙР y
... | no _ = refl
... | equ = √Шelim ((вИЙвЖТ¬ђвИИ x#ќУ) yвИИќУ)

----------------------------------------------------------------------
-- Renaming is well scoped
----------------------------------------------------------------------
rnDom :
  {ќУ ќУ' : Cx}
  {ѕБ : Rn}
  {x : рЭФЄ}
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  (_ : x вИИ dom ќУ)
  вЖТ ---------------
  ѕБ x вИИ dom ќУ'

rnDom ([] p _) (вИИвИ™вВБ q)    = rnDom p q
rnDom ([] _ q) (вИИвИ™вВВ вИИпљЫпљЭ) = isInвЖТdom q

Rn[]вИШ :
  {ќУ ќУ' : Cx}
  {ѕБ ѕБ' ѕБвВБ ѕБвВБ' : Rn}
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  (_ : Rn[ ќУ ] вИЛ ѕБ ~ ѕБ')
  (_ : Rn[ ќУ' ] вИЛ ѕБвВБ ~ ѕБвВБ')
  вЖТ -------------------------
  Rn[ ќУ ] вИЛ ѕБвВБ вИШ ѕБ ~ ѕБвВБ' вИШ ѕБ'

Rn[]вИШ {ѕБ = ѕБ}{ѕБвВБ' = ѕБвВБ'} p e eвВБ x r =
  trans (eвВБ (ѕБ x) (rnDom p r)) (cong ѕБвВБ' (e x r))

----------------------------------------------------------------------
-- Types of variables under renaming
----------------------------------------------------------------------
вКҐrnVar :
  {ѕБ : Rn}
  {ќУ ќУ' : Cx}
  {x : рЭФЄ}
  {A : Ty}
  (_ : (x , A) isIn ќУ)
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  вЖТ ------------------
  (ѕБ x , A) isIn ќУ'

вКҐrnVar (isInNew refl) ([] _ q) = q
вКҐrnVar (isInOld p)    ([] q _) = вКҐrnVar p q

----------------------------------------------------------------------
-- Weakening
----------------------------------------------------------------------
wkRn :
  {ќУ ќУ' : Cx}
  {ѕБ : Rn}
  {A : Ty}
  {x : рЭФЄ}
  в¶Г _ : x # ќУ' в¶Д
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  вЖТ -------------------
  ќУ' в®Я x вИґ A вКҐ ≥ ѕБ вИґ ќУ

wkRn вЧЗ = вЧЗ
wkRn ([] qвВА qвВБ) = [] (wkRn qвВА) (isInOld qвВБ)

----------------------------------------------------------------------
-- Identity renaming
----------------------------------------------------------------------
вКҐ ≥id :
  {ќУ : Cx}
  вЖТ ---------
  ќУ вКҐ ≥ id вИґ ќУ

вКҐ ≥id {вЧЗ} = вЧЗ
вКҐ ≥id {_ в®Я _ вИґ _} = [] (wkRn вКҐ ≥id) (isInNew refl)

----------------------------------------------------------------------
-- Composing renamings
----------------------------------------------------------------------
вКҐ ≥вИШ :
  {ќУ ќУ' ќУ'' : Cx}
  {ѕБ ѕБ' : Rn}
  (_ : ќУ'' вКҐ ≥ ѕБ' вИґ ќУ')
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  вЖТ ------------------
  ќУ'' вКҐ ≥ ѕБ' вИШ ѕБ вИґ ќУ

вКҐ ≥вИШ q вЧЗ  = вЧЗ
вКҐ ≥вИШ q ([] qвВА qвВБ) = [] (вКҐ ≥вИШ q qвВА) (вКҐrnVar qвВБ q)

----------------------------------------------------------------------
-- Extensionality property of well-typed renamings
----------------------------------------------------------------------
вКҐ ≥Ext :
  {ѕБ ѕБ' : Rn}
  {ќУ ќУ' : Cx}
  (_ : Rn[ ќУ ] вИЛ ѕБ ~ ѕБ')
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  вЖТ --------------------
  ќУ' вКҐ ≥ ѕБ' вИґ ќУ

вКҐ ≥Ext _ вЧЗ = вЧЗ
вКҐ ≥Ext e ([]{x = x} q q')
  rewrite e x (вИИвИ™вВВ вИИпљЫпљЭ) = []
  (вКҐ ≥Ext (ќї x' x'вИИќУ вЖТ e x' (вИИвИ™вВБ x'вИИќУ)) q) q'

----------------------------------------------------------------------
-- Lifting
----------------------------------------------------------------------
liftRn :
  {ѕБ : Rn}
  {ќУ ќУ' : Cx}
  {A : Ty}
  {x x' : рЭФЄ}
  в¶Г _ : x # ќУ в¶Д
  в¶Г _ : x' # ќУ' в¶Д
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  вЖТ -----------------------------------------
  ќУ' в®Я x' вИґ A вКҐ ≥ (ѕБ вИШ/ x := x') вИґ (ќУ в®Я x вИґ A)

liftRn{ѕБ}{ќУ}{ќУ'}{A}{x}{x'} q = []
  (вКҐ ≥Ext (rnUpdate# ѕБ it) (wkRn q))
  (subst (ќї z вЖТ (z , A) isIn (ќУ' в®Я x' вИґ A))
    (symm (:=Eq{f = ѕБ}{x'} x))
    (isInNew refl))

----------------------------------------------------------------------
-- Renaming preserves typing
----------------------------------------------------------------------
rnвКҐ :
  {ѕБ : Rn}
  {ќУ ќУ' : Cx}
  {A : Ty}
  {a : Tm}
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  (_ : ќУ вКҐ a вИґ A)
  вЖТ ---------------
  ќУ' вКҐ ѕБ * a вИґ A

rnвКҐ p (Var q) = Var (вКҐrnVar q p)
rnвКҐ{ѕБ}{ќУ' = ќУ'} p (Lam{A}{B}{b}{x} q x#b)
  with (x' , x'#ѕБb вИЙвИ™ x'#ќУ') вЖР fresh (ѕБ * b , ќУ') = Lam
    (subst (ќї c вЖТ ќУ' в®Я x' вИґ A вКҐ c вИґ B)
      (rnUpdate[] ѕБ x x' b x#b)
      (rnвКҐ (liftRn p) q))
    x'#ѕБb
  where
  instance
    _ : x' # ќУ'
    _ = x'#ќУ'
rnвКҐ p (App qвВА qвВБ) = App (rnвКҐ p qвВА) (rnвКҐ p qвВБ)
rnвКҐ p Zero = Zero
rnвКҐ p (Succ q) = Succ (rnвКҐ p q)
rnвКҐ p (Nrec qвВА qвВБ qвВВ) = Nrec (rnвКҐ p qвВА) (rnвКҐ p qвВБ) (rnвКҐ p qвВВ)

rnвКҐ¬є :
  {ќУ : Cx}
  {A B : Ty}
  (x x' : рЭФЄ)
  в¶Г _ : x # ќУ в¶Д
  в¶Г _ : x' # ќУ в¶Д
  (b : Tm[ 1 ])
  (_ : ќУ в®Я x вИґ A вКҐ b [ x ] вИґ B)
  (_ : x # b)
  (_ : x' # b)
  вЖТ ----------------------------
  ќУ в®Я x' вИґ A вКҐ b [ x' ] вИґ B

rnвКҐ¬є{ќУ}{A}{B} x x' b q x#b x'вИЙb =
  subst (ќї c вЖТ ќУ в®Я x' вИґ A вКҐ c вИґ B)
    e
    (rnвКҐ (liftRn вКҐ ≥id) q)
  where
  e : (x := x') * (b [ x ]) вЙ° b [ x' ]
  e rewrite rnUpdate[] id x x' b x#b
    | rnUnit b = refl

----------------------------------------------------------------------
-- Renaming preserves conversion
----------------------------------------------------------------------
rnпЉЭ :
  {ѕБ : Rn}
  {ќУ ќУ' : Cx}
  {A : Ty}
  {a a' : Tm}
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  (_ : ќУ вКҐ a пЉЭ a' вИґ A)
  вЖТ ----------------------
  ќУ' вКҐ ѕБ * a пЉЭ ѕБ * a' вИґ A

rnпЉЭ p (Refl q) = Refl (rnвКҐ p q)
rnпЉЭ p (Symm q) = Symm (rnпЉЭ p q)
rnпЉЭ p (Trans qвВА qвВБ) = Trans (rnпЉЭ p qвВА) (rnпЉЭ p qвВБ)
rnпЉЭ{ѕБ}{ќУ' = ќУ'} p (Lam{A}{B}{b}{b'}{x} q (x#b вИЙвИ™ x#b'))
  with (x' , x'# вИЙвИ™ x'#ќУ') вЖР fresh ((ѕБ * b , ѕБ * b') , ќУ') = Lam
    (substвВВ (ќї c c' вЖТ ќУ' в®Я x' вИґ A вКҐ c пЉЭ c' вИґ B)
      (rnUpdate[] ѕБ x x' b x#b)
      (rnUpdate[] ѕБ x x' b' x#b')
      (rnпЉЭ (liftRn p) q))
    x'#
  where
  instance
    _ : x' # ќУ'
    _ = x'#ќУ'
rnпЉЭ p (App qвВА qвВБ) = App (rnпЉЭ p qвВА) (rnпЉЭ p qвВБ)
rnпЉЭ p (Succ q) = Succ (rnпЉЭ p q)
rnпЉЭ p (Nrec qвВА qвВБ qвВВ) =
  Nrec (rnпЉЭ p qвВА) (rnпЉЭ p qвВБ) (rnпЉЭ p qвВВ)
rnпЉЭ{ѕБ}{ќУ' = ќУ'} p (BetaLam{A}{B}{a}{b}{x} qвВА qвВБ x#b)
  with (x' , x'# вИЙвИ™ x'#ќУ') вЖР fresh (ѕБ * b , ќУ')
  rewrite rn[] ѕБ b a =
  BetaLam{b = ѕБ * b}
    (subst (ќї c вЖТ ќУ' в®Я x' вИґ A вКҐ c вИґ B)
        (rnUpdate[] ѕБ x x' b x#b)
        (rnвКҐ (liftRn p) qвВА))
    (rnвКҐ p qвВБ)
    x'#
  where
  instance
    _ : x' # ќУ'
    _ = x'#ќУ'
rnпЉЭ p (BetaZero qвВА qвВБ) =
  BetaZero (rnвКҐ p qвВА) (rnвКҐ p qвВБ)
rnпЉЭ p (BetaSucc qвВА qвВБ qвВВ) =
  BetaSucc (rnвКҐ p qвВА) (rnвКҐ p qвВБ) (rnвКҐ p qвВВ)
rnпЉЭ{ѕБ}{ќУ' = ќУ'} p (Eta{b = b}{x} q x#b)
  with (x' , x'# вИЙвИ™ x'вИЙќУ') вЖР fresh (ѕБ * b , ќУ')
  rewrite
    (rnAbs ѕБ x x' (b вИЩ рЭРѓ x) ќї{
      _ (вИИвИ™вВБ q') _ refl вЖТ
        вИЙвЖТ¬ђвИИ x'вИЙќУ' (rnDom  p (suppвКҐ q q')) ;
      _ (вИИвИ™вВВ (вИИвИ™вВБ вИИпљЫпљЭ)) q' refl вЖТ q' refl})
  | :=Eq {f = ѕБ}{x'} x
  | updateFreshRn ѕБ x x' b x#b =
  Eta{x = x'} (rnвКҐ p q) x'#

rnпЉЭ¬є :
  {ќУ : Cx}
  {A B : Ty}
  (x x' : рЭФЄ)
  в¶Г _ : x # ќУ в¶Д
  в¶Г _ : x' # ќУ в¶Д
  (b b' : Tm[ 1 ])
  (_ : ќУ в®Я x вИґ A вКҐ b [ x ] пЉЭ b' [ x ] вИґ B)
  (_ : x # (b , b'))
  (_ : x' # (b , b'))
  вЖТ ---------------------------------------
  ќУ в®Я x' вИґ A вКҐ b [ x' ] пЉЭ b' [ x' ] вИґ B

rnпЉЭ¬є{ќУ}{A}{B} x x' b b' q (x#b вИЙвИ™ x#b') (x'вИЙb вИЙвИ™ x'#b') =
  substвВВ (ќї c c' вЖТ ќУ в®Я x' вИґ A вКҐ c пЉЭ c' вИґ B)
    e
    e'
    (rnпЉЭ (liftRn вКҐ ≥id) q)
  where
  e : (x := x') * (b [ x ]) вЙ° b [ x' ]
  e rewrite rnUpdate[] id x x' b x#b
    | rnUnit b = refl
  e' : (x := x') * (b' [ x ]) вЙ° b' [ x' ]
  e' rewrite rnUpdate[] id x x' b' x#b'
    | rnUnit b' = refl

----------------------------------------------------------------------
-- Weakening
----------------------------------------------------------------------
wkвКҐ :
  {ќУ : Cx}
  {A A' : Ty}
  {a : Tm}
  {x : рЭФЄ}
  (_ : ќУ вКҐ a вИґ A)
  в¶Г _ : x # ќУ в¶Д
  вЖТ ----------------
  ќУ в®Я x вИґ A' вКҐ a вИґ A

wkвКҐ {ќУ}{A}{A'}{a}{x} q = subst (ќї b вЖТ ќУ в®Я x вИґ A' вКҐ b вИґ A)
  (rnUnit a)
  (rnвКҐ (wkRn вКҐ ≥id) q)

wkпЉЭ :
  {ќУ : Cx}
  {A A' : Ty}
  {a a' : Tm}
  {x : рЭФЄ}
  (_ : ќУ вКҐ a пЉЭ a' вИґ A)
  в¶Г _ : x # ќУ в¶Д
  вЖТ ----------------------
  ќУ в®Я x вИґ A' вКҐ a пЉЭ a' вИґ A

wkпЉЭ {ќУ}{A}{A'}{a}{a'}{x} q =
  substвВВ (ќї b b' вЖТ ќУ в®Я x вИґ A' вКҐ b пЉЭ b' вИґ A)
    (rnUnit a)
    (rnUnit a')
    (rnпЉЭ (wkRn вКҐ ≥id) q)

----------------------------------------------------------------------
-- Support-respecting renaming of terms
----------------------------------------------------------------------
rnRespSuppTm :
  {ќУ ќУ' : Cx}
  {A : Ty}
  {a a' : Tm}
  {ѕБ ѕБ' : Rn}
  (_ : ќУ вКҐ a пЉЭ a' вИґ A)
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  (_ : Rn[ ќУ ] вИЛ ѕБ ~ ѕБ')
  вЖТ -----------------------
  ќУ' вКҐ ѕБ * a пЉЭ ѕБ' * a' вИґ A

rnRespSuppTm {ќУ' = ќУ'}{A}{a}{a'}{ѕБ}{ѕБ'} q p e =
  subst (ќї b вЖТ ќУ' вКҐ ѕБ * a пЉЭ b вИґ A)
  (rnRespSupp ѕБ ѕБ' a' ќї x xвИИa' вЖТ e x (suppпЉЭвВВ q xвИИa'))
  (rnпЉЭ p q)

----------------------------------------------------------------------
-- Unitary and associative laws
----------------------------------------------------------------------
вКҐrnUnit :
  {ќУ : Cx}
  {A : Ty}
  {a : Tm}
  (_ : ќУ вКҐ a вИґ A)
  вЖТ ------------------
  ќУ вКҐ id ≥ * a пЉЭ a вИґ A

вКҐrnUnit {a = a} q rewrite rnUnit a = Refl q

вКҐrnAssoc :
  {ќУ ќУ' ќУ'' : Cx}
  {A : Ty}
  {a : Tm}
  {ѕБ ѕБ' : Rn}
  (_ : ќУ вКҐ a вИґ A)
  (_ : ќУ' вКҐ ≥ ѕБ вИґ ќУ)
  (_ : ќУ'' вКҐ ≥ ѕБ' вИґ ќУ')
  вЖТ ----------------------------------
  ќУ'' вКҐ (ѕБ' вИШ ѕБ) * a пЉЭ ѕБ' * ѕБ * a вИґ A

вКҐrnAssoc {a = a}{ѕБ}{ѕБ'} q p p'
  rewrite rnAssoc ѕБ ѕБ' a = Refl (rnвКҐ p' (rnвКҐ p q))
