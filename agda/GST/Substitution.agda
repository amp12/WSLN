module GST.Substitution where

open import Prelude
open import WSLN

open import GST.Syntax
open import GST.Context
open import GST.TypeSystem
open import GST.WellScoped
open import GST.Setoid
open import GST.Renaming

----------------------------------------------------------------------
-- Well-typed and convertible substitutions
----------------------------------------------------------------------
infix 4 _вҠўЛў_вҲ¶_
data _вҠўЛў_вҲ¶_ (О“' : Cx) : Sb вҶ’ Cx вҶ’ Set where
  в—Ү :
    {Пғ : Sb}
    вҶ’ ---------
    О“' вҠўЛў Пғ вҲ¶ в—Ү
  [] :
    {О“ : Cx}
    {Пғ : Sb}
    {A : Ty}
    {x : рқ”ё}
    вҰғ _ : x # dom О“ вҰ„
    (qвӮҖ : О“' вҠўЛў Пғ вҲ¶ О“)
    (qвӮҒ : О“' вҠў Пғ x вҲ¶ A)
    вҶ’ -------------------
    О“' вҠўЛў Пғ вҲ¶ О“ вЁҹ x вҲ¶ A

infix 4 _вҠўЛў_пјқ_вҲ¶_
data _вҠўЛў_пјқ_вҲ¶_ (О“' : Cx) : Sb вҶ’ Sb вҶ’ Cx вҶ’ Set where
  пјқв—Ү :
    {Пғ Пғ' : Sb}
    вҶ’ --------------
    О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ в—Ү
  пјқ[] :
    {О“ : Cx}
    {Пғ Пғ' : Sb}
    {A : Ty}
    {x : рқ”ё}
    вҰғ _ : x # dom О“ вҰ„
    (qвӮҖ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
    (qвӮҒ : О“' вҠў Пғ x пјқ Пғ' x вҲ¶ A)
    вҶ’ -------------------------
    О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“ вЁҹ x вҲ¶ A

вҠўКівҶ’вҠўЛў :
  {О“ О“' : Cx}
  {ПҒ : Rn}
  (_ : О“' вҠўКі ПҒ вҲ¶ О“)
  вҶ’ ---------------
  О“' вҠўЛў рқҗҡвҲҳ ПҒ вҲ¶ О“

вҠўКівҶ’вҠўЛў в—Ү = в—Ү
вҠўКівҶ’вҠўЛў ([] qвӮҖ qвӮҒ) = [] (вҠўКівҶ’вҠўЛў qвӮҖ) (Var qвӮҒ)

----------------------------------------------------------------------
-- Provable substitutions are well-scoped
----------------------------------------------------------------------
suppвҠўЛў :
  {О“ О“' : Cx}
  {Пғ : Sb}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : x вҲҲ dom О“)
  вҶ’ -----------------
  supp (Пғ x) вҠҶ dom О“'

suppвҠўЛў ([] q _) (вҲҲвҲӘвӮҒ p) = suppвҠўЛў q p
suppвҠўЛў ([] _ q) (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = suppвҠў q

suppвҠўЛўпјқвӮҒ :
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : x вҲҲ dom О“)
  вҶ’ ---------------------
  supp (Пғ x) вҠҶ dom О“'

suppвҠўЛўпјқвӮҒ (пјқ[] q _) (вҲҲвҲӘвӮҒ p) = suppвҠўЛўпјқвӮҒ q p
suppвҠўЛўпјқвӮҒ (пјқ[] _ q) (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = suppпјқвӮҒ q

suppвҠўЛўпјқвӮӮ :
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : x вҲҲ dom О“)
  вҶ’ ---------------------
  supp (Пғ' x) вҠҶ dom О“'

suppвҠўЛўпјқвӮӮ (пјқ[] q _) (вҲҲвҲӘвӮҒ p) = suppвҠўЛўпјқвӮӮ q p
suppвҠўЛўпјқвӮӮ (пјқ[] _ q) (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = suppпјқвӮӮ q

----------------------------------------------------------------------
-- Renaming well-typed substitutions
----------------------------------------------------------------------
rnSb :
  {О“ О“' О“'' : Cx}
  {ПҒ : Rn}
  {Пғ : Sb}
  (_ : О“'' вҠўКі ПҒ вҲ¶ О“')
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -----------------
  О“'' вҠўЛў рқҗҡвҲҳ ПҒ вҲҳ Пғ вҲ¶ О“

rnSb q в—Ү = в—Ү
rnSb q ([] pвӮҖ pвӮҒ) = [] (rnSb q pвӮҖ) (rnвҠў q pвӮҒ)

rnпјқSb :
  {О“ О“' О“'' : Cx}
  {ПҒ : Rn}
  {ПғвӮҒ ПғвӮӮ : Sb}
  (_ : О“'' вҠўКі ПҒ вҲ¶ О“')
  (_ : О“' вҠўЛў ПғвӮҒ пјқ ПғвӮӮ вҲ¶ О“)
  вҶ’ -----------------------------
  О“'' вҠўЛў рқҗҡвҲҳ ПҒ вҲҳ ПғвӮҒ пјқ рқҗҡвҲҳ ПҒ вҲҳ ПғвӮӮ вҲ¶ О“

rnпјқSb q пјқв—Ү = пјқв—Ү
rnпјқSb q (пјқ[] pвӮҖ pвӮҒ) = пјқ[] (rnпјқSb q pвӮҖ) (rnпјқ q pвӮҒ)

----------------------------------------------------------------------
-- Renamings as substitutions
----------------------------------------------------------------------
rn2sb :
  {О“ О“' : Cx}
  {ПҒ : Rn}
  (_ : О“' вҠўКі ПҒ вҲ¶ О“)
  вҶ’ ---------------
  О“' вҠўЛў рқҗҡвҲҳ ПҒ вҲ¶ О“

rn2sb в—Ү         = в—Ү
rn2sb ([] pвӮҖ pвӮҒ) = [] (rn2sb pвӮҖ) (Var pвӮҒ)

----------------------------------------------------------------------
-- Identity substitution is well-typed
----------------------------------------------------------------------
вҠўidЛў :
  {О“ : Cx}
  вҶ’ --------
  О“ вҠўЛў idЛў вҲ¶ О“

вҠўidЛў {в—Ү} = в—Ү
вҠўidЛў {О“ вЁҹ x вҲ¶ A} = []
  (rnSb (wkRn вҠўКіid) вҠўidЛў)
  (Var (isInNew refl))

вҠўidЛўпјқidЛў :
  {О“ : Cx}
  вҶ’ -------------
  О“ вҠўЛў idЛў пјқ idЛў вҲ¶ О“

вҠўidЛўпјқidЛў {в—Ү} = пјқв—Ү
вҠўidЛўпјқidЛў {О“ вЁҹ x вҲ¶ A} = пјқ[]
  (rnпјқSb (wkRn вҠўКіid) вҠўidЛўпјқidЛў)
  (Refl (Var (isInNew refl)))

----------------------------------------------------------------------
-- Eqivalence relation
----------------------------------------------------------------------
пјқвҲ¶Refl :
  {Пғ : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ ---------------
  О“' вҠўЛў Пғ пјқ Пғ вҲ¶ О“
пјқвҲ¶Refl в—Ү        = пјқв—Ү
пјқвҲ¶Refl ([] pвӮҖ pвӮҒ) = пјқ[] (пјқвҲ¶Refl pвӮҖ) (Refl pвӮҒ)

пјқвҲ¶Symm :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  вҶ’ --------------------
  О“' вҠўЛў Пғ' пјқ Пғ вҲ¶ О“

пјқвҲ¶Symm пјқв—Ү = пјқв—Ү
пјқвҲ¶Symm (пјқ[] qвӮҖ qвӮҒ) = пјқ[] (пјқвҲ¶Symm qвӮҖ) (Symm qвӮҒ)

пјқвҲ¶Trans :
  {Пғ Пғ' Пғ'' : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“' вҠўЛў Пғ' пјқ Пғ'' вҲ¶ О“)
  вҶ’ --------------------
  О“' вҠўЛў Пғ пјқ Пғ'' вҲ¶ О“

пјқвҲ¶Trans пјқв—Ү пјқв—Ү = пјқв—Ү
пјқвҲ¶Trans (пјқ[] qвӮҖ qвӮҒ) (пјқ[] qвӮҖ' qвӮҒ') =
  пјқ[] (пјқвҲ¶Trans qвӮҖ qвӮҖ') (Trans qвӮҒ qвӮҒ')

----------------------------------------------------------------------
-- Setoid of substitutions in a given context
----------------------------------------------------------------------
infix 1 Sb[_]
Sb[_] : Cx вҶ’ Setd

вҲЈ Sb[ О“ ] вҲЈ = Sb
Sb[ О“ ] вҲӢ Пғ ~ Пғ' = вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ Пғ x вүЎ Пғ' x
~Refl Sb[ О“ ] _ _ _ = refl
~Symm Sb[ О“ ] e x r = symm (e x r )
~Trans Sb[ О“ ] e e' x r = trans (e x r) (e' x r)

sbUpdate# :
  {О“ : Cx}
  {x : рқ”ё}
  {a : Tm}
  (Пғ : Sb)
  (_ : x # О“)
  вҶ’ -------------------------
  Sb[ О“ ] вҲӢ  Пғ ~ (Пғ вҲҳ/ x := a)

sbUpdate# {x = x} _ x#О“ y yвҲҲО“ with x вүҗ y
... | no _ = refl
... | equ = Гҳelim (вҲүвҶ’В¬вҲҲ x#О“ yвҲҲО“)

----------------------------------------------------------------------
-- Extensionality properties of well-typed substitutions
----------------------------------------------------------------------
вҠўЛўExt :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  (_ : Sb[ О“ ] вҲӢ Пғ ~ Пғ')
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ --------------------
  О“' вҠўЛў Пғ' вҲ¶ О“

вҠўЛўExt _ в—Ү = в—Ү
вҠўЛўExt{Пғ}{Пғ'} e ([]{x = x} вҠўПғ вҠўПғx)
  rewrite e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = []
  (вҠўЛўExt (О» x' x'вҲҲО“ вҶ’ e x' (вҲҲвҲӘвӮҒ x'вҲҲО“)) вҠўПғ) вҠўПғx

вҠўЛўпјқExt :
  {Пғ' П„' Пғ П„ : Sb}
  {О“ О“' : Cx}
  (_ : Sb[ О“ ] вҲӢ Пғ ~ Пғ')
  (_ : Sb[ О“ ] вҲӢ П„ ~ П„')
  (_ : О“' вҠўЛў Пғ пјқ П„ вҲ¶ О“)
  вҶ’ --------------------
  О“' вҠўЛў Пғ' пјқ П„' вҲ¶ О“

вҠўЛўпјқExt _ _ пјқв—Ү = пјқв—Ү
вҠўЛўпјқExt{Пғ'}{П„'} e e' (пјқ[]{Пғ = Пғ}{П„}{A = A}{x} Пғ=П„ Пғx=Пғ'x)
  rewrite e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ)
  | e' x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = пјқ[]
  (вҠўЛўпјқExt (О» y yвҲҲО“ вҶ’ e y (вҲҲвҲӘвӮҒ yвҲҲО“)) (О» y yвҲҲО“ вҶ’ e' y (вҲҲвҲӘвӮҒ yвҲҲО“)) Пғ=П„)
  Пғx=Пғ'x

вҠўЛўвүЎExt :
  {Пғ' Пғ  : Sb}
  {О“ О“' : Cx}
  (_ : Sb[ О“ ] вҲӢ Пғ ~ Пғ')
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ --------------------
  О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“

вҠўЛўвүЎExt e q = вҠўЛўпјқExt (О» _ _ вҶ’ refl) e (пјқвҲ¶Refl q)

----------------------------------------------------------------------
-- Action of equal renamings on equal substitutions
----------------------------------------------------------------------
rnпјқSb' :
  {О“ О“' О“'' : Cx}
  {ПҒ ПҒ' : Rn}
  {ПғвӮҒ ПғвӮӮ : Sb}
  (_ : О“' вҠўЛў ПғвӮҒ пјқ ПғвӮӮ вҲ¶ О“)
  (_ : О“'' вҠўКі ПҒ вҲ¶ О“')
  (_ : Rn[ О“' ] вҲӢ ПҒ ~ ПҒ')
  вҶ’ ----------------------------------
  О“'' вҠўЛў рқҗҡвҲҳ ПҒ вҲҳЛў ПғвӮҒ пјқ рқҗҡвҲҳ ПҒ' вҲҳЛў ПғвӮӮ вҲ¶ О“

rnпјқSb'{ПҒ = ПҒ}{ПҒ'}{ПғвӮӮ = ПғвӮӮ} q p e = вҠўЛўпјқExt
  (О» _ _ вҶ’ refl)
  (О» x r вҶ’ rnRespSupp ПҒ ПҒ'
    (ПғвӮӮ x)
    О» y s вҶ’ e y (suppвҠўЛўпјқвӮӮ q r s))
  (rnпјқSb p q)

----------------------------------------------------------------------
-- Weakening
----------------------------------------------------------------------
wkSb :
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҰғ _ : x # О“' вҰ„
  вҶ’ -------------------
  О“' вЁҹ x вҲ¶ A вҠўЛў Пғ вҲ¶ О“

wkSb{Пғ = Пғ} q = вҠўЛўExt
  (О» x _ вҶ’ sbUnit (Пғ x))
  (rnSb (wkRn вҠўКіid) q)

wkпјқSb :
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {A : Ty}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  вҰғ _ : x # dom О“' вҰ„
  вҶ’ -------------------------
  О“' вЁҹ x вҲ¶ A вҠўЛў Пғ пјқ Пғ' вҲ¶ О“

wkпјқSb{Пғ = Пғ}{Пғ'} q = вҠўЛўпјқExt
  (О» x _ вҶ’ sbUnit (Пғ x))
  (О» x _ вҶ’ sbUnit (Пғ' x))
  (rnпјқSb (wkRn вҠўКіid) q)

----------------------------------------------------------------------
-- Lifting
----------------------------------------------------------------------
[]' :
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  вҰғ _ : x # О“ вҰ„
  (вҠўПғ : О“' вҠўЛў Пғ вҲ¶ О“)
  (вҠўa : О“' вҠў a вҲ¶ A)
  вҶ’ -------------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) вҲ¶ О“ вЁҹ x вҲ¶ A

[]'{О“}{О“'}{Пғ}{A}{a}{x} вҠўПғ вҠўa = []
  (вҠўЛўExt (sbUpdate# Пғ it) вҠўПғ )
  (subst (О» z вҶ’ О“' вҠў z вҲ¶ A)
    (symm (:=Eq{f = Пғ}{a} x))
    вҠўa)

пјқ[]' :
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {A : Ty}
  {a a' : Tm}
  {x : рқ”ё}
  вҰғ _ : x # О“ вҰ„
  (Пғ=Пғ' : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (a=a' : О“' вҠў a пјқ a' вҲ¶ A)
  вҶ’ --------------------------------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) пјқ (Пғ' вҲҳ/ x := a') вҲ¶ О“ вЁҹ x вҲ¶ A

пјқ[]'{О“}{О“'}{Пғ}{Пғ'}{A}{a}{a'}{x} Пғ=Пғ' a=a' = пјқ[]
  (вҠўЛўпјқExt (sbUpdate# Пғ it) (sbUpdate# Пғ' it) Пғ=Пғ')
  (substвӮӮ (О» z z' вҶ’ О“' вҠў z пјқ z' вҲ¶ A)
    (symm (:=Eq{f = Пғ}{a} x))
    (symm (:=Eq{f = Пғ'}{a'} x))
    a=a')

[]'# :
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  вҰғ _ : x # О“ вҰ„
  (вҠўПғ : О“' вҠўЛў Пғ вҲ¶ О“)
  (вҠўa : О“' вҠў a вҲ¶ A)
  вҶ’ --------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) пјқ Пғ вҲ¶ О“

[]'# {О“}{Пғ = Пғ} вҠўПғ вҠўa = вҠўЛўпјқExt
  (sbUpdate# Пғ it)
  (~Refl (Sb[ О“ ]) Пғ)
  (пјқвҲ¶Refl вҠўПғ)

liftSb :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x y : рқ”ё}
  вҰғ _ : x # dom О“ вҰ„
  вҰғ _ : y # dom О“' вҰ„
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -------------------------------------------
  О“' вЁҹ y вҲ¶ A вҠўЛў (Пғ вҲҳ/ x := рқҗҜ y) вҲ¶ О“ вЁҹ x вҲ¶ A

liftSb q = []' (wkSb q) (Var (isInNew refl))


liftпјқSb :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x y : рқ”ё}
  вҰғ _ : x # dom О“ вҰ„
  вҰғ _ : y # dom О“' вҰ„
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  вҶ’ ---------------------------------------------------------------
  О“' вЁҹ y вҲ¶ A вҠўЛў (Пғ вҲҳ/ x := рқҗҜ y) пјқ (Пғ' вҲҳ/ x := рқҗҜ y) вҲ¶ О“ вЁҹ x вҲ¶ A

liftпјқSb q = пјқ[]' (wkпјқSb q) (Refl (Var (isInNew refl)))

----------------------------------------------------------------------
-- Single substitution
----------------------------------------------------------------------
ssbвҲ¶ :
  {О“ : Cx}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  вҰғ _ : x # dom О“ вҰ„
  (_ : О“ вҠў a вҲ¶ A)
  вҶ’ -------------------------
  О“ вҠўЛў (x := a) вҲ¶ О“ вЁҹ x вҲ¶ A

ssbвҲ¶ = []' вҠўidЛў

ssbпјқвҲ¶ :
  {О“ : Cx}
  {x : рқ”ё}
  {a a' : Tm}
  {A : Ty}
  вҰғ _ : x # dom О“ вҰ„
  (_ : О“ вҠў a пјқ a' вҲ¶ A)
  вҶ’ --------------------------------------
  О“ вҠўЛў (x := a) пјқ (x := a') вҲ¶ О“ вЁҹ x вҲ¶ A

ssbпјқвҲ¶ = пјқ[]' вҠўidЛўпјқidЛў

----------------------------------------------------------------------
-- Types of variables under substitution
----------------------------------------------------------------------
вҠўsbVar :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  {A : Ty}
  (_ : (x , A) isIn О“)
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ ------------------
  О“' вҠў Пғ x вҲ¶ A

вҠўsbVar (isInNew refl) ([] _ вҠўПғx) = вҠўПғx
вҠўsbVar (isInOld p)    ([] q _)   = вҠўsbVar p q

вҠўsbConvVar :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  {A : Ty}
  (_  : (x , A) isIn О“)
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  вҶ’ --------------------
  О“' вҠў Пғ x пјқ Пғ' x вҲ¶ A

вҠўsbConvVar (isInNew refl) (пјқ[] _ ПғxпјқПғ'x) = ПғxпјқПғ'x
вҠўsbConvVar (isInOld p)    (пјқ[] q _)       = вҠўsbConvVar p q

----------------------------------------------------------------------
-- Substitution preserves typing
----------------------------------------------------------------------
sbвҠў :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {a : Tm}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў a вҲ¶ A)
  вҶ’ --------------
  О“' вҠў Пғ * a вҲ¶ A

sbвҠў{Пғ} p (Var{x = x} q)
  rewrite вҖҝunit (Пғ x) вҰғ вүӨrefl вҰ„ = вҠўsbVar q p
sbвҠў{Пғ}{О“' = О“'} p (Lam{A}{B}{b}{x} q x#b)
  with (x' , x'#Пғb вҲүвҲӘ x'#О“') вҶҗ fresh (Пғ * b , О“') = Lam
  (subst (О» c вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c вҲ¶ B)
    (sbUpdate[] Пғ x (рқҗҜ x') b x#b)
    (sbвҠў (liftSb p) q))
  x'#Пғb
  where
  instance
    _ : x' # О“'
    _ = x'#О“'
sbвҠў p (App qвӮҖ qвӮҒ) = App (sbвҠў p qвӮҖ) (sbвҠў p qвӮҒ)
sbвҠў p Zero = Zero
sbвҠў p (Succ q) = Succ (sbвҠў p q)
sbвҠў p (Nrec qвӮҖ qвӮҒ qвӮӮ) = Nrec (sbвҠў p qвӮҖ) (sbвҠў p qвӮҒ) (sbвҠў p qвӮӮ)

sbвҠўВ№ :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A B : Ty}
  {x x' : рқ”ё}
  вҰғ _ : x # О“ вҰ„
  вҰғ _ : x' # О“' вҰ„
  (b : Tm[ 1 ])
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вЁҹ x вҲ¶ A вҠў b [ x ] вҲ¶ B)
  (_ : x # b)
  (_ : x' # b)
  вҶ’ --------------------------------
  О“' вЁҹ x' вҲ¶ A вҠў (Пғ * b) [ x' ] вҲ¶ B

sbвҠўВ№{Пғ}{О“' = О“'}{A}{B}{x}{x'} b p q x#b x'#b =
  subst (О» c вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c вҲ¶ B)
    (sbUpdate[] Пғ x (рқҗҜ x') b x#b)
    (sbвҠў (liftSb p) q)

----------------------------------------------------------------------
-- Substitution preserves conversion
----------------------------------------------------------------------
sbConv :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {a a' : Tm}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў a пјқ a' вҲ¶ A)
  вҶ’ ----------------------
  О“' вҠў Пғ * a пјқ Пғ * a' вҲ¶ A

sbConv p (Refl q) = Refl (sbвҠў p q)
sbConv p (Symm q) = Symm (sbConv p q)
sbConv p (Trans qвӮҖ qвӮҒ) = Trans (sbConv p qвӮҖ) (sbConv p qвӮҒ)
sbConv{Пғ}{О“' = О“'} p (Lam{A}{B}{b}{b'}{x} q (x#b вҲүвҲӘ x#b'))
  with (x' , x'# вҲүвҲӘ x'#О“') вҶҗ fresh ((Пғ * b , Пғ * b') , О“') = Lam
    (substвӮӮ (О» c c' вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c пјқ c' вҲ¶ B)
      (sbUpdate[] Пғ x (рқҗҜ x') b x#b)
      (sbUpdate[] Пғ x (рқҗҜ x') b' x#b')
      (sbConv (liftSb p) q))
    x'#
  where
  instance
    _ : x' # О“'
    _ = x'#О“'
sbConv p (App qвӮҖ qвӮҒ) = App (sbConv p qвӮҖ) (sbConv p qвӮҒ)
sbConv p (Succ q) = Succ (sbConv p q)
sbConv p (Nrec qвӮҖ qвӮҒ qвӮӮ) =
  Nrec (sbConv p qвӮҖ) (sbConv p qвӮҒ) (sbConv p qвӮӮ)
sbConv{Пғ}{О“' = О“'} p (BetaLam{A}{B}{a}{b}{x} qвӮҖ qвӮҒ x#b)
  with (x' , x'# вҲүвҲӘ x'#О“') вҶҗ fresh (Пғ * b , О“')
  rewrite sb[] Пғ b a =
  BetaLam{b = Пғ * b}
    (subst (О» c вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c вҲ¶ B)
        (sbUpdate[] Пғ x (рқҗҜ x') b x#b)
        (sbвҠў (liftSb p) qвӮҖ))
    (sbвҠў p qвӮҒ)
    x'#
  where
  instance
    _ : x' # О“'
    _ = x'#О“'
sbConv p (BetaZero qвӮҖ qвӮҒ) =
  BetaZero (sbвҠў p qвӮҖ) (sbвҠў p qвӮҒ)
sbConv p (BetaSucc qвӮҖ qвӮҒ qвӮӮ) =
  BetaSucc (sbвҠў p qвӮҖ) (sbвҠў p qвӮҒ) (sbвҠў p qвӮӮ)
sbConv{Пғ}{О“' = О“'} p (Eta{b = b}{x} q x#b)
  with (x' , x'# вҲүвҲӘ x'вҲүО“') вҶҗ fresh (Пғ * b , О“')
  rewrite
    (sbAbs Пғ x x' (b вҲҷ рқҗҜ x)
      О»{y (вҲҲвҲӘвӮҒ q') _ вҶ’ вҠҶвҲү (suppвҠўЛў p (suppвҠў q q')) x'вҲүО“' ;
        y (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮҒ вҲҲпҪӣпҪқ)) q' вҶ’ Гҳelim (q' refl)})
  | :=Eq {f = Пғ}{рқҗҜ x'} x
  | updateFresh Пғ x (рқҗҜ x') b x#b =
  Eta{x = x'} (sbвҠў p q) x'#

sbпјқConv :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {a : Tm}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў a вҲ¶ A)
  вҶ’ ----------------------
  О“' вҠў Пғ * a пјқ Пғ' * a вҲ¶ A

sbпјқConv{Пғ}{Пғ'} p (Var{x = x} q)
  rewrite вҖҝunit (Пғ x) вҰғ вүӨrefl вҰ„
  | вҖҝunit (Пғ' x) вҰғ вүӨrefl вҰ„ = вҠўsbConvVar q p
sbпјқConv{Пғ}{Пғ'}{О“' = О“'} p (Lam{A}{B}{b}{x} q x#b)
  with (x' , x'# вҲүвҲӘ x'#О“') вҶҗ fresh ((Пғ * b , Пғ' * b) , О“') =
  Lam
    (substвӮӮ (О» c c' вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c пјқ c' вҲ¶ B)
      (sbUpdate[] Пғ x (рқҗҜ x') b x#b)
      (sbUpdate[] Пғ' x (рқҗҜ x') b x#b)
      (sbпјқConv (liftпјқSb p) q))
    x'#
  where
  instance
    _ : x' # О“'
    _ = x'#О“'
sbпјқConv p (App qвӮҖ qвӮҒ) = App
  (sbпјқConv p qвӮҖ)
  (sbпјқConv p qвӮҒ)
sbпјқConv p Zero = Refl Zero
sbпјқConv p (Succ q) = Succ (sbпјқConv p q)
sbпјқConv p (Nrec qвӮҖ qвӮҒ qвӮӮ) = Nrec
  (sbпјқConv p qвӮҖ)
  (sbпјқConv p qвӮҒ)
  (sbпјқConv p qвӮӮ)

----------------------------------------------------------------------
-- Concretion preserves typing
----------------------------------------------------------------------
вҠўconc :
  {О“ : Cx}
  {A B : Ty}
  {a : Tm}
  (b : Tm[ 1 ])
  (x : рқ”ё)
  вҰғ _ : x # О“ вҰ„
  (_ : О“ вЁҹ x вҲ¶ A вҠў b [ x ] вҲ¶ B)
  (_ : О“ вҠў a вҲ¶ A)
  (_ : x # b)
  вҶ’ ---------------------------
  О“ вҠў b [ a ] вҲ¶ B

вҠўconc{О“}{B = B}{a} b x p q x#b =
  subst (О» z вҶ’ О“ вҠў z вҲ¶ B)
    (ssb[] x a b x#b)
    (sbвҠў (ssbвҲ¶ q) p)

----------------------------------------------------------------------
-- Reflexivity Inversion
----------------------------------------------------------------------
вҠўtyвӮҒ :
  {О“ : Cx}
  {A : Ty}
  {a a' : Tm}
  (_ : О“ вҠў a пјқ a' вҲ¶ A)
  вҶ’ -------------------
  О“ вҠў a вҲ¶ A

вҠўtyвӮӮ :
  {О“ : Cx}
  {A : Ty}
  {a a' : Tm}
  (_ : О“ вҠў a пјқ a' вҲ¶ A)
  вҶ’ -------------------
  О“ вҠў a' вҲ¶ A

вҠўtyвӮҒ (Refl q) = q
вҠўtyвӮҒ (Symm q) = вҠўtyвӮӮ q
вҠўtyвӮҒ (Trans q _) = вҠўtyвӮҒ q
вҠўtyвӮҒ (Lam q (x#b вҲүвҲӘ _)) = Lam (вҠўtyвӮҒ q) x#b
вҠўtyвӮҒ (App qвӮҖ qвӮҒ) = App (вҠўtyвӮҒ qвӮҖ) (вҠўtyвӮҒ qвӮҒ)
вҠўtyвӮҒ (Succ q) = Succ (вҠўtyвӮҒ q)
вҠўtyвӮҒ (Nrec qвӮҖ qвӮҒ qвӮӮ) =
  Nrec (вҠўtyвӮҒ qвӮҖ) (вҠўtyвӮҒ qвӮҒ) (вҠўtyвӮҒ qвӮӮ)
вҠўtyвӮҒ (BetaLam qвӮҖ qвӮҒ x#b) = App (Lam qвӮҖ x#b) qвӮҒ
вҠўtyвӮҒ (BetaZero qвӮҖ qвӮҒ) = Nrec qвӮҖ qвӮҒ Zero
вҠўtyвӮҒ (BetaSucc qвӮҖ qвӮҒ qвӮӮ) = Nrec qвӮҖ qвӮҒ (Succ qвӮӮ)
вҠўtyвӮҒ (Eta q _) = q

вҠўtyвӮӮ (Refl q) = q
вҠўtyвӮӮ (Symm q) = вҠўtyвӮҒ q
вҠўtyвӮӮ (Trans _ q) = вҠўtyвӮӮ q
вҠўtyвӮӮ (Lam q (_ вҲүвҲӘ x#b')) = Lam (вҠўtyвӮӮ q) x#b'
вҠўtyвӮӮ (App qвӮҖ qвӮҒ) = App (вҠўtyвӮӮ qвӮҖ) (вҠўtyвӮӮ qвӮҒ)
вҠўtyвӮӮ (Succ q) = Succ (вҠўtyвӮӮ q)
вҠўtyвӮӮ (Nrec qвӮҖ qвӮҒ qвӮӮ) =
  Nrec (вҠўtyвӮӮ qвӮҖ) (вҠўtyвӮӮ qвӮҒ) (вҠўtyвӮӮ qвӮӮ)
вҠўtyвӮӮ (BetaLam{b = b}{x} qвӮҖ qвӮҒ x#b) =
  -- here we need the fact that concretion preserves typing,
  -- which in turn depends on the fact that
  -- susbtitution preserves typing
  вҠўconc b x qвӮҖ qвӮҒ x#b
вҠўtyвӮӮ (BetaZero q _) = q
вҠўtyвӮӮ (BetaSucc qвӮҖ qвӮҒ qвӮӮ) = App (App qвӮҒ qвӮӮ) (Nrec qвӮҖ qвӮҒ qвӮӮ)
вҠўtyвӮӮ{О“} (Eta{A}{B}{b}{x} q  x#b)
  with (x' , x'#x вҲүвҲӘ x'#b вҲүвҲӘ x'#О“) вҶҗ fresh (x , b , О“) =
  Lam{x = x'}  q' (#abs' (b вҲҷ рқҗҜ x) (x'#b вҲүвҲӘ x'#x вҲүвҲӘ вҲүвҲ…))
  where
  instance
   _ : x' # О“
   _ = x'#О“
  q' : О“ вЁҹ x' вҲ¶ A вҠў (x пјҺ b вҲҷ рқҗҜ x)[ x' ] вҲ¶ B
  q' rewrite concAbs x (b вҲҷ рқҗҜ x) (рқҗҜ x')
     | ssbFresh x (рқҗҜ x') b x#b
     | updateEq{idЛў}{рқҗҜ x'} x =
    App (wkвҠў q) (Var (isInNew refl))

----------------------------------------------------------------------
-- Reflexivity Inversion for substitutions
----------------------------------------------------------------------
вҠўsbвӮҒ :
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  (_ : О“ вҠўЛў Пғ пјқ Пғ' вҲ¶ О“')
  вҶ’ ---------------------
  О“ вҠўЛў Пғ вҲ¶ О“'

вҠўsbвӮҒ пјқв—Ү         = в—Ү
вҠўsbвӮҒ (пјқ[] qвӮҖ qвӮҒ) = [] (вҠўsbвӮҒ qвӮҖ) (вҠўtyвӮҒ qвӮҒ)

вҠўsbвӮӮ :
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  (_ : О“ вҠўЛў Пғ пјқ Пғ' вҲ¶ О“')
  вҶ’ ---------------------
  О“ вҠўЛў Пғ' вҲ¶ О“'

вҠўsbвӮӮ пјқв—Ү         = в—Ү
вҠўsbвӮӮ (пјқ[] qвӮҖ qвӮҒ) = [] (вҠўsbвӮӮ qвӮҖ) (вҠўtyвӮӮ qвӮҒ)

----------------------------------------------------------------------
-- Substitution preserves conversion, continued
----------------------------------------------------------------------
-- Now we have reflexivity inversion, we can prove:
sbпјқ :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {a a' : Tm}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў a пјқ a' вҲ¶ A)
  вҶ’ -----------------------
  О“' вҠў Пғ * a пјқ Пғ' * a' вҲ¶ A

sbпјқ p q = Trans (sbпјқConv p (вҠўtyвӮҒ q)) (sbConv (вҠўsbвӮӮ p) q)

sbпјқВ№ :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A B : Ty}
  {x x' : рқ”ё}
  вҰғ _ : x # О“ вҰ„
  вҰғ _ : x' # О“' вҰ„
  (b b' : Tm[ 1 ])
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вЁҹ x вҲ¶ A вҠў b [ x ] пјқ b' [ x ] вҲ¶ B)
  (_ : x # (b , b'))
  (_ : x' # (b , b'))
  вҶ’ --------------------------------------------------
  О“' вЁҹ x' вҲ¶ A вҠў (Пғ * b) [ x' ] пјқ (Пғ' * b') [ x' ] вҲ¶ B

sbпјқВ№{Пғ}{Пғ'}{О“' = О“'}{A}{B}{x}{x'}
  b b' p q (x#b вҲүвҲӘ x#b') (x'#b вҲүвҲӘ x'#b') =
  substвӮӮ (О» c c' вҶ’ О“' вЁҹ x' вҲ¶ A вҠў c пјқ c' вҲ¶ B)
    (sbUpdate[] Пғ x (рқҗҜ x') b x#b)
    (sbUpdate[] Пғ' x (рқҗҜ x') b' x#b')
    (sbпјқ (liftпјқSb p) q)

----------------------------------------------------------------------
-- Composing well-typed substitutions
----------------------------------------------------------------------
вҠўЛўвҲҳ :
  {О“ О“' О“'' : Cx}
  {Пғ Пғ' : Sb}
  (_ : О“'' вҠўЛў Пғ' вҲ¶ О“')
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -----------------
  О“'' вҠўЛў Пғ' вҲҳЛў Пғ вҲ¶ О“

вҠўЛўвҲҳ q в—Ү = в—Ү
вҠўЛўвҲҳ q ([] pвӮҖ pвӮҒ) = [] (вҠўЛўвҲҳ q pвӮҖ) (sbвҠў q pвӮҒ)

вҠўЛўпјқвҲҳ :
  {О“ О“' О“'' : Cx}
  {ПғвӮҒ ПғвӮӮ ПғвӮҒ' ПғвӮӮ' : Sb}
  (_ : О“'' вҠўЛў ПғвӮҒ' пјқ ПғвӮӮ' вҲ¶ О“')
  (_ : О“' вҠўЛў ПғвӮҒ пјқ ПғвӮӮ вҲ¶ О“)
  вҶ’ -------------------------------
  О“'' вҠўЛў ПғвӮҒ' вҲҳЛў ПғвӮҒ пјқ ПғвӮӮ' вҲҳЛў ПғвӮӮ вҲ¶ О“

вҠўЛўпјқвҲҳ q пјқв—Ү = пјқв—Ү
вҠўЛўпјқвҲҳ q (пјқ[] pвӮҖ pвӮҒ) = пјқ[] (вҠўЛўпјқвҲҳ q pвӮҖ) (sbпјқ q pвӮҒ)

----------------------------------------------------------------------
-- Unitary and associative laws for substitution composition
----------------------------------------------------------------------
вҠўsbUnit :
  {Пғ : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -------------------
  О“' вҠўЛў idЛў вҲҳЛў Пғ пјқ Пғ вҲ¶ О“
вҠўsbUnit {Пғ} q = пјқвҲ¶Symm (вҠўЛўвүЎExt
  (О» x _ вҶ’ symm (sbUnit (Пғ x)))
  q)

вҠўsbAssoc :
  {ПғвӮҒ ПғвӮӮ ПғвӮғ : Sb}
  {О“ О“' О“'' О“''' : Cx}
  (_ : О“''' вҠўЛў ПғвӮғ вҲ¶ О“'')
  (_ : О“'' вҠўЛў ПғвӮӮ вҲ¶ О“')
  (_ : О“' вҠўЛў ПғвӮҒ вҲ¶ О“)
  вҶ’ ----------------------------------------------
  О“''' вҠўЛў (ПғвӮғ вҲҳЛў ПғвӮӮ) вҲҳЛў ПғвӮҒ пјқ ПғвӮғ вҲҳЛў (ПғвӮӮ вҲҳЛў ПғвӮҒ) вҲ¶ О“
вҠўsbAssoc {ПғвӮҒ}{ПғвӮӮ}{ПғвӮғ} qвӮғ qвӮӮ qвӮҒ = вҠўЛўвүЎExt
  (О» x r вҶ’ sbAssoc ПғвӮӮ ПғвӮғ (ПғвӮҒ x))
  (вҠўЛўвҲҳ (вҠўЛўвҲҳ qвӮғ qвӮӮ) qвӮҒ)

----------------------------------------------------------------------
-- Concretion preserves conversion
----------------------------------------------------------------------
пјқconc :
  {О“ : Cx}
  {A B : Ty}
  {a a' : Tm}
  (b b' : Tm[ 1 ])
  (x : рқ”ё)
  вҰғ _ : x # О“ вҰ„
  (_ : О“ вЁҹ x вҲ¶ A вҠў
    b [ x ] пјқ b' [ x ] вҲ¶ B)
  (_ : О“ вҠў a пјқ a' вҲ¶ A)
  (_ : x # (b , b'))
  вҶ’ --------------------------
  О“ вҠў b [ a ] пјқ b' [ a' ] вҲ¶ B

пјқconc{О“}{B = B}{a}{a'} b b' x p q (x#b вҲүвҲӘ x#b') =
  substвӮӮ (О» z z' вҶ’ О“ вҠў z пјқ z' вҲ¶ B)
    (ssb[] x a b x#b)
    (ssb[] x a' b' x#b')
    (sbпјқ (ssbпјқвҲ¶ q) p)
