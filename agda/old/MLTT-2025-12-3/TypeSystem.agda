--       (h₀ : Γ ⊢ A ∶ 𝐒𝐞𝐭 ℓ)
--       (h₁ : (Γ ⸴ x ∶ A) ⊢ B ⟨ x ⟩ ∶ 𝐒𝐞𝐭 ℓ')
--       → -----------------------------------------
--       Γ ⊢ 𝛌 A b ∙[ A , B ] a ＝ b ⟨ a ⟩ ∶ B ⟨ a ⟩

