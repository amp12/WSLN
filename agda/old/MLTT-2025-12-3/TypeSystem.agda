--     ⊢𝐔 :
--       {ℓ : Lvl}
--       (q : Ok Γ)
--       → --------------------
--       Γ ⊢ 𝐒𝐞𝐭 ℓ ∶ 𝐒𝐞𝐭 (1+ ℓ)

--     ⊢𝚷 :
--       {ℓ ℓ' : Lvl}
--       {A : Tm}
--       {B : Tm[ 1 ]}
--       {x : 𝔸}
--       ⦃ _ : x # Γ ⦄
--       (q₀ : Γ ⊢ A ∶ 𝐒𝐞𝐭 ℓ)
--       (q₁ : (Γ ⸴ x ∶ A) ⊢ B ⟨ x ⟩ ∶ 𝐒𝐞𝐭 ℓ')
--       (q₂ : x # B)
--       → -----------------------------------
--       Γ ⊢ 𝚷 A B ∶ 𝐒𝐞𝐭 (max ℓ ℓ')

--     ⊢𝛌 :
--       {ℓ ℓ' : Lvl}
--       {A : Ty}
--       {B : Ty[ 1 ]}
--       {b : Tm[ 1 ]}
--       {x : 𝔸}
--       ⦃ _ : x # Γ ⦄
--       (q₀ : (Γ ⸴ x ∶ A) ⊢ b ⟨ x ⟩ ∶ B ⟨ x ⟩)
--       (q₁ : x # (B , b))
--       -- helper hypotheses
--       (h₀ : Γ ⊢ A ∶ 𝐒𝐞𝐭 ℓ)
