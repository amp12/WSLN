--       {ℓ ℓ' : Lvl}
--       {A : Ty}
--       {C : Ty[ 2 ]}
--       {a c : Tm}
--       {x y : 𝔸}
--       ⦃ _ : x # Γ ⦄
--       ⦃ _ : y # (Γ , x) ⦄
--       (q₀ : (Γ ⸴ x ∶ A ⸴ y ∶ 𝐈𝐝 A a (𝐯 x)) ⊢
--         C ⟨ x ⸴ y ⟩ ∶ 𝐒𝐞𝐭 ℓ')
--       (q₁ : Γ ⊢ a ∶ A)
--       (q₂ : Γ ⊢ c ∶ C ⟨ a ⸴ 𝐫𝐞𝐟𝐥 a ⟩)
--       (q₃ : x # C)
--       (q₄ : y # C)
--       -- helper hypotheses
--       (h₀ : Γ ⊢ A ∶ 𝐒𝐞𝐭 ℓ)
--       (h₁ : (Γ ⸴ x ∶ A) ⊢ 𝐈𝐝 A a (𝐯 x) ∶ 𝐒𝐞𝐭 ℓ)
--       → --------------------------------------------
--       Γ ⊢ 𝐉 C a a c (𝐫𝐞𝐟𝐥 a) ＝ c ∶ C ⟨ a ⸴ 𝐫𝐞𝐟𝐥 a ⟩

--     𝐍𝐚𝐭Beta₀ :
--       {ℓ : Lvl}
--       {C : Ty[ 1 ]}
--       {c₀ : Tm}
--       {c₊ : Tm[ 2 ]}
--       {x y : 𝔸}
--       ⦃ _ : x # Γ ⦄
--       ⦃ _ : y # (Γ , x) ⦄
--       (q₀ : Γ ⊢ c₀ ∶ C ⟨ 𝐳𝐞𝐫𝐨 ⟩)
--       (q₁ : (Γ ⸴ x ∶ 𝐍𝐚𝐭 ⸴ y ∶ C ⟨ x ⟩) ⊢
--         c₊ ⟨ x ⸴ y ⟩ ∶ C ⟨ 𝐬𝐮𝐜𝐜 (𝐯 x) ⟩)
--       (q₂ : x # (C , c₊))
--       (q₃ : y # c₊)
--       -- helper hypotheses
--       (h : (Γ ⸴ x ∶ 𝐍𝐚𝐭) ⊢ C ⟨ x ⟩ ∶ 𝐒𝐞𝐭 ℓ)
--       → --------------------------------------
--       Γ ⊢ 𝐧𝐫𝐞𝐜 C c₀ c₊ 𝐳𝐞𝐫𝐨 ＝ c₀ ∶ C ⟨ 𝐳𝐞𝐫𝐨 ⟩

--     𝐍𝐚𝐭Beta₊ :
--       {ℓ : Lvl}
--       {C : Ty[ 1 ]}
--       {c₀ a : Tm}
--       {c₊ : Tm[ 2 ]}
--       {x y : 𝔸}
--       ⦃ _ : x # Γ ⦄
--       ⦃ _ : y # (Γ , x) ⦄
--       (q₀ : Γ ⊢ c₀ ∶ C ⟨ 𝐳𝐞𝐫𝐨 ⟩)
--       (q₁ : (Γ ⸴ x ∶ 𝐍𝐚𝐭 ⸴ y ∶ C ⟨ x ⟩) ⊢
