--       -- helper hypotheses
--       (h₀ : Γ ⊢ A ∶ 𝐒𝐞𝐭 ℓ)
--       (h₁ : (Γ ⸴ x ∶ A) ⊢ 𝐈𝐝 A a (𝐯 x) ∶ 𝐒𝐞𝐭 ℓ)
--       → -----------------------------------------------
--       Γ ⊢ 𝐉 C a b c e ＝ 𝐉 C' a' b' c' e' ∶ C ⟨ b ⸴ e ⟩

