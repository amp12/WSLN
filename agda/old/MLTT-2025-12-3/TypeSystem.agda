--       {c₊ c₊' : Tm[ 2 ]}
--       {x y : 𝔸}
--       ⦃ _ : x # Γ ⦄
--       ⦃ _ : y # (Γ , x) ⦄
--       (q₀ : Γ ⸴ x ∶ 𝐍𝐚𝐭 ⊢ C ⟨ x ⟩ ＝ C' ⟨ x ⟩ ∶ 𝐒𝐞𝐭 ℓ)
--       (q₁ : Γ ⊢ c₀ ＝ c₀' ∶ C ⟨ 𝐳𝐞𝐫𝐨 ⟩)
