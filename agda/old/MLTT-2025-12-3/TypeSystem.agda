--       (q₂ : Γ ⊢ a ∶ 𝐍𝐚𝐭)
--       (q₃ : x # (C , c₊))
--       (q₄ : y # c₊)
--       -- helper hypothesis
--       (h : (Γ ⸴ x ∶ 𝐍𝐚𝐭) ⊢ C ⟨ x ⟩ ∶ 𝐒𝐞𝐭 ℓ)
--       → --------------------------------------
--       Γ ⊢ 𝐧𝐫𝐞𝐜 C c₀ c₊ (𝐬𝐮𝐜𝐜 a) ＝
