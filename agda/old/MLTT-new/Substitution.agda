  y#C : y # C
  y#C = вҠҶвҲү (вҠўsupp qвӮҖ вҲҳ вҲҲвҲӘвӮӮ вҲҳ ([]supp C рқҗірқҗһрқҗ«рқҗЁ)) (вҲүвҲӘвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))))

  qвӮҖ' :  О“' вҠў Пғ * cвӮҖ вҲ¶ (Пғ * C) [ рқҗірқҗһрқҗ«рқҗЁ ] вҰӮ l
  qвӮҖ' = subst (О» C' вҶ’ О“' вҠў Пғ * cвӮҖ вҲ¶ C' вҰӮ l)
    (sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ)
    (sbJg p qвӮҖ)

  eq : (Пғ вҲҳ/ x := рқҗҜ x') * C [ x ] вүЎ (Пғ * C)[ x' ]
  eq rewrite sb[] ((Пғ вҲҳ/ x := рқҗҜ x')) C (рқҗҜ x)
     | updateFresh Пғ x (рқҗҜ x') C qвӮғ
     | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

  h' : (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x' ] вҰӮ l
  h' = subst (О» C' вҶ’ (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
    eq
    (sbJg (liftSb p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (ПҖвӮҒ ([]вҒ»В№(вҠўok h))) x'#О“' (вҠўрқҗҚрқҗҡрқҗӯ (okSb p))) h)

  eq' : ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')* cвӮҠ [ x ][ y ] вүЎ
        (Пғ * cвӮҠ)[ x' ][ y' ]
  eq' rewrite sb[]ВІ ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') cвӮҠ (рқҗҜ x) (рқҗҜ y)
      | updateFresh ((Пғ вҲҳ/ x := рқҗҜ x')) y (рқҗҜ y') cвӮҠ qвӮ„
      | updateFresh Пғ x (рқҗҜ x') cвӮҠ qвӮғ'
      | :=Eq{f = (Пғ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y
      | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y x
          (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ (вҲүвҲӘвӮӮ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ)))) (вҲҲпҪӣпҪқ)})
      | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

  eq'' : ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ
        (Пғ * C)[ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x') ]
  eq'' rewrite sb[] ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))
       | updateFresh ((Пғ вҲҳ/ x := рқҗҜ x')) y (рқҗҜ y') C y#C
       | updateFresh Пғ x (рқҗҜ x') C qвӮғ
       | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y x
          (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ (вҲүвҲӘвӮӮ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ)))) (вҲҲпҪӣпҪқ)})
       | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

  qвӮҒ' : (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0  вЁҹ y' вҲ¶ (Пғ * C)[ x' ] вҰӮ l) вҠў
      (Пғ * cвӮҠ)[ x' ][ y' ] вҲ¶ (Пғ * C) [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x') ] вҰӮ l
  qвӮҒ' = substвӮӮ (О» c' C' вҶ’
    (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y' вҲ¶ (Пғ * C) [ x' ] вҰӮ l) вҠў c' вҲ¶ C' вҰӮ l)
      eq'
      eq''
      (sbJg
        (liftSbВІ p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) h x'#О“' (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))) y'#О“'x'
          refl eq (вҠўрқҗҚрқҗҡрқҗӯ(okSb p)) h')
        qвӮҒ)

sbJg{Пғ}{О“' = О“'} p (рқҡ·Eta{l}{l'}{A}{B}{b}{x} qвӮҖ qвӮҒ h) =
  -- helper hypothesis used
  subst (О» b' вҶ’ О“' вҠў Пғ * b пјқ b' вҲ¶ рқҡ· (Пғ * A) (Пғ * B) вҰӮ max l l')
    eq
    (рқҡ·Eta{x = x'}
      (sbJg p qвӮҖ)
      (subst (О» B' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
        (sbUpdate[] Пғ x (рқҗҜ x') B (вҠҶвҲү (вҠўsupp qвӮҖ вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮҒ) x#О“))
        (sbJg (liftSb p h x#О“ x'#О“' (sbJg p h)) qвӮҒ))
      (sbJg p h))
  where
  x#О“ =  ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))
  S = supp ((Пғ * B , Пғ * b) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

  x#b : x # b
  x#b = вҲүвҲӘвӮҒ (вҠў# qвӮҖ x#О“)

  x#A : x # A
  x#A = вҲүвҲӘвӮҒ (вҲүвҲӘвӮӮ (вҠў# qвӮҖ x#О“))

  x#B : x # B
  x#B = вҲүвҲӘвӮҒ (вҲүвҲӘвӮӮ (вҲүвҲӘвӮӮ (вҠў# qвӮҖ x#О“)))

  f :
    (y : в„•)
    (_ : y вҲҲ supp (b вҲҷ[ A , B ] рқҗҜ x))
    (_ : В¬ (x вүЎ y))
    вҶ’ -------------------------------
    x' # Пғ y
  f y (вҲҲвҲӘвӮҒ yвҲҲb) В¬xy =
    вҠҶвҲү (sbDom p (вҠўsupp qвӮҖ (вҲҲвҲӘвӮҒ yвҲҲb))) x'#О“'
  f y (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮҒ yвҲҲA)) В¬xy =
    вҠҶвҲү (sbDom p (вҠўsupp qвӮҖ (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮҒ yвҲҲA)))) x'#О“'
  f y (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮҒ yвҲҲB))) В¬xy =
    вҠҶвҲү (sbDom p (вҠўsupp qвӮҖ (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮҒ yвҲҲB))))) x'#О“'
  f y (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮӮ (вҲҲвҲӘвӮҒ вҲҲпҪӣпҪқ)))) В¬xy =
    Гҳelim (В¬xy refl)

  eq : рқӣҢ (Пғ * A)(x' пјҺ (Пғ * b) вҲҷ[ Пғ * A , Пғ * B ] рқҗҜ x') вүЎ
    Пғ * рқӣҢ A (x пјҺ b вҲҷ[ A , B ] рқҗҜ x)
  eq rewrite sbAbs Пғ x x' (b вҲҷ[ A , B ] рқҗҜ x) f
     | updateFresh Пғ x (рқҗҜ x') b x#b
     | updateFresh Пғ x (рқҗҜ x') A x#A
     | updateFresh Пғ x (рқҗҜ x') B x#B
     | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

----------------------------------------------------------------------
-- Conversion for substitutions is reflexive
----------------------------------------------------------------------
sbпјқRefl :
  {Пғ : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ ---------------
  О“' вҠўЛў Пғ пјқ Пғ вҲ¶ О“

sbпјқRefl (в—Ү q) = в—Ү q
sbпјқRefl ([] qвӮҖ qвӮҒ qвӮӮ qвӮғ) = [] (sbпјқRefl qвӮҖ) qвӮҒ (Refl qвӮӮ) qвӮғ

----------------------------------------------------------------------
-- Properties of substitution update
----------------------------------------------------------------------
sbUpdate :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“' вҠў a вҲ¶ Пғ * A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ -----------------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

sbUpdate{l}{О“' = О“'}{Пғ}{A}{a}{x} вҠўПғ вҠўa x#О“ вҠўA = []
  (sbExt вҠўПғ (О» y r вҶ’
    symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r })))
  вҠўA
  (substвӮӮ (О» z Z вҶ’ О“' вҠў z вҲ¶ Z вҰӮ l)
    (symm (:=Eq{f = Пғ}{a} x))
    (symm (updateFresh Пғ x a A (вҲүвҲӘвӮҒ (вҠў# вҠўA x#О“))))
    вҠўa)
  x#О“

sbпјқUpdate :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {A : Ty}
  {a a' : Tm}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“' вҠў a пјқ a' вҲ¶ Пғ * A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ ------------------------------------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) пјқ (Пғ' вҲҳ/ x := a') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

sbпјқUpdate{l}{О“' = О“'}{Пғ}{Пғ'}{A}{a}{a'}{x} Пғ=Пғ' a=a' x#О“ вҠўA = []
  (sbпјқExt Пғ=Пғ'
    (О» y r вҶ’
      symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r }))
    (О» y r вҶ’
      symm (:=Neq {f = Пғ'} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r })))
  вҠўA
  (substвӮғ (О» z z' Z вҶ’ О“' вҠў z пјқ z' вҲ¶ Z вҰӮ l)
    (symm (:=Eq{f = Пғ}{a} x))
    (symm (:=Eq{f = Пғ'}{a'} x))
    (symm (updateFresh Пғ x a A (вҲүвҲӘвӮҒ (вҠў# вҠўA x#О“))))
    a=a')
  x#О“

ssbUpdate :
  {l : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ -----------------------------
  О“ вҠўЛў (x := a) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

ssbUpdate{l}{О“}{A}{a} q x#О“ h = sbUpdate
  (вҠўidЛў (вҠўok q))
  (subst (О» A' вҶ’ О“ вҠў a вҲ¶ A' вҰӮ l) (symm (sbUnit A)) q)
  x#О“
  h

ssbпјқUpdate :
  {l : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a a' : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ ------------------------------------------
  О“ вҠўЛў (x := a) пјқ (x := a') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

ssbпјқUpdate{l}{О“}{A}{a}{a'} q x#О“ h = sbпјқUpdate
  (sbпјқRefl (вҠўidЛў (вҠўok q)))
  (subst (О» A' вҶ’ О“ вҠў a пјқ a' вҲ¶ A' вҰӮ l) (symm (sbUnit A)) q)
  x#О“
  h

ssbUpdateВІ :
  {l l' : Lvl}
  {О“ : Cx}
  {x y : рқ”ё}
  {a b : Tm}
  {A B : Ty}
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B вҰӮ l')
  (_ : О“ вҠў b вҲ¶ (x := a) * B вҰӮ l')
  (_ : y # (О“ , x))
  вҶ’ ----------------------------------------------------
  О“ вҠўЛў (x := a вҲҳ/ y := b) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')

ssbUpdateВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ
  with [] q q' _ вҶҗ вҠўok qвӮҒ =
  sbUpdate (ssbUpdate qвӮҖ q' q) qвӮӮ qвӮғ qвӮҒ


ssbпјқUpdateВІ :
  {l l' : Lvl}
  {О“ : Cx}
  {x y : рқ”ё}
  {a a' b b' : Tm}
  {A  B : Ty}
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B вҰӮ l')
  (_ : О“ вҠў b пјқ b' вҲ¶ (x := a) * B вҰӮ l')
  (_ : y # (О“ , x))
  вҶ’ ---------------------------------------------
  О“ вҠўЛў (x := a вҲҳ/ y := b) пјқ (x := a' вҲҳ/ y := b')
    вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')

ssbпјқUpdateВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ
  with [] q q' _ вҶҗ вҠўok qвӮҒ =
  sbпјқUpdate (ssbпјқUpdate qвӮҖ q' q) qвӮӮ qвӮғ qвӮҒ

----------------------------------------------------------------------
-- Lifting substitutions, again
----------------------------------------------------------------------
liftSbвҒ» :
  {l : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : x # О“)
  (_ : x' # О“')
  вҶ’ ---------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

liftSbвҒ» qвӮҖ qвӮҒ qвӮӮ qвӮғ = liftSb qвӮҖ qвӮҒ qвӮӮ qвӮғ (sbJg qвӮҖ qвӮҒ)

liftпјқSb :
  {l : Lvl}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : x # О“)
  (_ : x' # О“')
  -- helper hypothesis
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠўЛў
    (Пғ вҲҳ/ x := рқҗҜ x') пјқ (Пғ' вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

liftпјқSb{l}{Пғ}{Пғ'}{О“}{О“'}{A}{x}{x'} p q x#О“ x'#О“ h =
  [] (wkпјқSb x' (sbJg h q) p' x'#О“) q q'' x#О“
  where
  p' : О“' вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') пјқ (Пғ' вҲҳ/ x := рқҗҜ x') вҲ¶ О“
  p' = sbпјқExt p
    (О» y r вҶ’ symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r }))
    О» y r вҶ’ symm (:=Neq {f = Пғ'} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r })

  q'' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў
      (Пғ вҲҳ/ x := рқҗҜ x') x пјқ (Пғ' вҲҳ/ x := рқҗҜ x') x вҲ¶ (Пғ вҲҳ/ x := рқҗҜ x') * A вҰӮ l
  q'' rewrite updateFresh Пғ x (рқҗҜ x') A (вҲүвҲӘвӮҒ (вҠў# q x#О“))
      | :=Eq{f = Пғ}{рқҗҜ x'} x
      | :=Eq{f = Пғ'}{рқҗҜ x'} x =
    Refl (вҠўрқҗҜ ([]вҒ» (sbJg h q) x'#О“) isInNew)

liftпјқSbВІ :
  {l l' : Lvl}
  {x y x' y' : рқ”ё}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A A' B B' : Ty}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B вҰӮ l')
  (_ : x' # О“')
  (_ : y # (О“ , x))
  (_ : y' # (О“' , x'))
  (_ : Пғ * A вүЎ A')
  (_ : (Пғ вҲҳ/ x := рқҗҜ x') * B вүЎ B')
  -- helper hypotheses
  (h : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ --------------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ A' вҰӮ l вЁҹ y' вҲ¶ B' вҰӮ l') вҠўЛў
  ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')
  пјқ
  ((Пғ' вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l  вЁҹ y вҲ¶ B вҰӮ l')

liftпјқSbВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… refl refl h
  with [] q q' _ вҶҗ вҠўok qвӮӮ =
  liftпјқSb (liftпјқSb qвӮҖ q q' qвӮғ h) qвӮӮ qвӮ„ qвӮ…
    (liftSbвҒ» h q q' qвӮғ)

----------------------------------------------------------------------
-- Action of convertible substitutions
----------------------------------------------------------------------
пјқsbTm :
  {l : Lvl}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {a : Tm}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  -- helper hypothesis
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ ------------------------------
  О“' вҠў Пғ * a пјқ Пғ' * a вҲ¶ Пғ * A вҰӮ l

пјқsbTm p (вҠўconv qвӮҖ qвӮҒ) h = пјқconv (пјқsbTm p qвӮҖ h) (sbJg h qвӮҒ)

пјқsbTm{Пғ = Пғ}{Пғ'} p (вҠўрқҗҜ{x = x} _ q) h
  rewrite вҖҝunit (Пғ x) вҰғ it вҰ„
  | вҖҝunit (Пғ' x) вҰғ it вҰ„ = sbVarпјқ p q

пјқsbTm p (вҠўрқҗ” _) h = Refl (вҠўрқҗ” (okSbпјқ p))

пјқsbTm{Пғ = Пғ}{Пғ'}{О“' = О“'} p (вҠўрқҡ·{l}{l'}{A = A}{B}{x} qвӮҖ qвӮҒ qвӮӮ) h =
  -- helper hypotheses used
  рқҡ·Cong{x = x'}
    (пјқsbTm p qвӮҖ h)
    (substвӮӮ (О» C C' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў C пјқ C' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮӮ)
      (sbUpdate[] Пғ' x (рқҗҜ x') B qвӮӮ)
      (пјқsbTm (liftпјқSb p qвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҒ))) x'#О“' h) qвӮҒ
        (liftSbвҒ» h qвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҒ))) x'#О“')))
    x'#
    (sbJg h qвӮҖ)
  where
  S = supp ((Пғ * B , Пғ' * B) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

пјқsbTm{Пғ = Пғ}{Пғ'}{О“' = О“'} p (вҠўрқӣҢ{l}{l'}{A}{B}{b}{x}
  qвӮҖ (qвӮҒ вҲүвҲӘ qвӮҒ') hвӮҖ hвӮҒ) h' =
  -- helper hypotheses used
  рқӣҢCong{x = x'}
    (пјқsbTm p hвӮҖ h')
    (substвӮғ (О» c c' C вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў c пјқ c' вҲ¶ C вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') b qвӮҒ')
      (sbUpdate[] Пғ' x (рқҗҜ x') b qвӮҒ')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮҒ)
      (пјқsbTm (liftпјқSb p hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok hвӮҒ))) x'#О“' h') qвӮҖ
        (liftSbвҒ» h' hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok hвӮҒ))) x'#О“')))
    x'#
    (sbJg h' hвӮҖ)
    (subst (О» B' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l ) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮҒ)
      (sbJg (liftSb h' hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok hвӮҒ))) x'#О“' (sbJg h' hвӮҖ)) hвӮҒ))
  where
  S = supp ((Пғ * B , Пғ * b , Пғ' * b) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

пјқsbTm{Пғ = Пғ}{Пғ'}{О“' = О“'} p
  (вҠўвҲҷ{l}{l'}{A}{B}{a}{b}{x} qвӮҖ qвӮҒ qвӮӮ qвӮғ h') h
  rewrite sb[] Пғ B a =
  -- helper hypotheses used
  вҲҷCong{x = x'}
    (пјқsbTm p h' h)
    (substвӮӮ (О» C C' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў C пјқ C' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮғ)
      (sbUpdate[] Пғ' x (рқҗҜ x') B qвӮғ)
      (пјқsbTm (liftпјқSb p h' (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮӮ))) x'#О“' h) qвӮӮ
        (liftSbвҒ» h h' (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮӮ))) x'#О“')))
    (пјқsbTm p qвӮҖ h)
    (пјқsbTm p qвӮҒ h)
    x'#
    (sbJg h h')
    (subst (О» B' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮғ)
      (sbJg (liftSb h h' (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮӮ))) x'#О“' (sbJg h h')) qвӮӮ))
  where
  S = supp ((Пғ * B , Пғ' * B) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

пјқsbTm p (вҠўрқҗҲрқҗқ qвӮҖ qвӮҒ h) h' = рқҗҲрқҗқCong
  (пјқsbTm p h h')
  (пјқsbTm p qвӮҖ h')
  (пјқsbTm p qвӮҒ h')

пјқsbTm p (вҠўрқҗ«рқҗһрқҗҹрқҗҘ q h') h = рқҗ«рқҗһрқҗҹрқҗҘCong
  (пјқsbTm p q h)
  (sbJg h h')

пјқsbTm{Пғ = Пғ}{Пғ'}{О“' = О“'} p (вҠўрқҗү{l}{l'}{A}{C}{a}{b}{c}{e}{x}{y}
  qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… qвӮҶ hвӮҖ hвӮҒ) h
  rewrite sb[]ВІ Пғ C b e =
  -- helper hypotheses used
  рқҗүCong{x = x'}{y'}
    qвӮҖ'
    (пјқsbTm p qвӮҒ h)
    (пјқsbTm p qвӮӮ h)
    (subst (О» C' вҶ’ О“' вҠў Пғ * c пјқ Пғ' * c вҲ¶ C' вҰӮ l')
      (sb[]ВІ Пғ C a (рқҗ«рқҗһрқҗҹрқҗҘ a))
      (пјқsbTm p qвӮғ h))
    (пјқsbTm p qвӮ„ h)
    x'#
    y'#
    (sbJg h hвӮҖ)
    hвӮҒ'
  where
  S = supp ((Пғ * C , Пғ' * C) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)
  S' = supp ((Пғ * C , Пғ' * C) , О“' , x')
  y' = new S'
  y'# = вҲүвҲӘвӮҒ (newвҲү S')
  y'#О“'x' = вҲүвҲӘвӮӮ (newвҲү S')

  eq : (Пғ вҲҳ/ x := рқҗҜ x') * рқҗҲрқҗқ A a (рқҗҜ x) вүЎ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x')
  eq rewrite  updateFresh Пғ x (рқҗҜ x') A (вҲүвҲӘвӮӮ (вҠў# qвӮҒ (ПҖвӮҒ([]вҒ»В№(вҠўok hвӮҒ)))))
     | updateFresh Пғ x (рқҗҜ x') a (вҲүвҲӘвӮҒ (вҠў# qвӮҒ (ПҖвӮҒ([]вҒ»В№(вҠўok hвӮҒ)))))
     | :=Eq{f = Пғ}{(рқҗҜ x')} x = refl

  hвӮҒ' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x') вҰӮ l
  hвӮҒ' = subst (О» I вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l ) вҠў I вҰӮ l)
    eq
    (sbJg (liftSb h hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok hвӮҒ))) x'#О“' (sbJg h hвӮҖ)) hвӮҒ)

  eq' :
    (П„ : Sb)
    вҶ’ ------------------------------------------------------------------
    ((П„ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') * C [ x ][ y ] вүЎ (П„ * C)[ x' ][ y' ]
  eq' П„ rewrite sb[]ВІ ((П„ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') C (рқҗҜ x) (рқҗҜ y)
      | updateFresh (П„ вҲҳ/ x := рқҗҜ x') y (рқҗҜ y') C qвӮҶ
      | updateFresh П„ x (рқҗҜ x') C qвӮ…
      | :=Eq{f = (П„ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y
      | :=Neq{f = (П„ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y x
          (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ ((вҲүвҲӘвӮӮ (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҖ))))) (вҲҲпҪӣпҪқ)})
      | :=Eq{f = П„}{рқҗҜ x'} x = refl

  qвӮҖ' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l вЁҹ y' вҲ¶ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x') вҰӮ l) вҠў
    (Пғ * C) [ x' ][ y' ] пјқ (Пғ' * C) [ x' ][ y' ] вҰӮ l'
  qвӮҖ' = substвӮӮ (О» D D' вҶ’
    (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l вЁҹ y' вҲ¶ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x') вҰӮ l) вҠў D пјқ D' вҰӮ l')
    (eq' Пғ)
    (eq' Пғ')
    (пјқsbTm (liftпјқSbВІ p hвӮҖ hвӮҒ x'#О“' (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҖ))) y'#О“'x' refl eq h) qвӮҖ
      (liftSbВІ h hвӮҖ hвӮҒ x'#О“' ((ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҖ)))) y'#О“'x' refl eq (sbJg h hвӮҖ) hвӮҒ'))

пјқsbTm p (вҠўрқҗҚрқҗҡрқҗӯ _) _ = Refl (вҠўрқҗҚрқҗҡрқҗӯ (okSbпјқ p))

пјқsbTm p (вҠўрқҗірқҗһрқҗ«рқҗЁ _) _ = Refl (вҠўрқҗірқҗһрқҗ«рқҗЁ (okSbпјқ p))

пјқsbTm p (вҠўрқҗ¬рқҗ®рқҗңрқҗң q) h = рқҗ¬рқҗ®рқҗңрқҗңCong (пјқsbTm p q h)

пјқsbTm{Пғ = Пғ}{Пғ'}{О“' = О“'} p (вҠўрқҗ§рқҗ«рқҗһрқҗң{l}{C}{cвӮҖ}{a}{cвӮҠ}{x}{y}
  qвӮҖ qвӮҒ qвӮӮ (qвӮғ вҲүвҲӘ qвӮғ') qвӮ„ qвӮ…) h
  rewrite sb[] Пғ C a =
  -- helper hypotheses used
  рқҗ§рқҗ«рқҗһрқҗңCong {x = x'} {y'}
    (substвӮӮ (О» D D' вҶ’ (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў D пјқ D' вҰӮ l)
      (eq Пғ)
      (eq Пғ')
      (пјқsbTm (liftпјқSb p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮ…))) x'#О“' h) qвӮ…
      (liftSb h (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮ…))) x'#О“' (вҠўрқҗҚрқҗҡрқҗӯ (okSbпјқ p)))))
    (subst (О» D вҶ’ О“' вҠў Пғ * cвӮҖ пјқ Пғ' * cвӮҖ вҲ¶ D вҰӮ l)
      (sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ)
      (пјқsbTm p qвӮҖ h))
    qвӮӮ'
    (пјқsbTm p qвӮӮ h)
    x'#
    y'#
    h'
  where
  S = supp ((Пғ * C , Пғ' * C , Пғ * cвӮҠ , Пғ' * cвӮҠ) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)
  S' = supp ((Пғ * cвӮҠ , Пғ' * cвӮҠ) , О“' , x')
  y' = new S'
  y'# = вҲүвҲӘвӮҒ (newвҲү S')
  y'#О“'x' = вҲүвҲӘвӮӮ (newвҲү S')

  y#C : y # C
  y#C = вҠҶвҲү (вҠўsupp qвӮҖ вҲҳ вҲҲвҲӘвӮӮ вҲҳ []supp C рқҗірқҗһрқҗ«рқҗЁ) (вҲүвҲӘвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))))

  eq :
    (П„ : Sb)
    вҶ’ -----------------------------------------
    (П„ вҲҳ/ x := рқҗҜ x') * C [ x ] вүЎ (П„ * C)[ x' ]
  eq П„ rewrite sb[] ((П„ вҲҳ/ x := рқҗҜ x')) C (рқҗҜ x)
     | updateFresh П„ x (рқҗҜ x') C qвӮғ
     | :=Eq{f = П„}{рқҗҜ x'} x = refl

  h' : (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x' ] вҰӮ l
  h' = subst (О» C' вҶ’ (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
    (eq Пғ)
    (sbJg (liftSb h (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ))
      (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮ…))) x'#О“' (вҠўрқҗҚрқҗҡрқҗӯ (okSb h))) qвӮ…)

  eqвӮҠ :
    (П„ : Sb)
    вҶ’ --------------------------------------------------------------------
    ((П„ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') * cвӮҠ [ x ][ y ] вүЎ (П„ * cвӮҠ)[ x' ][ y' ]
  eqвӮҠ П„ rewrite sb[]ВІ ((П„ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') cвӮҠ (рқҗҜ x) (рқҗҜ y)
      | updateFresh (П„ вҲҳ/ x := рқҗҜ x') y (рқҗҜ y') cвӮҠ qвӮ„
      | updateFresh П„ x (рқҗҜ x') cвӮҠ qвӮғ'
      | :=Eq{f = (П„ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y
      | :=Neq{f = (П„ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y x
          (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ ((вҲүвҲӘвӮӮ (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҒ))))) (вҲҲпҪӣпҪқ)})
      | :=Eq{f = П„}{рқҗҜ x'} x = refl

  eq'' : ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ
        (Пғ * C)[ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x') ]
  eq'' rewrite sb[] ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))
       | updateFresh ((Пғ вҲҳ/ x := рқҗҜ x')) y (рқҗҜ y') C y#C
       | updateFresh Пғ x (рқҗҜ x') C qвӮғ
       | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y x
          (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ ((вҲүвҲӘвӮӮ (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҒ))))) (вҲҲпҪӣпҪқ)})
       | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

  qвӮӮ' : (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y' вҲ¶ (Пғ * C)[ x' ] вҰӮ l) вҠў
      (Пғ * cвӮҠ)[ x' ][ y' ] пјқ (Пғ' * cвӮҠ)[ x' ][ y' ] вҲ¶ (Пғ * C) [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x') ] вҰӮ l
  qвӮӮ' = substвӮғ (О» d d' D вҶ’
    (О“' вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y' вҲ¶ (Пғ * C) [ x' ] вҰӮ l) вҠў d пјқ d' вҲ¶ D вҰӮ l)
      (eqвӮҠ Пғ)
      (eqвӮҠ Пғ')
      eq''
      (пјқsbTm
        (liftпјқSbВІ p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) qвӮ…
          x'#О“' (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))) y'#О“'x' refl (eq Пғ) h) qвӮҒ
        (liftSbВІ h (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) qвӮ…
          x'#О“' (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))) y'#О“'x'  refl (eq Пғ)
          (вҠўрқҗҚрқҗҡрқҗӯ (okSb h)) h'))
