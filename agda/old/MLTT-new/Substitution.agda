module MLTT.Substitution where

open import Prelude
open import WSLN

open import MLTT.Syntax
open import MLTT.Judgement
open import MLTT.TypeSystem
open import MLTT.Ok
open import MLTT.WellScoped
open import MLTT.Renaming

----------------------------------------------------------------------
-- Weakening
----------------------------------------------------------------------
wkSb :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  (x : рқ”ё)
  (_ : О“' вҠў A вҰӮ l)
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : x # О“')
  вҶ’ -----------------------
  (О“' вЁҹ x вҲ¶ A вҰӮ l)вҠўЛў Пғ вҲ¶ О“

wkSb x q (в—Ү q') q'' = в—Ү ([] q q'' q')
wkSb x q ([] qвӮҖ qвӮҒ qвӮӮ qвӮғ) q'' =
  [] (wkSb x q qвӮҖ q'') qвӮҒ (wkJg x q qвӮӮ q'') qвӮғ

wkпјқSb :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {A : Ty}
  (x : рқ”ё)
  (_ : О“' вҠў A вҰӮ l)
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : x # О“')
  вҶ’ ----------------------------
  (О“' вЁҹ x вҲ¶ A вҰӮ l)вҠўЛў Пғ пјқ Пғ' вҲ¶ О“

wkпјқSb x q (в—Ү q') q'' = в—Ү ([] q q'' q')
wkпјқSb x q ([] qвӮҖ qвӮҒ qвӮӮ qвӮғ) q'' =
  [] (wkпјқSb x q qвӮҖ q'') qвӮҒ (wkJg x q qвӮӮ q'') qвӮғ

----------------------------------------------------------------------
-- Identity substitution is well-typed
----------------------------------------------------------------------
вҠўidЛў :
  {О“ : Cx}
  (_ : Ok О“)
  вҶ’ ---------
  О“ вҠўЛў idЛў вҲ¶ О“

вҠўidЛў в—Ү = в—Ү в—Ү
вҠўidЛў ([]{l}{О“}{A}{x} q q' q'') = []
  (wkSb _ q (вҠўidЛў q'') q')
  q
  (вҠўрқҗҜ ([]вҒ» q q') (subst (О» A' вҶ’ (x , A' , l) isIn (О“ вЁҹ x вҲ¶ A вҰӮ l))
    (symm (sbUnit A))
    isInNew))
  q'

----------------------------------------------------------------------
-- Extensionality properties of well-typed substitutions
----------------------------------------------------------------------
sbExt :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ Пғ x вүЎ Пғ' x)
  вҶ’ --------------------------------
  О“' вҠўЛў Пғ' вҲ¶ О“

sbExt (в—Ү q) _ = в—Ү q
sbExt{Пғ}{Пғ'} ([]{A = A}{x} qвӮҖ qвӮҒ qвӮӮ qвӮғ) e
  rewrite sbRespSupp Пғ Пғ' A (О» x' p' вҶ’ e x' (вҲҲвҲӘвӮҒ (вҠўsupp qвӮҒ (вҲҲвҲӘвӮҒ p'))))
  | e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = [] (sbExt qвӮҖ (О» y r вҶ’ e y (вҲҲвҲӘвӮҒ r))) qвӮҒ qвӮӮ qвӮғ

sbпјқExt :
  {Пғ' П„' Пғ П„ : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ пјқ П„ вҲ¶ О“)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ Пғ x вүЎ Пғ' x)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ П„ x вүЎ П„' x)
  вҶ’ --------------------------------
  О“' вҠўЛў Пғ' пјқ П„' вҲ¶ О“

sbпјқExt (в—Ү q) _ _ = в—Ү q
sbпјқExt{Пғ'}{П„'} ([]{Пғ = Пғ}{П„}{A = A}{x} qвӮҖ qвӮҒ qвӮӮ qвӮғ) e e'
  rewrite sbRespSupp Пғ Пғ' A (О» x' p' вҶ’ e x' (вҲҲвҲӘвӮҒ (вҠўsupp qвӮҒ (вҲҲвҲӘвӮҒ p'))))
  | e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ)
  | e' x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ)= []
    (sbпјқExt qвӮҖ (О» y r вҶ’ e y (вҲҲвҲӘвӮҒ r)) (О» y' r' вҶ’ e' y' (вҲҲвҲӘвӮҒ r')))
    qвӮҒ
    qвӮӮ
    qвӮғ

----------------------------------------------------------------------
-- Lifting substitutions
----------------------------------------------------------------------
liftSb :
  {l : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : x # О“)
  (_ : x' # О“')
  -- helper hypothesis
  (_ : О“' вҠў Пғ * A вҰӮ l)
  вҶ’ --------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l)вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

liftSb{l}{Пғ}{О“}{О“'}{A}{x}{x'} вҠўПғ вҠўA x#О“ x'#О“' вҠўПғA =
  [] (wkSb x' вҠўПғA вҠўПғ' x'#О“') вҠўA вҠўA' x#О“
  where
  вҠўПғ' : О“' вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ О“
  вҠўПғ' = sbExt вҠўПғ (О» y r вҶ’
    symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r }))

  вҠўA' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l)вҠў
    (Пғ вҲҳ/ x := рқҗҜ x') x вҲ¶ (Пғ вҲҳ/ x := рқҗҜ x') * A вҰӮ l
  вҠўA' rewrite updateFresh Пғ x (рқҗҜ x') A (вҲүвҲӘвӮҒ (вҠў# вҠўA x#О“))
      | :=Eq{f = Пғ}{рқҗҜ x'} x = вҠўрқҗҜ ([]вҒ» вҠўПғA x'#О“') isInNew

-- Iterated lifting
liftSbВІ :
  {l l' : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A A' B B' : Ty}
  {x y x' y' : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l)вҠў B вҰӮ l')
  (_ : x' # О“')
  (_ : y # (О“ , x))
  (_ : y' # (О“' , x'))
  (_ : Пғ * A вүЎ A')
  (_ : (Пғ вҲҳ/ x := рқҗҜ x') * B вүЎ B')
  -- helper hypotheses
  (_ : О“' вҠў A' вҰӮ l)
  (_ : (О“' вЁҹ x' вҲ¶ A' вҰӮ l) вҠў B' вҰӮ l')
  вҶ’ -------------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ A' вҰӮ l вЁҹ y' вҲ¶ B' вҰӮ l') вҠўЛў
    ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')

liftSbВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… refl refl h h' =
  liftSb (liftSb qвӮҖ qвӮҒ (ПҖвӮҒ ([]вҒ»В№ (вҠўok qвӮӮ))) qвӮғ h) qвӮӮ qвӮ„ qвӮ… h'

----------------------------------------------------------------------
-- Types of variables under substitution
----------------------------------------------------------------------
sbVar :
  {l : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  {A : Ty}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : (x , A , l) isIn О“)
  вҶ’ ----------------------
  О“' вҠў Пғ x вҲ¶ Пғ * A вҰӮ l

sbVar ([] _ _ q _)  isInNew     = q
sbVar ([] q _ _ _) (isInOld q') = sbVar q q'

sbVarпјқ :
  {l : Lvl}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  {A : Ty}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_  : (x , A , l) isIn О“)
  вҶ’ --------------------------
  О“' вҠў Пғ x пјқ Пғ' x вҲ¶ Пғ * A вҰӮ l

sbVarпјқ ([] _ _ q _)  isInNew     = q
sbVarпјқ ([] q _ _ _) (isInOld q') = sbVarпјқ q q'

sbDom :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : x вҲҲ dom О“)
  вҶ’ ----------------
  supp (Пғ x) вҠҶ dom О“'

sbDom p q =
  let (_ , _ , q') = domвҶ’isIn q
  in вҠўsupp (sbVar p q') вҲҳ вҲҲвҲӘвӮҒ

----------------------------------------------------------------------
-- Substitution preserves provable judgements
----------------------------------------------------------------------
sbJg :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {J : Jg}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў J)
  вҶ’ ---------------
  О“' вҠў Пғ * J

sbJg p (вҠўconv qвӮҖ qвӮҒ) = вҠўconv
  (sbJg p qвӮҖ)
  (sbJg p qвӮҒ)

sbJg{Пғ} p (вҠўрқҗҜ{x = x} _ q) rewrite вҖҝunit (Пғ x) вҰғ it вҰ„ = sbVar p q

sbJg p (вҠўрқҗ” _) = вҠўрқҗ” (okSb p)

sbJg{Пғ}{О“' = О“'} p (вҠўрқҡ·{l}{l'}{A = A}{B}{x} qвӮҖ qвӮҒ qвӮӮ) =
  вҠўрқҡ·{x = x'}
    (sbJg p qвӮҖ)
    (subst (О» B' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮӮ)
      (sbJg (liftSb p qвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҒ))) x'#О“' (sbJg p qвӮҖ)) qвӮҒ))
    x'#
  where
  S = supp (Пғ * B , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

sbJg{Пғ}{О“' = О“'} p (вҠўрқӣҢ{l}{l'}{A}{B}{b}{x} qвӮҖ (qвӮҒ вҲүвҲӘ qвӮҒ') hвӮҖ hвӮҒ) =
  вҠўрқӣҢ{x = x'}
    (substвӮӮ (О» b' B' вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў b' вҲ¶ B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') b qвӮҒ')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮҒ)
      (sbJg (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҖ))) x'#О“' (sbJg p hвӮҖ)) qвӮҖ))
    x'#
    (sbJg p hвӮҖ)
    (subst (О» C вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў C вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮҒ)
      (sbJg (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮҖ))) x'#О“' (sbJg p hвӮҖ)) hвӮҒ))
  where
  S = supp ((Пғ * B , Пғ * b) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

sbJg{Пғ}{О“' = О“'} p (вҠўвҲҷ{l}{l'}{A}{B}{a}{b}{x} qвӮҖ qвӮҒ qвӮӮ qвӮғ h)
  rewrite sb[] Пғ B a =
  -- helper hypothesis used
  вҠўвҲҷ
    (sbJg p qвӮҖ)
    (sbJg p qвӮҒ)
    (subst (О» C вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў C вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x') B qвӮғ)
      (sbJg (liftSb p h (ПҖвӮҒ ([]вҒ»В№(вҠўok qвӮӮ))) x'#О“' (sbJg p h)) qвӮӮ))
    x'#
    (sbJg p h)
  where
  S = supp (Пғ * B , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)

sbJg p (вҠўрқҗҲрқҗқ qвӮҖ qвӮҒ qвӮӮ) = вҠўрқҗҲрқҗқ
  (sbJg p qвӮҖ)
  (sbJg p qвӮҒ)
  (sbJg p qвӮӮ)

sbJg p (вҠўрқҗ«рқҗһрқҗҹрқҗҘ q h) = вҠўрқҗ«рқҗһрқҗҹрқҗҘ
  (sbJg p q)
  (sbJg p h)

sbJg{Пғ}{О“' = О“'} p (вҠўрқҗү{l}{l'}{A}{C}{a}{b}{c}{e}{x}{y}
  qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… qвӮҶ hвӮҖ hвӮҒ)
  rewrite sb[]ВІ Пғ C b e =
  -- helper hypotheses used
  вҠўрқҗү{x = x'}{y'}
    qвӮҖ'
    (sbJg p qвӮҒ)
    (sbJg p qвӮӮ)
    qвӮғ'
    (sbJg p qвӮ„)
    x'#
    y'#
    (sbJg p hвӮҖ)
    hвӮҒ'
  where
  S = supp (Пғ * C , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)
  S' = supp (Пғ * C , О“' , x')
  y' = new S'
  y'# = вҲүвҲӘвӮҒ (newвҲү S')
  y'#О“'x' = вҲүвҲӘвӮӮ (newвҲү S')

  qвӮғ' : О“' вҠў Пғ * c вҲ¶ (Пғ * C) [ Пғ * a ][ рқҗ«рқҗһрқҗҹрқҗҘ (Пғ * a)] вҰӮ l'
  qвӮғ' = subst (О» C' вҶ’ О“' вҠў Пғ * c вҲ¶ C' вҰӮ l')
    (sb[]ВІ Пғ C a (рқҗ«рқҗһрқҗҹрқҗҘ a))
    (sbJg p qвӮғ)

  eq : (Пғ вҲҳ/ x := рқҗҜ x') * рқҗҲрқҗқ A a (рқҗҜ x) вүЎ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x')
  eq rewrite  updateFresh Пғ x (рқҗҜ x') A (вҲүвҲӘвӮӮ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok hвӮҒ)))))
     | updateFresh Пғ x (рқҗҜ x') a (вҲүвҲӘвӮҒ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok hвӮҒ)))))
     | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

  hвӮҒ' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x') вҰӮ l
  hвӮҒ' = subst (О» I вҶ’ (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў I вҰӮ l)
    eq
    (sbJg (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok hвӮҒ))) x'#О“' (sbJg p hвӮҖ)) hвӮҒ)

  eq' : ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')* C [ x ][ y ] вүЎ (Пғ * C)[ x' ][ y' ]
  eq' rewrite sb[]ВІ ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') C (рқҗҜ x) (рқҗҜ y)
      | updateFresh (Пғ вҲҳ/ x := рқҗҜ x') y (рқҗҜ y') C qвӮҶ
      | updateFresh Пғ x (рқҗҜ x') C qвӮ…
      | :=Eq{f = (Пғ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y
      | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x')}{рқҗҜ y'} y x
          (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ (вҲүвҲӘвӮӮ (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҖ)))) (вҲҲпҪӣпҪқ)})
      | :=Eq{f = Пғ}{рқҗҜ x'} x = refl

  qвӮҖ' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l вЁҹ y' вҲ¶ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x') вҰӮ l) вҠў
    (Пғ * C) [ x' ][ y' ] вҰӮ l'
  qвӮҖ' = subst (О» C вҶ’
    (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l  вЁҹ y' вҲ¶ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x') вҰӮ l)вҠў C вҰӮ l')
    eq'
    (sbJg (liftSbВІ p hвӮҖ hвӮҒ x'#О“'
      (ПҖвӮҒ([]вҒ»В№(вҠўok qвӮҖ))) y'#О“'x' refl eq (sbJg p hвӮҖ) hвӮҒ') qвӮҖ)

sbJg p (вҠўрқҗҚрқҗҡрқҗӯ _) = вҠўрқҗҚрқҗҡрқҗӯ (okSb p)

sbJg p (вҠўрқҗірқҗһрқҗ«рқҗЁ _) = вҠўрқҗірқҗһрқҗ«рқҗЁ (okSb p)

sbJg p (вҠўрқҗ¬рқҗ®рқҗңрқҗң q) = вҠўрқҗ¬рқҗ®рқҗңрқҗң (sbJg p q)

sbJg{Пғ}{О“' = О“'} p (вҠўрқҗ§рқҗ«рқҗһрқҗң{l}{C}{cвӮҖ}{a}{cвӮҠ}{x}{y} qвӮҖ qвӮҒ qвӮӮ (qвӮғ вҲүвҲӘ qвӮғ') qвӮ„ h)
  rewrite sb[] Пғ C a =
  -- helper hypotheses used
  вҠўрқҗ§рқҗ«рқҗһрқҗң{x = x'}{y'}
    qвӮҖ'
    qвӮҒ'
    (sbJg p qвӮӮ)
    x'#
    y'#
    h'
  where
  S = supp ((Пғ * C , Пғ * cвӮҠ) , О“')
  x' = new S
  x'# = вҲүвҲӘвӮҒ (newвҲү S)
  x'#О“' = вҲүвҲӘвӮӮ (newвҲү S)
  S' = supp (Пғ * cвӮҠ , О“' , x')
  y' = new S'
  y'# = вҲүвҲӘвӮҒ (newвҲү S')
