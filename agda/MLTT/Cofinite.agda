module MLTT.Cofinite where

open import Prelude
open import WSLN

open import MLTT.Syntax
open import MLTT.Judgement

----------------------------------------------------------------------
-- Provable judgements in context, using cofinite quantification
-- for fresh names
----------------------------------------------------------------------
infix 1 _вҠў_
data Ok : Cx вҶ’ Set
data _вҠў_ (О“ : Cx) : Jg вҶ’ Set

{- Some rules include helper hypotheses that aid proofs by structural
induction; versions of those rules without these hypotheses are
admissible; see MLTT.AdmissibleRules. -}

data Ok where
  -----------------------------
  -- Well-formed contexts: Ok О“
  -----------------------------
  okв—Ү : Ok в—Ү
  okвЁҹ :
    {l : Lvl}
    {О“ : Cx}
    {A : Ty}
    {x : рқ”ё}
    (qвӮҖ : О“ вҠў A вҰӮ l)
    (qвӮҒ : x # О“)
    -- helper hypothesis
    (h : Ok О“)
    вҶ’ ----------------
    Ok (О“ вЁҹ x вҲ¶ A вҰӮ l)

data _вҠў_  О“ where
  -----------------------------------
  -- Well-formed terms: О“ вҠў a вҲ¶ A вҰӮ l
  -----------------------------------
  вҠўconv :
    {l : Lvl}
    {a : Tm}
    {A A' : Ty}
    (qвӮҖ : О“ вҠў a вҲ¶ A вҰӮ l)
    (qвӮҒ : О“ вҠў A пјқ A' вҰӮ l)
    вҶ’ ---------------------
    О“ вҠў a вҲ¶ A' вҰӮ l

  вҠўрқҗҜ :
    {l : Lvl}
    {A : Ty}
    {x : рқ”ё}
    (qвӮҖ : Ok О“)
    (qвӮҒ : (x , A , l) isIn О“)
    вҶ’ -----------------------
    О“ вҠў рқҗҜ x вҲ¶ A вҰӮ l

  вҠўрқҗ” :
    {l : Lvl}
    (q : Ok О“)
    вҶ’ ---------------
    О“ вҠў рқҗ” l вҰӮ (1+ l)

  вҠўрқҡ· :
    {l l' : Lvl}
    {A : Tm}
    {B : Tm[ 1 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў A вҰӮ l)
    (qвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
    вҶ’ -------------------------------
    О“ вҠў рқҡ· l l' A B вҰӮ (max l l')

  вҠўрқӣҢ :
    {l l' : Lvl}
    {A : Ty}
    {B : Ty[ 1 ]}
    {b : Tm[ 1 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў b [ x ] вҲ¶ B [ x ] вҰӮ l')
    -- helper hypotheses
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
    вҶ’ ------------------------------------------
    О“ вҠў рқӣҢ A b вҲ¶ рқҡ· l l' A B вҰӮ max l l'

  вҠўвҲҷ :
    {l l' : Lvl}
    {A : Ty}
    {B : Ty[ 1 ]}
    {a b : Tm}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў b вҲ¶ рқҡ· l l' A B вҰӮ max l l')
    (qвӮҒ : О“ вҠў a вҲ¶ A вҰӮ l)
    (qвӮӮ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ ------------------------------------
    О“ вҠў b вҲҷ[ A , B ] a вҲ¶ B [ a ] вҰӮ l'

  вҠўрқҗҲрқҗқ :
    {l : Lvl}
    {A a b : Tm}
    (qвӮҖ : О“ вҠў a вҲ¶ A вҰӮ l)
    (qвӮҒ : О“ вҠў b вҲ¶ A вҰӮ l)
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ -------------------
    О“ вҠў рқҗҲрқҗқ A a b вҰӮ l

  вҠўрқҗ«рқҗһрқҗҹрқҗҘ :
    {l : Lvl}
    {A : Ty}
    {a : Tm}
    (q : О“ вҠў a вҲ¶ A вҰӮ l)
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ -----------------------
    О“ вҠў рқҗ«рқҗһрқҗҹрқҗҘ a вҲ¶ рқҗҲрқҗқ A a a вҰӮ l

  вҠўрқҗү :
    {l l' : Lvl}
    {A : Ty}
    {C : Ty[ 2 ]}
    {a b c e : Tm}
    (S : Fsetрқ”ё)
    (qвӮҖ : вҲҖ x y вҶ’ x # y # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ рқҗҲрқҗқ A a (рқҗҜ x) вҰӮ l) вҠў
      C [ x ][ y ] вҰӮ l')
    (qвӮҒ : О“ вҠў a вҲ¶ A вҰӮ l)
    (qвӮӮ : О“ вҠў b вҲ¶ A вҰӮ l)
    (qвӮғ : О“ вҠў c вҲ¶ C [ a ][ рқҗ«рқҗһрқҗҹрқҗҘ a ] вҰӮ l')
    (qвӮ„ : О“ вҠў e вҲ¶ рқҗҲрқҗқ A a b вҰӮ l)
    --  helper hypotheses
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў рқҗҲрқҗқ A a (рқҗҜ x) вҰӮ l)
    вҶ’ -----------------------------------------
    О“ вҠў рқҗү C a b c e вҲ¶ C [ b ][ e ] вҰӮ l'

  вҠўрқҗҚрқҗҡрқҗӯ :
    (q : Ok О“)
    вҶ’ -----------
    О“ вҠў рқҗҚрқҗҡрқҗӯ вҰӮ 0

  вҠўрқҗірқҗһрқҗ«рқҗЁ :
    (q : Ok О“)
    вҶ’ ----------------
    О“ вҠў рқҗірқҗһрқҗ«рқҗЁ вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0

  вҠўрқҗ¬рқҗ®рқҗңрқҗң :
    {a : Tm}
    (q : О“ вҠў a вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0)
    вҶ’ -------------------
    О“ вҠў рқҗ¬рқҗ®рқҗңрқҗң a вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0

  вҠўрқҗ§рқҗ«рқҗһрқҗң :
    {l : Lvl}
    {C : Ty[ 1 ]}
    {cвӮҖ a : Tm}
    {cвӮҠ : Tm[ 2 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў cвӮҖ вҲ¶ C [ рқҗірқҗһрқҗ«рқҗЁ ] вҰӮ l)
    (qвӮҒ : вҲҖ x y вҶ’ x # y # S вҶ’
      (О“ вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ C [ x ] вҰӮ l) вҠў
      cвӮҠ [ x ][ y ] вҲ¶ C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вҰӮ l)
    (qвӮӮ : О“ вҠў a вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0)
    --  helper hypothesis
    (h : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C [ x ] вҰӮ l)
    вҶ’ --------------------------------------
    О“ вҠў рқҗ§рқҗ«рқҗһрқҗң C cвӮҖ cвӮҠ a вҲ¶ C [ a ] вҰӮ l

  ---------------------------------------
  -- Term conversion: О“ вҠў a пјқ a' вҲ¶ A вҰӮ l
  ---------------------------------------
  Refl :
    {l : Lvl}
    {A : Ty}
    {a : Tm}
    (q : О“ вҠў a вҲ¶ A вҰӮ l)
