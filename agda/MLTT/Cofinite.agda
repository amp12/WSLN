  рқӣҢCong :
    {l l' : Lvl}
    {A A' : Ty}
    {B : Ty[ 1 ]}
    {b b' : Tm[ 1 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў A пјқ A' вҰӮ l)
    (qвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў b [ x ] пјқ b' [ x ] вҲ¶ B [ x ] вҰӮ l')
    -- helper hypothesis
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
