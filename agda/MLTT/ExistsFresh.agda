----------------------------------------------------------------------
-- "Exists fresh" style typing rules (without helper hypotheses)
----------------------------------------------------------------------
вҠўрқҡ·вҒ» :
  {О“ : Cx}
  {l l' : Lvl}
  {A : Tm}
  {B : Tm[ 1 ]}
  {x : рқ”ё}
  (_ : О“ вҠў A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
  (_ : x # B)
  вҶ’ ----------------------------------
  О“ вҠў рқҡ· l l' A B вҰӮ (max l l')

вҠўрқҡ·вҒ»{О“}{l}{l'}{A}{B}{x} qвӮҖ qвӮҒ qвӮӮ = вҠўрқҡ·
  (supp О“)
  qвӮҖ
  О» y y#О“ вҶ’ subst (О» B' вҶ’ (О“ вЁҹ y вҲ¶ A вҰӮ l) вҠў B' вҰӮ l')
    (ssb[] x (рқҗҜ y) B qвӮӮ)
    (rnвЁҹ qвӮҒ y#О“)

вҠўрқӣҢвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A : Ty}
  {B : Ty[ 1 ]}
  {b : Tm[ 1 ]}
  {x : рқ”ё}
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў b [ x ] вҲ¶ B [ x ] вҰӮ l')
  (_ : x # (B , b))
  вҶ’ --------------------------------------------
  О“ вҠў рқӣҢ A b вҲ¶ рқҡ· l l' A B вҰӮ max l l'

вҠўрқӣҢвҒ»{l}{l'}{О“}{A}{B}{b}{x} q (x#B вҲүвҲӘ x#b)
  with okвЁҹ q' x#О“ okО“ вҶҗ вҠўok q = вҠўрқӣҢ
  (supp О“)
  (О» y y#О“ вҶ’ substвӮӮ (О» b' B' вҶ’ (О“ вЁҹ y вҲ¶ A вҰӮ l) вҠў b' вҲ¶ B' вҰӮ l')
    (ssb[] x (рқҗҜ y) b x#b)
    (ssb[] x (рқҗҜ y) B x#B)
    (rnвЁҹ q y#О“))
  q'
  О» y y#О“ вҶ’ subst (О» B' вҶ’ (О“ вЁҹ y вҲ¶ A вҰӮ l) вҠў B' вҰӮ l')
    (ssb[] x (рқҗҜ y) B x#B)
    (rnвЁҹ (вҠўвҲ¶ty q) y#О“)

вҠўвҲҷвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A : Ty}
  {B : Ty[ 1 ]}
  {a b : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў b вҲ¶ рқҡ· l l' A B вҰӮ max l l')
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
  (_ : x # B)
  вҶ’ ----------------------------------
  О“ вҠў b вҲҷ[ A , B ] a вҲ¶ B [ a ] вҰӮ l'

вҠўвҲҷвҒ»{l}{l'}{О“}{A}{B}{x = x} qвӮҖ qвӮҒ qвӮӮ x#B = вҠўвҲҷ
  (supp О“)
  qвӮҖ
  qвӮҒ
  (О» y y#О“ вҶ’ subst (О» B' вҶ’ (О“ вЁҹ y вҲ¶ A вҰӮ l) вҠў B' вҰӮ l')
    (ssb[] x (рқҗҜ y) B x#B)
    (rnвЁҹ qвӮӮ y#О“))
  (вҠўвҲ¶ty qвӮҒ)

вҠўрқҗҲрқҗқвҒ» :
  {l : Lvl}
  {О“ : Cx}
  {A a b : Tm}
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : О“ вҠў b вҲ¶ A вҰӮ l)
  вҶ’ ------------------
  О“ вҠў рқҗҲрқҗқ A a b вҰӮ l

вҠўрқҗҲрқҗқвҒ» qвӮҖ qвӮҒ = вҠўрқҗҲрқҗқ qвӮҖ qвӮҒ (вҠўвҲ¶ty qвӮҖ)

вҠўрқҗ«рқҗһрқҗҹрқҗҘвҒ» :
  {l : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a : Tm}
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  вҶ’ -----------------------
  О“ вҠў рқҗ«рқҗһрқҗҹрқҗҘ a вҲ¶ рқҗҲрқҗқ A a a вҰӮ l

вҠўрқҗ«рқҗһрқҗҹрқҗҘвҒ» q = вҠўрқҗ«рқҗһрқҗҹрқҗҘ q (вҠўвҲ¶ty q)

вҠўрқҗүвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A : Ty}
  {C : Ty[ 2 ]}
  {a b c e : Tm}
  {x y : рқ”ё}
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ рқҗҲрқҗқ A a (рқҗҜ x) вҰӮ l) вҠў
    C [ x ][ y ] вҰӮ l')
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : О“ вҠў b вҲ¶ A вҰӮ l)
  (_ : О“ вҠў c вҲ¶ C [ a ][ рқҗ«рқҗһрқҗҹрқҗҘ a ] вҰӮ l')
  (_ : О“ вҠў e вҲ¶ рқҗҲрқҗқ A a b вҰӮ l)
  (_ : x # C)
  (_ : y # C)
  вҶ’ --------------------------------------------
  О“ вҠў рқҗү C a b c e вҲ¶ C [ b ][ e ] вҰӮ l'

вҠўрқҗүвҒ»{l}{l'}{О“}{A}{C}{a}{b}{c}{e}{x}{y} qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ x#C y#C
  with okвЁҹ q (y#О“ вҲүвҲӘ y#x) (okвЁҹ q' x#О“ okО“) вҶҗ вҠўok qвӮҖ = вҠўрқҗү
  (supp О“)
  (О»{x' y' (##:: y'#О“ (##:: (x'#y' вҲүвҲӘ x'#О“) ##в—Ү)) вҶ’
    substвӮӮ (О» I C' вҶ’
      (О“ вЁҹ x' вҲ¶ A вҰӮ l вЁҹ y' вҲ¶ I вҰӮ l) вҠў C' вҰӮ l')
      (eq (рқҗҜ x'))
      (ssb[]ВІ x y (рқҗҜ x') (рқҗҜ y') C x#C (y#C вҲүвҲӘ y#x))
      (rnвЁҹВІ qвӮҖ x'#О“ ((#symm x'#y') вҲүвҲӘ y'#О“))})
  qвӮҒ
  qвӮӮ
  qвӮғ
  qвӮ„
  (вҠўвҲ¶ty qвӮҒ)
  О» x' x'#О“ вҶ’ subst (О» I вҶ’ (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў I вҰӮ l)
    (eq (рқҗҜ x'))
    (rnвЁҹ q x'#О“)
  where
  x#A : x # A
  x#A = вҠҶвҲү (вҠўsupp q' вҲҳ вҲҲвҲӘвӮҒ) x#О“
  x#a : x # a
  x#a = вҠҶвҲү (вҠўsupp qвӮҒ вҲҳ вҲҲвҲӘвӮҒ) x#О“

  eq : вҲҖ a' вҶ’ (x := a') * рқҗҲрқҗқ A a (рқҗҜ x) вүЎ рқҗҲрқҗқ A a a'
  eq a' rewrite ssbFresh x a' A x#A
        | ssbFresh x a' a x#a
        | updateEq{Пғ = id}{a'} x = refl

вҠўрқҗ§рқҗ«рқҗһрқҗңвҒ» :
  {l : Lvl}
  {О“ : Cx}
  {C : Ty[ 1 ]}
  {cвӮҖ a : Tm}
  {cвӮҠ : Tm[ 2 ]}
  {x y : рқ”ё}
  (_ : О“ вҠў cвӮҖ вҲ¶ C [ рқҗірқҗһрқҗ«рқҗЁ ] вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ C [ x ] вҰӮ l) вҠў
    cвӮҠ [ x ][ y ] вҲ¶ C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вҰӮ l)
  (_ : О“ вҠў a вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0)
  (_ : x # (C , cвӮҠ))
  (_ : y # cвӮҠ)
  вҶ’ ----------------------------------------
  О“ вҠў рқҗ§рқҗ«рқҗһрқҗң C cвӮҖ cвӮҠ a вҲ¶ C [ a ] вҰӮ l

вҠўрқҗ§рқҗ«рқҗһрқҗңвҒ»{l}{О“}{C}{cвӮҖ}{a}{cвӮҠ}{x}{y} qвӮҖ qвӮҒ qвӮӮ (x#C вҲүвҲӘ x#cвӮҠ) y#cвӮҠ
  with okвЁҹ q (y#О“ вҲүвҲӘ y#x) (okвЁҹ q' x#О“ okО“) вҶҗ вҠўok qвӮҒ = вҠўрқҗ§рқҗ«рқҗһрқҗң
  (supp О“)
  qвӮҖ
  (О»{x' y' (##:: y'#О“ (##:: (x'#y' вҲүвҲӘ x'#О“) ##в—Ү)) вҶ’
    substвӮғ (О» C' c' C'' вҶ’
      (О“ вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y' вҲ¶ C' вҰӮ l) вҠў c' вҲ¶ C'' вҰӮ l)
      (ssb[] x (рқҗҜ x') C x#C)
      (ssb[]ВІ x y (рқҗҜ x') (рқҗҜ y') cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ y#x))
      (eq (рқҗҜ x') (рқҗҜ y'))
      (rnвЁҹВІ qвӮҒ x'#О“ (#symm x'#y' вҲүвҲӘ y'#О“))})
  qвӮӮ
  О» x' x'#О“ вҶ’ subst (О» C' вҶ’ (О“ вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
    (ssb[] x (рқҗҜ x') C x#C)
    (rnвЁҹ q x'#О“)
  where
  y#C : y # C
  y#C = вҠҶвҲү (вҠўsupp qвӮҖ вҲҳ вҲҲвҲӘвӮӮ вҲҳ []supp C рқҗірқҗһрқҗ«рқҗЁ) y#О“
  y#Cs : y # C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
  y#Cs = вҠҶвҲү (supp[] C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))) (y#C вҲүвҲӘ y#x вҲүвҲӘ вҲүвҲ…)

  eq : вҲҖ a' b' вҶ’
    (x := a' вҲҳ/ y := b') * C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ C [ рқҗ¬рқҗ®рқҗңрқҗң a' ]
  eq a' b' =
    begin
      (x := a' вҲҳ/ y := b')* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
    вүЎвҹЁ updateFresh (x := a') y b' (C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]) y#Cs  вҹ©
      (x := a') * C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
    вүЎвҹЁ sb[] (x := a') C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x)) вҹ©
      ((x := a') * C) [ (x := a') * (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x)) ]
    вүЎвҹЁ (cong (_[ (x := a') * рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ])) (ssbFresh x a' C x#C) вҹ©
      C [ (x := a') * (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x)) ]
    вүЎвҹЁвҹ©
      C [ рқҗ¬рқҗ®рқҗңрқҗң ((x := a') * рқҗҜ x) ]
    вүЎвҹЁ cong (О» d вҶ’ C [ рқҗ¬рқҗ®рқҗңрқҗң d ]) (updateEq{Пғ = id}{a'} x) вҹ©
      C [ рқҗ¬рқҗ®рқҗңрқҗң a' ]
    вҲҺ

рқҡ·CongвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A A' : Ty}
  {B B' : Ty[ 1 ]}
  {x : рқ”ё}
  (_ : О“ вҠў A пјқ A' вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў
    B [ x ] пјқ B' [ x ] вҰӮ l')
  (_ : x # (B , B'))
  вҶ’ -----------------------------------------
  О“ вҠў рқҡ· l l' A B пјқ рқҡ· l l' A' B' вҰӮ (max l l')

рқҡ·CongвҒ»{l}{l'}{О“}{A}{A'}{B}{B'}{x}  qвӮҖ qвӮҒ (x#B вҲүвҲӘ x#B') = рқҡ·Cong
  (supp О“)
  qвӮҖ
  (О» x' x'#О“ вҶ’ substвӮӮ (О» C C' вҶ’ (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў C пјқ C' вҰӮ l')
    (ssb[] x (рқҗҜ x') B x#B)
    (ssb[] x (рқҗҜ x') B' x#B')
    (rnвЁҹ qвӮҒ x'#О“))
  (вҠўtyвӮҒ qвӮҖ)

рқӣҢCongвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A A' : Ty}
  {B : Ty[ 1 ]}
  {b b' : Tm[ 1 ]}
  {x : рқ”ё}
  (_ : О“ вҠў A пјқ A' вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў
    b [ x ] пјқ b' [ x ] вҲ¶ B [ x ] вҰӮ l')
  (_ : x # (B , b , b'))
  вҶ’ ------------------------------------------
  О“ вҠў рқӣҢ A b пјқ рқӣҢ A' b' вҲ¶ рқҡ· l l' A B вҰӮ max l l'

рқӣҢCongвҒ»{l}{l'}{О“}{A}{A'}{B}{b}{b'}{x} qвӮҖ qвӮҒ (x#B вҲүвҲӘ x#b вҲүвҲӘ x#b') = рқӣҢCong
  (supp О“)
  qвӮҖ
  (О» x' x'#О“ вҶ’ substвӮғ (О» c c' C вҶ’
    (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў c пјқ c' вҲ¶ C вҰӮ l')
    (ssb[] x (рқҗҜ x') b x#b)
    (ssb[] x (рқҗҜ x') b' x#b')
    (ssb[] x (рқҗҜ x') B x#B)
    (rnвЁҹ qвӮҒ x'#О“))
  (вҠўtyвӮҒ qвӮҖ)
  О» x' x'#О“ вҶ’
    subst (О» C вҶ’ (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў C вҰӮ l')
    (ssb[] x (рқҗҜ x') B x#B)
    (rnвЁҹ (вҠўвҲ¶ty (вҠўtyвӮҒ qвӮҒ)) x'#О“)

вҲҷCongвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A A' : Ty}
  {B B' : Ty[ 1 ]}
  {a a' b b' : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў A пјқ A' вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] пјқ B' [ x ] вҰӮ l')
  (_ : О“ вҠў b пјқ b' вҲ¶ рқҡ· l l' A B вҰӮ max l l')
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  (_ : x # (B , B'))
  вҶ’ -----------------------------------------------------
  О“ вҠў b вҲҷ[ A , B ] a пјқ b' вҲҷ[ A' , B' ] a' вҲ¶ B [ a ] вҰӮ l'

вҲҷCongвҒ»{l}{l'}{О“}{A}{A'}{B}{B'}{a}{a'}{b}{b'}{x}
  qвӮҖ qвӮҒ qвӮӮ qвӮғ (x#B вҲүвҲӘ x#B') = вҲҷCong
  (supp О“)
  qвӮҖ
  (О» x' x'#О“ вҶ’ substвӮӮ (О» C C' вҶ’
    (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў C пјқ C' вҰӮ l')
    (ssb[] x (рқҗҜ x') B x#B)
    (ssb[] x (рқҗҜ x') B' x#B')
    (rnвЁҹ qвӮҒ x'#О“))
  qвӮӮ
  qвӮғ
  (вҠўtyвӮҒ qвӮҖ)
  О» x' x'#О“ вҶ’ subst (О» C вҶ’
    (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў C вҰӮ l')
    (ssb[] x (рқҗҜ x') B x#B)
    (rnвЁҹ (вҠўtyвӮҒ qвӮҒ) x'#О“)

рқҗ«рқҗһрқҗҹрқҗҘCongвҒ» :
  {l : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a a' : Tm}
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  вҶ’ ----------------------------------
  О“ вҠў рқҗ«рқҗһрқҗҹрқҗҘ a пјқ рқҗ«рқҗһрқҗҹрқҗҘ a' вҲ¶ рқҗҲрқҗқ A a a вҰӮ l

рқҗ«рқҗһрқҗҹрқҗҘCongвҒ» q = рқҗ«рқҗһрқҗҹрқҗҘCong q (вҠўвҲ¶ty (вҠўtyвӮҒ q))

рқҗүCongвҒ»  :
  {l l' : Lvl}
  {О“ : Cx}
  {A : Ty}
  {C C' : Ty[ 2 ]}
  {a a' b b' c c' e e' : Tm}
  {x y : рқ”ё}
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ рқҗҲрқҗқ A a (рқҗҜ x) вҰӮ l) вҠў
    C [ x ][ y ] пјқ C' [ x ][ y ] вҰӮ l')
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  (_ : О“ вҠў b пјқ b' вҲ¶ A вҰӮ l)
  (_ : О“ вҠў c пјқ c' вҲ¶ C [ a ][ рқҗ«рқҗһрқҗҹрқҗҘ a ] вҰӮ l')
  (_ : О“ вҠў e пјқ e' вҲ¶ рқҗҲрқҗқ A a b вҰӮ l)
  (_ : x # (C , C'))
  (_ : y # (C , C'))
  вҶ’ -----------------------------------------------------
  О“ вҠў рқҗү C a b c e пјқ рқҗү C' a' b' c' e' вҲ¶ C [ b ][ e ] вҰӮ l'

рқҗүCongвҒ»{l}{l'}{О“}{A}{C}{C'}{a}{a'}{b}{b'}{c}{c'}{e}{e'}{x}{y}
  qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ (x#C вҲүвҲӘ x#C') (y#C вҲүвҲӘ y#C')
  with okвЁҹ q (y#О“ вҲүвҲӘ y#x) (okвЁҹ q' x#О“ okО“) вҶҗ вҠўok qвӮҖ = рқҗүCong
  (supp О“)
