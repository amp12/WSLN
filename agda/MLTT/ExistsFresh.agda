  (О»{x' y' (##:: y'#О“ (##:: (x'#y' вҲүвҲӘ x'#О“) ##в—Ү)) вҶ’
    substвӮғ (О» C' c' C'' вҶ’
      (О“ вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y' вҲ¶ C' вҰӮ l) вҠў c' вҲ¶ C'' вҰӮ l)
      (ssb[] x (рқҗҜ x') C x#C)
      (ssb[]ВІ x y (рқҗҜ x') (рқҗҜ y') cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ y#x))
      (eq (рқҗҜ x') (рқҗҜ y'))
      (rnвЁҹВІ qвӮҒ x'#О“ (#symm x'#y' вҲүвҲӘ y'#О“))})
  qвӮӮ
  (О» x' x'#О“ вҶ’ subst (О» C' вҶ’ (О“ вЁҹ x' вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
    (ssb[] x (рқҗҜ x') C x#C)
    (rnвЁҹ q x'#О“))
  where
  y#C : y # C
  y#C = вҠҶвҲү (вҠўsupp qвӮҖ вҲҳ вҲҲвҲӘвӮӮ вҲҳ []supp C рқҗірқҗһрқҗ«рқҗЁ) y#О“
  y#Cs : y # C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
  y#Cs = вҠҶвҲү (supp[] C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))) (y#C вҲүвҲӘ y#x вҲүвҲӘ вҲүвҲ…)

  eq : вҲҖ a' b' вҶ’
    (x := a' вҲҳ/ y := b') * C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ C [ рқҗ¬рқҗ®рқҗңрқҗң a' ]
  eq a' b' =
    begin
      (x := a' вҲҳ/ y := b')* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
    вүЎвҹЁ updateFresh (x := a') y b' (C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]) y#Cs  вҹ©
      (x := a') * C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
    вүЎвҹЁ sb[] (x := a') C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x)) вҹ©
      ((x := a') * C) [ (x := a') * (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x)) ]
    вүЎвҹЁ (cong (_[ (x := a') * рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ])) (ssbFresh x a' C x#C) вҹ©
      C [ (x := a') * (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x)) ]
    вүЎвҹЁвҹ©
      C [ рқҗ¬рқҗ®рқҗңрқҗң ((x := a') * рқҗҜ x) ]
    вүЎвҹЁ cong (О» d вҶ’ C [ рқҗ¬рқҗ®рқҗңрқҗң d ]) (updateEq{Пғ = id}{a'} x) вҹ©
      C [ рқҗ¬рқҗ®рқҗңрқҗң a' ]
    вҲҺ

рқҡ·вҒ»В№ :
  {l l' l'' : Lvl}
  {О“ : Cx}
  {A C : Ty}
  {B : Ty[ 1 ]}
  {x : рқ”ё}
  (_ : О“ вҠў рқҡ· l l' A B вҲ¶ C вҰӮ l'')
  (_ : x # О“)
  вҶ’ ----------------------------
  (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l'

рқҡ·вҒ»В№ (вҠўconv q _) x# = рқҡ·вҒ»В№ q x#
рқҡ·вҒ»В№{l}{l'}{О“ = О“}{A}{B = B}{x} (вҠўрқҡ· S qвӮҖ qвӮҒ) x#О“
  with (x' , x'#S вҲүвҲӘ x'#B) вҶҗ fresh (S , B) =
  subst (О» B' вҶ’ (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B' вҰӮ l')
    ((ssb[] x' (рқҗҜ x) B x'#B))
    (rnвЁҹ (qвӮҒ x' x'#S) x#О“)

рқҡ·EtaвҒ» :
  {l l' : Lvl}
  {О“ : Cx}
  {A : Ty}
  {B : Ty[ 1 ]}
  {b : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў b вҲ¶ рқҡ· l l' A B вҰӮ max l l')
  (_ : x # О“)
  вҶ’ -------------------------------------------------------------
  О“ вҠў b пјқ рқӣҢ A (x пјҺ (b вҲҷ[ A , B ] рқҗҜ x)) вҲ¶ рқҡ· l  l' A B вҰӮ max l l'

рқҡ·EtaвҒ»{l}{l'}{О“}{A}{B}{b}{x} q x#О“
  with (x' , x'#О“ вҲүвҲӘ x'#x) вҶҗ fresh (О“ , x) =
  рқҡ·Eta (supp (О“ , x)) q q' (О» y y# вҶ’ Symm (q'' y y#)) вҠўA
  where
  x#b : x # b
  x#b = вҠҶвҲү (вҠўsupp q вҲҳ вҲҲвҲӘвӮҒ) x#О“
  x#A : x # A
  x#A = вҠҶвҲү (вҠўsupp q вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮҒ) x#О“
  x#B : x # B
  x#B = вҠҶвҲү (вҠўsupp q вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮҒ) x#О“
  x'#B : x' # B
  x'#B = вҠҶвҲү (вҠўsupp q вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮӮ вҲҳ вҲҲвҲӘвӮҒ) x'#О“

  вҠўBx' : (О“ вЁҹ x' вҲ¶ A вҰӮ l) вҠў B [ x' ] вҰӮ l'
  вҠўBx'  = рқҡ·вҒ»В№ (вҠўвҲ¶ty q) x'#О“

  вҠўA : О“ вҠў A вҰӮ l
  вҠўA = ПҖвӮҒ (ПҖвӮӮ ([]вҒ»В№ (вҠўok вҠўBx')))

  r : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў b вҲҷ[ A , B ] рқҗҜ x вҲ¶ B [ x ] вҰӮ l'
  r = вҠўвҲҷвҒ» {x = x'}
    (в–·Jg (proj вҠўA x#О“) q)
    (вҠўрқҗҜ (okвЁҹ вҠўA x#О“ (вҠўok q)) isInNew)
    (в–·Jg
          (в–·вЁҹ (proj вҠўA x#О“) вҠўA (x'#О“ вҲүвҲӘ x'#x) (в–·Jg (proj вҠўA x#О“) вҠўA))
          вҠўBx')
    x'#B

  q' : О“ вҠў рқӣҢ A (x пјҺ b вҲҷ[ A , B ] рқҗҜ x) вҲ¶ рқҡ· l l' A B вҰӮ max l l'
  q' = вҠўрқӣҢвҒ»{x = x}
    (subst (О» c вҶ’ (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў c вҲ¶ B [ x ] вҰӮ l')
      (symm (concAbs' x (b вҲҷ[ A , B ] рқҗҜ x)))
      r)
    (x#B вҲүвҲӘ #abs x (b вҲҷ[ A , B ] рқҗҜ x))

  q'' : вҲҖ y вҶ’ y # (О“ , x) вҶ’ (О“ вЁҹ y вҲ¶ A вҰӮ l) вҠў
    (рқӣҢ A (x пјҺ (b вҲҷ[ A , B ] рқҗҜ x))) вҲҷ[ A , B ] рқҗҜ y пјқ
    b вҲҷ[ A , B ] рқҗҜ y вҲ¶ B [ y ] вҰӮ l'
  q'' y (y#О“ вҲүвҲӘ y#x) = subst (О» b' вҶ’
    (О“ вЁҹ y вҲ¶ A вҰӮ l) вҠў
      (рқӣҢ A (x пјҺ (b вҲҷ[ A , B ] рқҗҜ x))) вҲҷ[ A , B ] рқҗҜ y пјқ
      b'  вҲ¶ B [ y ] вҰӮ l')
    eq
    (рқҡ·BetaвҒ»{x = x}
      (subst (О» c вҶ’ (О“ вЁҹ y вҲ¶ A вҰӮ l вЁҹ x вҲ¶ A вҰӮ l) вҠў c вҲ¶ B [ x ] вҰӮ l')
        (symm (concAbs' x (b вҲҷ[ A , B ] рқҗҜ x)))
        (в–·Jg
          (в–·вЁҹ (proj вҠўA y#О“) вҠўA (x#О“ вҲүвҲӘ #symm y#x) (в–·Jg (proj вҠўA y#О“) вҠўA))
          r))
      (вҠўрқҗҜ (okвЁҹ вҠўA y#О“ (вҠўok q)) isInNew)
      (x#B вҲүвҲӘ (#abs x (b вҲҷ[ A , B ] рқҗҜ x))))
    where
    eq : (x пјҺ (b вҲҷ[ A , B ] рқҗҜ x)) [ y ] вүЎ b вҲҷ[ A , B ] рқҗҜ y
    eq rewrite concAbs x (b вҲҷ[ A , B ] рқҗҜ x) (рқҗҜ y)
       | ssbFresh x (рқҗҜ y) b x#b
       | ssbFresh x (рқҗҜ y) A x#A
       | ssbFresh x (рқҗҜ y) B x#B
       | updateEq{Пғ = id}{рқҗҜ y} x = refl

