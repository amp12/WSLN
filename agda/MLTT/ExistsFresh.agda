  {О“ О“' : Cx}
  {A A' : Ty}
  {x : рқ”ё}
  (_ : вҠў О“ пјқ О“')
  (_ : О“ вҠў A пјқ A' вҰӮ l)
  (_ : x # (О“ , О“'))
