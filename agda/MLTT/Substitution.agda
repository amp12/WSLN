module MLTT.Substitution where

open import Prelude
open import WSLN

open import MLTT.Syntax
open import MLTT.Judgement
open import MLTT.Cofinite
open import MLTT.Ok
open import MLTT.WellScoped
open import MLTT.Weakening

----------------------------------------------------------------------
-- Weakening substitutions
----------------------------------------------------------------------
в–·Sb :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  (x : рқ”ё)
  (_ : О“' вҠў A вҰӮ l)
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : x # О“')
  вҶ’ -----------------------
  (О“' вЁҹ x вҲ¶ A вҰӮ l)вҠўЛў Пғ вҲ¶ О“

в–·Sb x q (в—ҮЛў q') q'' = в—ҮЛў (okвЁҹ q q'' q')
в–·Sb x q (вЁҹЛў qвӮҖ qвӮҒ qвӮӮ qвӮғ) q' =
  вЁҹЛў (в–·Sb x q qвӮҖ q') qвӮҒ (в–·Jg (proj q q') qвӮӮ)  qвӮғ

в–·пјқSb :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {A : Ty}
  (x : рқ”ё)
  (_ : О“' вҠў A вҰӮ l)
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : x # О“')
  вҶ’ ----------------------------
  (О“' вЁҹ x вҲ¶ A вҰӮ l)вҠўЛў Пғ пјқ Пғ' вҲ¶ О“

в–·пјқSb x q (пјқв—ҮЛў q') q'' = пјқв—ҮЛў (okвЁҹ q q'' q')
в–·пјқSb x q (пјқвЁҹЛў qвӮҖ qвӮҒ qвӮӮ qвӮғ) q' =
  пјқвЁҹЛў (в–·пјқSb x q qвӮҖ q') qвӮҒ (в–·Jg (proj q q') qвӮӮ)  qвӮғ

----------------------------------------------------------------------
-- Identity substitution is well-typed
----------------------------------------------------------------------
вҠўidЛў :
  {О“ : Cx}
  (_ : Ok О“)
  вҶ’ ---------
  О“ вҠўЛў idЛў вҲ¶ О“

вҠўidЛў okв—Ү = в—ҮЛў okв—Ү
вҠўidЛў (okвЁҹ{l}{О“}{A}{x} q q' q'') = вЁҹЛў
  (в–·Sb _ q (вҠўidЛў q'') q')
  q
  (вҠўрқҗҜ (okвЁҹвҒ» q q') (subst (О» A' вҶ’ (x , A' , l) isIn (О“ вЁҹ x вҲ¶ A вҰӮ l))
    (symm (sbUnit A))
    isInNew))
  q'

----------------------------------------------------------------------
-- Extensionality properties of well-typed substitutions
----------------------------------------------------------------------
sbExt :
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ Пғ x вүЎ Пғ' x)
  вҶ’ --------------------------------
  О“' вҠўЛў Пғ' вҲ¶ О“

sbExt (в—ҮЛў q) _ = в—ҮЛў q
sbExt{Пғ}{Пғ'} (вЁҹЛў{A = A}{x} qвӮҖ qвӮҒ qвӮӮ qвӮғ) e
  rewrite sbRespSupp Пғ Пғ' A (О» x' p' вҶ’ e x' (вҲҲвҲӘвӮҒ (вҠўsupp qвӮҒ (вҲҲвҲӘвӮҒ p'))))
  | e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = вЁҹЛў (sbExt qвӮҖ (О» y r вҶ’ e y (вҲҲвҲӘвӮҒ r))) qвӮҒ qвӮӮ qвӮғ

sbпјқExt :
  {Пғ' П„' Пғ П„ : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ пјқ П„ вҲ¶ О“)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ Пғ x вүЎ Пғ' x)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ П„ x вүЎ П„' x)
  вҶ’ --------------------------------
  О“' вҠўЛў Пғ' пјқ П„' вҲ¶ О“

sbпјқExt (в—Ү q) _ _ = в—Ү q
sbпјқExt{Пғ'}{П„'} ([]{Пғ = Пғ}{П„}{A = A}{x} qвӮҖ qвӮҒ qвӮӮ qвӮғ) e e'
  rewrite sbRespSupp Пғ Пғ' A (О» x' p' вҶ’ e x' (вҲҲвҲӘвӮҒ (вҠўsupp qвӮҒ (вҲҲвҲӘвӮҒ p'))))
  | e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ)
  | e' x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ)= []
    (sbпјқExt qвӮҖ (О» y r вҶ’ e y (вҲҲвҲӘвӮҒ r)) (О» y' r' вҶ’ e' y' (вҲҲвҲӘвӮҒ r')))
    qвӮҒ
    qвӮӮ
    qвӮғ

----------------------------------------------------------------------
-- Lifting substitutions
----------------------------------------------------------------------
liftSb :
  {l : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : x # О“)
  (_ : x' # О“')
  -- helper hypothesis
  (_ : О“' вҠў Пғ * A вҰӮ l)
  вҶ’ --------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l)вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

liftSb{l}{Пғ}{О“}{О“'}{A}{x}{x'} вҠўПғ вҠўA x#О“ x'#О“' вҠўПғA =
  вЁҹЛў (в–·Sb x' вҠўПғA вҠўПғ' x'#О“') вҠўA вҠўA' x#О“
  where
  вҠўПғ' : О“' вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ О“
  вҠўПғ' = sbExt вҠўПғ (О» y r вҶ’
    symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r }))

  вҠўA' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l)вҠў
    (Пғ вҲҳ/ x := рқҗҜ x') x вҲ¶ (Пғ вҲҳ/ x := рқҗҜ x') * A вҰӮ l
  вҠўA' rewrite updateFresh Пғ x (рқҗҜ x') A (вҲүвҲӘвӮҒ (вҠў# вҠўA x#О“))
      | :=Eq{f = Пғ}{рқҗҜ x'} x = вҠўрқҗҜ (okвЁҹвҒ» вҠўПғA x'#О“') isInNew

-- Iterated lifting
liftSbВІ :
  {l l' : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A A' B B' : Ty}
  {x y x' y' : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l)вҠў B вҰӮ l')
  (_ : x' # О“')
  (_ : y # (О“ , x))
  (_ : y' # (О“' , x'))
  (_ : Пғ * A вүЎ A')
  (_ : (Пғ вҲҳ/ x := рқҗҜ x') * B вүЎ B')
  -- helper hypotheses
  (_ : О“' вҠў A' вҰӮ l)
  (_ : (О“' вЁҹ x' вҲ¶ A' вҰӮ l) вҠў B' вҰӮ l')
  вҶ’ -------------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ A' вҰӮ l вЁҹ y' вҲ¶ B' вҰӮ l') вҠўЛў
    ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')

liftSbВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… refl refl h h' =
  liftSb (liftSb qвӮҖ qвӮҒ (ПҖвӮҒ ([]вҒ»В№ (вҠўok qвӮӮ))) qвӮғ h) qвӮӮ qвӮ„ qвӮ… h'

----------------------------------------------------------------------
-- Types of variables under substitution
----------------------------------------------------------------------
sbVar :
  {l : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  {A : Ty}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : (x , A , l) isIn О“)
  вҶ’ ----------------------
  О“' вҠў Пғ x вҲ¶ Пғ * A вҰӮ l

sbVar (вЁҹЛў _ _ q _)  isInNew     = q
sbVar (вЁҹЛў q _ _ _) (isInOld q') = sbVar q q'

sbVarпјқ :
  {l : Lvl}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  {A : Ty}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_  : (x , A , l) isIn О“)
  вҶ’ --------------------------
  О“' вҠў Пғ x пјқ Пғ' x вҲ¶ Пғ * A вҰӮ l

sbVarпјқ ([] _ _ q _)  isInNew     = q
sbVarпјқ ([] q _ _ _) (isInOld q') = sbVarпјқ q q'

sbDom :
  {Пғ : Sb}
  {О“ О“' : Cx}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : x вҲҲ dom О“)
  вҶ’ ----------------
  supp (Пғ x) вҠҶ dom О“'

sbDom p q =
  let (_ , _ , q') = domвҶ’isIn q
  in вҠўsupp (sbVar p q') вҲҳ вҲҲвҲӘвӮҒ

----------------------------------------------------------------------
-- Substitution preserves provable judgements
----------------------------------------------------------------------
sbJg :
  {Пғ : Sb}
  {О” О“ : Cx}
  {J : Jg}
  (_ : О” вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў J)
  вҶ’ --------------
  О” вҠў Пғ * J

sbJg p (вҠўconv qвӮҖ qвӮҒ) = вҠўconv
  (sbJg p qвӮҖ)
  (sbJg p qвӮҒ)

sbJg{Пғ} p (вҠўрқҗҜ{x = x} _ q)
  rewrite вҖҝunit (Пғ x) вҰғ it вҰ„ = sbVar p q

sbJg p (вҠўрқҗ” _) = вҠўрқҗ” (okSb p)

sbJg{Пғ}{О”} p (вҠўрқҡ·{l}{l'}{A = A}{B} S qвӮҖ qвӮҒ) = вҠўрқҡ·
  (S вҲӘ supp (О” , B))
  (sbJg p qвӮҖ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B) вҶ’
    subst (О» B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p qвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok (qвӮҒ x x#S)))) x#О” (sbJg p qвӮҖ))
        (qвӮҒ x x#S))}

sbJg{Пғ}{О”} p (вҠўрқӣҢ{l}{l'}{A = A}{B}{b} S qвӮҖ hвӮҖ hвӮҒ) = вҠўрқӣҢ
  (S вҲӘ supp (О” , B , b))
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B вҲүвҲӘ x#b) вҶ’
    substвӮӮ (О» b' B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў b' вҲ¶ B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) b x#b)
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg p hвӮҖ))
        (qвӮҖ x x#S))})
  (sbJg p hвӮҖ)
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B вҲүвҲӘ x#b) вҶ’
    subst (О» B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg p hвӮҖ))
        (hвӮҒ x x#S))})

sbJg{Пғ}{О”} p (вҠўвҲҷ{l}{l'}{A = A}{B = B}{a}{b} S qвӮҖ qвӮҒ qвӮӮ h)
  rewrite sb[] Пғ B a = вҠўвҲҷ
  (S вҲӘ supp (О” , B))
  (sbJg p qвӮҖ)
  (sbJg p qвӮҒ)
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B) вҶ’
    subst (О» C вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў C вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p h (ПҖвӮҒ ([]вҒ»В№(вҠўok (qвӮӮ x x#S)))) x#О” (sbJg p h))
        (qвӮӮ x x#S))})
  (sbJg p h)

sbJg p (вҠўрқҗҲрқҗқ qвӮҖ qвӮҒ h) = вҠўрқҗҲрқҗқ
  (sbJg p qвӮҖ)
  (sbJg p qвӮҒ)
  (sbJg p h)

sbJg p (вҠўрқҗ«рқҗһрқҗҹрқҗҘ q h) = вҠўрқҗ«рқҗһрқҗҹрқҗҘ
  (sbJg p q)
  (sbJg p h)

sbJg{Пғ}{О”} p (вҠўрқҗү{l}{l'}{A}{C}{a}{b}{c}{e} S qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ hвӮҖ hвӮҒ)
  rewrite sb[]ВІ Пғ C b e = вҠўрқҗү{l = l}{l'}{A = Пғ * A}{Пғ * C}
  (S вҲӘ supp (О” , C))
  (О»{x y (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C)
           (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C) ##в—Ү)) вҶ’
    subst (О» C' вҶ’
      (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вЁҹ y вҲ¶ рқҗҲрқҗқ (Пғ * A) (Пғ * a) (рқҗҜ x) вҰӮ l) вҠў C' вҰӮ l')
      (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) C x#C (y#C вҲүвҲӘ (#symm x#y)))
      (sbJg
        (liftSbВІ p hвӮҖ (hвӮҒ x x#S) x#О”
          ((ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ y y#S)))) вҲүвҲӘ #symm x#y)
          (y#О” вҲүвҲӘ (#symm x#y)) refl (eq x x#S x#О” x#C) (sbJg p hвӮҖ)
          (hвӮҒ' x x#S x#О” x#C))
        (qвӮҖ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))})
  (sbJg p qвӮҒ)
  (sbJg p qвӮӮ)
  (subst (О» C' вҶ’ О” вҠў Пғ * c вҲ¶ C' вҰӮ l')
    (sb[]ВІ Пғ C a (рқҗ«рқҗһрқҗҹрқҗҘ a))
    (sbJg p qвӮғ))
  (sbJg p qвӮ„)
  (sbJg p hвӮҖ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C) вҶ’ hвӮҒ' x x#S x#О” x#C}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)(x#C : x # C)
    where
    eq : (Пғ вҲҳ/ x := рқҗҜ x) * рқҗҲрқҗқ A a (рқҗҜ x) вүЎ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x)
    eq rewrite  updateFresh Пғ x (рқҗҜ x) A
                (вҲүвҲӘвӮӮ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S))))))
       | updateFresh Пғ x (рқҗҜ x) a (вҲүвҲӘвӮҒ
         (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S))))))
       | :=Eq{f = Пғ}{рқҗҜ x} x = refl

    hвӮҒ' : (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x) вҰӮ l
    hвӮҒ' = subst (О» I вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў I вҰӮ l)
      eq
      (sbJg
        (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg p hвӮҖ))
        (hвӮҒ x x#S))

sbJg p (вҠўрқҗҚрқҗҡрқҗӯ _) = вҠўрқҗҚрқҗҡрқҗӯ (okSb p)

sbJg p (вҠўрқҗірқҗһрқҗ«рқҗЁ q) = вҠўрқҗірқҗһрқҗ«рқҗЁ (okSb p)

sbJg p (вҠўрқҗ¬рқҗ®рқҗңрқҗң q) = вҠўрқҗ¬рқҗ®рқҗңрқҗң (sbJg p q)

sbJg{Пғ}{О”} p (вҠўрқҗ§рқҗ«рқҗһрқҗң{l}{C}{cвӮҖ}{a}{cвӮҠ} S qвӮҖ qвӮҒ qвӮӮ h)
  rewrite sb[] Пғ C a = вҠўрқҗ§рқҗ«рқҗһрқҗң
  (S вҲӘ supp (О” , C , cвӮҠ))
  (subst (О» C' вҶ’ О” вҠў Пғ * cвӮҖ вҲ¶ C' вҰӮ l)
    (sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ)
    (sbJg p qвӮҖ))
  (О»{x y (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C вҲүвҲӘ y#cвӮҠ)
           (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) ##в—Ү))
     вҶ’ qвӮҒ' x x#S x#О” x#C x#cвӮҠ y y#S y#О” y#C y#cвӮҠ x#y})
  (sbJg p qвӮӮ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) вҶ’ h' x x#S x#О” x#C x#cвӮҠ}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)(x#C : x # C)(x#cвӮҠ : x # cвӮҠ)
    where
    h' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x ] вҰӮ l
    h' = subst (О» C' вҶ’ (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
      (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
