        (Пғ * cвӮҠ)[ x ][ y ] пјқ (Пғ * cвӮҠ')[ x ][ y ] вҲ¶ (Пғ * C) [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вҰӮ l
      qвӮӮ' = substвӮғ (О» d d' D вҶ’
        (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C) [ x ] вҰӮ l) вҠў d пјқ d' вҲ¶ D вҰӮ l)
        (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ #symm x#y))
        (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) cвӮҠ' x#cвӮҠ' (y#cвӮҠ' вҲүвҲӘ #symm x#y))
        eq'
        (sbJg
          (liftSbВІ p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮғ)) (h x x#S) x#О”
            (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮӮ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))))
            (y#О” вҲүвҲӘ #symm x#y) refl
            (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
            (вҠўрқҗҚрқҗҡрқҗӯ(okSb p)) h')
          (qвӮӮ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))

sbJg{Пғ}{О”} p (рқҡ·Beta{l}{l'}{A}{a}{B}{b} S qвӮҖ qвӮҒ hвӮҖ hвӮҒ)
  rewrite sb[] Пғ b a
  | sb[] Пғ B a = рқҡ·Beta
  (S вҲӘ supp (О” , B , b))
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B вҲүвҲӘ x#b) вҶ’
    substвӮӮ (О» b' B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў b' вҲ¶ B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) b x#b)
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg p hвӮҖ))
        (qвӮҖ x x#S))})
  (sbJg p qвӮҒ)
  (sbJg p hвӮҖ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B вҲүвҲӘ x#b) вҶ’
    subst (О» B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg p hвӮҖ))
        (hвӮҒ x x#S))}

sbJg{Пғ}{О”} p (рқҗҲрқҗқBeta{l}{l'}{A}{C}{a}{c} S qвӮҖ qвӮҒ qвӮӮ hвӮҖ hвӮҒ)
  rewrite sb[]ВІ Пғ C a (рқҗ«рқҗһрқҗҹрқҗҘ a) = рқҗҲрқҗқBeta
  (S вҲӘ supp (О” , C))
  (О»{x y (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C)
           (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C) ##в—Ү)) вҶ’
    subst (О» C' вҶ’
      (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вЁҹ y вҲ¶ рқҗҲрқҗқ (Пғ * A) (Пғ * a) (рқҗҜ x) вҰӮ l) вҠў C' вҰӮ l')
      (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) C x#C (y#C вҲүвҲӘ (#symm x#y)))
      (sbJg
        (liftSbВІ p hвӮҖ (hвӮҒ x x#S) x#О”
          ((ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ y y#S)))) вҲүвҲӘ #symm x#y)
          (y#О” вҲүвҲӘ (#symm x#y)) refl (eq x x#S x#О” x#C) (sbJg p hвӮҖ)
          (hвӮҒ' x x#S x#О” x#C))
        (qвӮҖ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))})
  (sbJg p qвӮҒ)
  (subst (О» C' вҶ’ О” вҠў Пғ * c вҲ¶ C' вҰӮ l')
    (sb[]ВІ Пғ C a (рқҗ«рқҗһрқҗҹрқҗҘ a))
    (sbJg p qвӮӮ))
  (sbJg p hвӮҖ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C) вҶ’ hвӮҒ' x x#S x#О” x#C}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)(x#C : x # C)
    where
    eq : (Пғ вҲҳ/ x := рқҗҜ x) * рқҗҲрқҗқ A a (рқҗҜ x) вүЎ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x)
    eq rewrite  updateFresh Пғ x (рқҗҜ x) A
                (вҲүвҲӘвӮӮ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S))))))
      | updateFresh Пғ x (рқҗҜ x) a (вҲүвҲӘвӮҒ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S))))))
      | :=Eq{f = Пғ}{рқҗҜ x} x = refl

    hвӮҒ' : (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x) вҰӮ l
    hвӮҒ' = subst (О» I вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў I вҰӮ l)
      eq
      (sbJg
        (liftSb p hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg p hвӮҖ))
        (hвӮҒ x x#S))

sbJg{Пғ}{О”} p (рқҗҚрқҗҡрқҗӯBetaвӮҖ{l}{C}{cвӮҖ}{cвӮҠ} S qвӮҖ qвӮҒ h)
  rewrite sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ = рқҗҚрқҗҡрқҗӯBetaвӮҖ
  (S вҲӘ supp (О” , C , cвӮҠ))
  (subst (О» C' вҶ’ О” вҠў Пғ * cвӮҖ вҲ¶ C' вҰӮ l)
    (sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ)
    (sbJg p qвӮҖ))
  (О»{x y (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C вҲүвҲӘ y#cвӮҠ)
           (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) ##в—Ү))
     вҶ’ qвӮҒ' x x#S x#О” x#C x#cвӮҠ y y#S y#О” y#C y#cвӮҠ x#y})
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) вҶ’ h' x x#S x#О” x#C x#cвӮҠ}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)(x#C : x # C)(x#cвӮҠ : x # cвӮҠ)
    where
    h' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x ] вҰӮ l
    h' = subst (О» C' вҶ’ (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
      (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
      (sbJg (liftSb p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (ПҖвӮҒ ([]вҒ»В№(вҠўok (h x x#S)))) x#О”
        (вҠўрқҗҚрқҗҡрқҗӯ (okSb p))) (h x x#S))

    module _
      (y : рқ”ё)(y#S : y # S)(y#О” : y # О”)(y#C : y # C)
      (y#cвӮҠ : y # cвӮҠ)(x#y : x # y)
      where
      eq' : ((Пғ вҲҳ/ x := рқҗҜ x) вҲҳ/ y := рқҗҜ y)* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ
        (Пғ * C)[ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
      eq' rewrite sb[] ((Пғ вҲҳ/ x := рқҗҜ x) вҲҳ/ y := рқҗҜ y) C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))
           | updateFresh ((Пғ вҲҳ/ x := рқҗҜ x)) y (рқҗҜ y) C y#C
           | updateFresh Пғ x (рқҗҜ x) C x#C
           | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x)}{рқҗҜ y} y x
              (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ (вҲүвҲӘвӮӮ
              (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮҒ x y (##:: x#S (##:: (x#y вҲүвҲӘ y#S) ##в—Ү)))))))
              (вҲҲпҪӣпҪқ)})
           | :=Eq{f = Пғ}{рқҗҜ x} x = refl

      qвӮҒ' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C)[ x ] вҰӮ l) вҠў
        (Пғ * cвӮҠ)[ x ][ y ] вҲ¶ (Пғ * C) [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вҰӮ l
      qвӮҒ' = substвӮӮ (О» c' C' вҶ’
        (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C)[ x ] вҰӮ l) вҠў c' вҲ¶ C' вҰӮ l)
          (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ (#symm x#y)))
          eq'
          (sbJg
            (liftSbВІ p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (h x x#S) x#О”
              (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮҒ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))))
              (y#О” вҲүвҲӘ (#symm x#y))
              refl
              (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
              (вҠўрқҗҚрқҗҡрқҗӯ(okSb p)) h')
            (qвӮҒ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))

sbJg{Пғ}{О”} p (рқҗҚрқҗҡрқҗӯBetaвӮҠ{l}{C}{cвӮҖ}{a}{cвӮҠ} S qвӮҖ qвӮҒ qвӮӮ h)
  rewrite sb[]ВІ Пғ cвӮҠ a (рқҗ§рқҗ«рқҗһрқҗң C cвӮҖ cвӮҠ a)
  | sb[] Пғ C (рқҗ¬рқҗ®рқҗңрқҗң a) = рқҗҚрқҗҡрқҗӯBetaвӮҠ
  (S вҲӘ supp (О” , C , cвӮҠ))
  (subst (О» C' вҶ’ О” вҠў Пғ * cвӮҖ вҲ¶ C' вҰӮ l)
    (sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ)
    (sbJg p qвӮҖ))
  (О»{x y (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C вҲүвҲӘ y#cвӮҠ)
           (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) ##в—Ү))
     вҶ’ qвӮҒ' x x#S x#О” x#C x#cвӮҠ y y#S y#О” y#C y#cвӮҠ x#y})
  (sbJg p qвӮӮ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) вҶ’ h' x x#S x#О” x#C x#cвӮҠ}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)(x#C : x # C)(x#cвӮҠ : x # cвӮҠ)
    where
    h' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x ] вҰӮ l
    h' = subst (О» C' вҶ’ (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
      (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
      (sbJg (liftSb p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (ПҖвӮҒ ([]вҒ»В№(вҠўok (h x x#S)))) x#О”
        (вҠўрқҗҚрқҗҡрқҗӯ (okSb p))) (h x x#S))

    module _
      (y : рқ”ё)(y#S : y # S)(y#О” : y # О”)(y#C : y # C)
      (y#cвӮҠ : y # cвӮҠ)(x#y : x # y)
      where
      eq' : ((Пғ вҲҳ/ x := рқҗҜ x) вҲҳ/ y := рқҗҜ y)* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ
        (Пғ * C)[ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
      eq' rewrite sb[] ((Пғ вҲҳ/ x := рқҗҜ x) вҲҳ/ y := рқҗҜ y) C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))
           | updateFresh ((Пғ вҲҳ/ x := рқҗҜ x)) y (рқҗҜ y) C y#C
           | updateFresh Пғ x (рқҗҜ x) C x#C
           | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x)}{рқҗҜ y} y x
              (О»{refl вҶ’ вҲүвҶ’В¬вҲҲ (вҲүвҲӘвӮӮ
              (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮҒ x y (##:: x#S (##:: (x#y вҲүвҲӘ y#S) ##в—Ү)))))))
              (вҲҲпҪӣпҪқ)})
           | :=Eq{f = Пғ}{рқҗҜ x} x = refl

      qвӮҒ' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C)[ x ] вҰӮ l) вҠў
        (Пғ * cвӮҠ)[ x ][ y ] вҲ¶ (Пғ * C) [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вҰӮ l
      qвӮҒ' = substвӮӮ (О» c' C' вҶ’
        (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C)[ x ] вҰӮ l) вҠў c' вҲ¶ C' вҰӮ l)
          (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ (#symm x#y)))
          eq'
          (sbJg
            (liftSbВІ p (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (h x x#S) x#О”
              (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮҒ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))))
              (y#О” вҲүвҲӘ (#symm x#y))
              refl
              (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
              (вҠўрқҗҚрқҗҡрқҗӯ(okSb p)) h')
            (qвӮҒ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү))))

sbJg{Пғ}{О”} p (рқҡ·Eta{l}{l'}{A}{B}{b}{b'} S qвӮҖ qвӮҒ qвӮӮ h) = рқҡ·Eta
  (S вҲӘ supp О”)
  (sbJg p qвӮҖ)
  (sbJg p qвӮҒ)
  (О»{x (x#S вҲүвҲӘ x#О”) вҶ’ qвӮӮ' x x#S x#О”})
  (sbJg p h)
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”) where
    x#О“ =  ПҖвӮҒ ([]вҒ»В№(вҠўok (qвӮӮ x x#S)))
    x#b = вҲүвҲӘвӮҒ (вҠў# qвӮҖ x#О“)
    x#b' = вҲүвҲӘвӮҒ (вҠў# qвӮҒ x#О“)
    x#A = вҲүвҲӘвӮҒ (вҲүвҲӘвӮӮ (вҠў# qвӮҖ x#О“))
    x#B = вҲүвҲӘвӮҒ (вҲүвҲӘвӮӮ (вҲүвҲӘвӮӮ (вҠў# qвӮҖ x#О“)))

    eq : вҲҖ c вҶ’ x # c вҶ’ (Пғ вҲҳ/ x := рқҗҜ x) * (c вҲҷ[ A , B ] рқҗҜ x) вүЎ
      (Пғ * c) вҲҷ[ Пғ * A , Пғ * B ] (рқҗҜ x)
    eq c x#c
      rewrite updateFresh Пғ x (рқҗҜ x) c x#c
      | updateFresh Пғ x (рқҗҜ x) A x#A
      | updateFresh Пғ x (рқҗҜ x) B x#B
      | :=Eq{f = Пғ}{рқҗҜ x} x = refl

    qвӮӮ' : (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў
      (Пғ * b)  вҲҷ[ Пғ * A , Пғ * B ] (рқҗҜ x) пјқ
      (Пғ * b') вҲҷ[ Пғ * A , Пғ * B ] (рқҗҜ x) вҲ¶ (Пғ * B) [ x ] вҰӮ l'
    qвӮӮ' = substвӮғ (О» c c' C вҶ’ О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вҠў c пјқ c' вҲ¶ C вҰӮ l')
      (eq b x#b)
      (eq b' x#b')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb p h x#О“ x#О” (sbJg p h))
        (qвӮӮ x x#S))

----------------------------------------------------------------------
-- Conversion for substitutions is reflexive
----------------------------------------------------------------------
sbпјқRefl :
  {Пғ : Sb}
  {О“ О“' : Cx}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ ---------------
  О“' вҠўЛў Пғ пјқ Пғ вҲ¶ О“

sbпјқRefl (в—ҮЛў q) = в—Ү q
sbпјқRefl (вЁҹЛў qвӮҖ qвӮҒ qвӮӮ qвӮғ) = [] (sbпјқRefl qвӮҖ) qвӮҒ (Refl qвӮӮ) qвӮғ

----------------------------------------------------------------------
-- Properties of substitution update
----------------------------------------------------------------------
sbUpdate :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ : Sb}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“' вҠў a вҲ¶ Пғ * A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ -----------------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

sbUpdate{l}{О“' = О“'}{Пғ}{A}{a}{x} вҠўПғ вҠўa x#О“ вҠўA = вЁҹЛў
  (sbExt вҠўПғ (О» y r вҶ’
    symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r })))
  вҠўA
  (substвӮӮ (О» z Z вҶ’ О“' вҠў z вҲ¶ Z вҰӮ l)
    (symm (:=Eq{f = Пғ}{a} x))
    (symm (updateFresh Пғ x a A (вҲүвҲӘвӮҒ (вҠў# вҠўA x#О“))))
    вҠўa)
  x#О“

sbпјқUpdate :
  {l : Lvl}
  {О“ О“' : Cx}
  {Пғ Пғ' : Sb}
  {A : Ty}
  {a a' : Tm}
  {x : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“' вҠў a пјқ a' вҲ¶ Пғ * A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ ------------------------------------------------------
  О“' вҠўЛў (Пғ вҲҳ/ x := a) пјқ (Пғ' вҲҳ/ x := a') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

sbпјқUpdate{l}{О“' = О“'}{Пғ}{Пғ'}{A}{a}{a'}{x} Пғ=Пғ' a=a' x#О“ вҠўA = []
  (sbпјқExt Пғ=Пғ'
    (О» y r вҶ’
      symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r }))
    (О» y r вҶ’
      symm (:=Neq {f = Пғ'} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r })))
  вҠўA
  (substвӮғ (О» z z' Z вҶ’ О“' вҠў z пјқ z' вҲ¶ Z вҰӮ l)
    (symm (:=Eq{f = Пғ}{a} x))
    (symm (:=Eq{f = Пғ'}{a'} x))
    (symm (updateFresh Пғ x a A (вҲүвҲӘвӮҒ (вҠў# вҠўA x#О“))))
    a=a')
  x#О“

ssbUpdate :
  {l : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ -----------------------------
  О“ вҠўЛў (x := a) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

ssbUpdate{l}{О“}{A}{a} q x#О“ h = sbUpdate
  (вҠўidЛў (вҠўok q))
  (subst (О» A' вҶ’ О“ вҠў a вҲ¶ A' вҰӮ l) (symm (sbUnit A)) q)
  x#О“
  h

ssbпјқUpdate :
  {l : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a a' : Tm}
  {x : рқ”ё}
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  (_ : x # О“)
  -- helper hypothesis
  (_ : О“ вҠў A вҰӮ l)
  вҶ’ ------------------------------------------
  О“ вҠўЛў (x := a) пјқ (x := a') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

ssbпјқUpdate{l}{О“}{A}{a}{a'} q x#О“ h = sbпјқUpdate
  (sbпјқRefl (вҠўidЛў (вҠўok q)))
  (subst (О» A' вҶ’ О“ вҠў a пјқ a' вҲ¶ A' вҰӮ l) (symm (sbUnit A)) q)
  x#О“
  h

ssbUpdateВІ :
  {l l' : Lvl}
  {О“ : Cx}
  {x y : рқ”ё}
  {a b : Tm}
  {A B : Ty}
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B вҰӮ l')
  (_ : О“ вҠў b вҲ¶ (x := a) * B вҰӮ l')
  (_ : y # (О“ , x))
  вҶ’ ----------------------------------------------------
  О“ вҠўЛў (x := a вҲҳ/ y := b) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')

ssbUpdateВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ
  with okвЁҹ q q' _ вҶҗ вҠўok qвӮҒ =
  sbUpdate (ssbUpdate qвӮҖ q' q) qвӮӮ qвӮғ qвӮҒ

ssbпјқUpdateВІ :
  {l l' : Lvl}
  {О“ : Cx}
  {x y : рқ”ё}
  {a a' b b' : Tm}
  {A  B : Ty}
  (_ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B вҰӮ l')
  (_ : О“ вҠў b пјқ b' вҲ¶ (x := a) * B вҰӮ l')
  (_ : y # (О“ , x))
  вҶ’ ---------------------------------------------
  О“ вҠўЛў (x := a вҲҳ/ y := b) пјқ (x := a' вҲҳ/ y := b')
    вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')

ssbпјқUpdateВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ
  with okвЁҹ q q' _ вҶҗ вҠўok qвӮҒ =
  sbпјқUpdate (ssbпјқUpdate qвӮҖ q' q) qвӮӮ qвӮғ qвӮҒ

----------------------------------------------------------------------
-- Lifting substitutions, again
----------------------------------------------------------------------
liftSbвҒ» :
  {l : Lvl}
  {Пғ : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : x # О“)
  (_ : x' # О“')
  вҶ’ ---------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

liftSbвҒ» qвӮҖ qвӮҒ qвӮӮ qвӮғ = liftSb qвӮҖ qвӮҒ qвӮӮ qвӮғ (sbJg qвӮҖ qвӮҒ)

liftпјқSb :
  {l : Lvl}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : x # О“)
  (_ : x' # О“')
  -- helper hypothesis
  (_ : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠўЛў
    (Пғ вҲҳ/ x := рқҗҜ x') пјқ (Пғ' вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l)

liftпјқSb{l}{Пғ}{Пғ'}{О“}{О“'}{A}{x}{x'} p q x#О“ x'#О“ h =
  [] (в–·пјқSb x' (sbJg h q) p' x'#О“) q q'' x#О“
  where
  p' : О“' вҠўЛў (Пғ вҲҳ/ x := рқҗҜ x') пјқ (Пғ' вҲҳ/ x := рқҗҜ x') вҲ¶ О“
  p' = sbпјқExt p
    (О» y r вҶ’ symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r }))
    О» y r вҶ’ symm (:=Neq {f = Пғ'} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ x#О“ r })

  q'' : (О“' вЁҹ x' вҲ¶ Пғ * A вҰӮ l) вҠў
      (Пғ вҲҳ/ x := рқҗҜ x') x пјқ (Пғ' вҲҳ/ x := рқҗҜ x') x вҲ¶ (Пғ вҲҳ/ x := рқҗҜ x') * A вҰӮ l
  q'' rewrite updateFresh Пғ x (рқҗҜ x') A (вҲүвҲӘвӮҒ (вҠў# q x#О“))
      | :=Eq{f = Пғ}{рқҗҜ x'} x
      | :=Eq{f = Пғ'}{рқҗҜ x'} x =
    Refl (вҠўрқҗҜ (okвЁҹвҒ» (sbJg h q) x'#О“) isInNew)

liftпјқSbВІ :
  {l l' : Lvl}
  {x y x' y' : рқ”ё}
  {Пғ Пғ' : Sb}
  {О“ О“' : Cx}
  {A A' B B' : Ty}
  (_ : О“' вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў A вҰӮ l)
  (_ : (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B вҰӮ l')
  (_ : x' # О“')
  (_ : y # (О“ , x))
  (_ : y' # (О“' , x'))
  (_ : Пғ * A вүЎ A')
  (_ : (Пғ вҲҳ/ x := рқҗҜ x') * B вүЎ B')
  -- helper hypotheses
  (h : О“' вҠўЛў Пғ вҲ¶ О“)
  вҶ’ --------------------------------------------------------------
  (О“' вЁҹ x' вҲ¶ A' вҰӮ l вЁҹ y' вҲ¶ B' вҰӮ l') вҠўЛў
  ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y')
  пјқ
  ((Пғ' вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l  вЁҹ y вҲ¶ B вҰӮ l')

liftпјқSbВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… refl refl h
  with okвЁҹ q q' _ вҶҗ вҠўok qвӮӮ =
  liftпјқSb (liftпјқSb qвӮҖ q q' qвӮғ h) qвӮӮ qвӮ„ qвӮ…
    (liftSbвҒ» h q q' qвӮғ)

----------------------------------------------------------------------
-- Action of convertible substitutions
----------------------------------------------------------------------
пјқsbTm :
  {l : Lvl}
  {Пғ Пғ' : Sb}
  {О” О“ : Cx}
  {A : Ty}
  {a : Tm}
  (_ : О” вҠўЛў Пғ пјқ Пғ' вҲ¶ О“)
  (_ : О“ вҠў a вҲ¶ A вҰӮ l)
  -- helper hypothesis
  (_ : О” вҠўЛў Пғ вҲ¶ О“)
  вҶ’ -----------------------------
  О” вҠў Пғ * a пјқ Пғ' * a вҲ¶ Пғ * A вҰӮ l

пјқsbTm p (вҠўconv qвӮҖ qвӮҒ) h = пјқconv (пјқsbTm p qвӮҖ h) (sbJg h qвӮҒ)

пјқsbTm{Пғ = Пғ}{Пғ'} p (вҠўрқҗҜ{x = x} _ q) h
  rewrite вҖҝunit (Пғ x) вҰғ it вҰ„
  | вҖҝunit (Пғ' x) вҰғ it вҰ„ = sbVarпјқ p q

пјқsbTm p (вҠўрқҗ” _) h = Refl (вҠўрқҗ” (okSbпјқ p))

пјқsbTm{Пғ = Пғ}{Пғ'}{О”} p (вҠўрқҡ·{l}{l'}{A = A}{B} S qвӮҖ qвӮҒ) h = рқҡ·Cong
  (S вҲӘ supp (О” , B))
  (пјқsbTm p qвӮҖ h)
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B) вҶ’
    substвӮӮ (О» C C' вҶ’ О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вҠў C пјқ C' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbUpdate[] Пғ' x (рқҗҜ x) B x#B)
      (пјқsbTm
        (liftпјқSb p qвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮҒ x x#S)))) x#О” h)
        (qвӮҒ x x#S)
        (liftSbвҒ» h qвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮҒ x x#S)))) x#О”))})
  (sbJg h qвӮҖ)

пјқsbTm{Пғ = Пғ}{Пғ'}{О”} p (вҠўрқӣҢ{l}{l'}{A}{B}{b} S qвӮҖ hвӮҖ hвӮҒ) h = рқӣҢCong
  (S вҲӘ supp (О” , B , b))
  (пјқsbTm p hвӮҖ h)
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B вҲүвҲӘ x#b) вҶ’
    substвӮғ (О» c c' C вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў c пјқ c' вҲ¶ C вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) b x#b)
      (sbUpdate[] Пғ' x (рқҗҜ x) b x#b)
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (пјқsbTm
        (liftпјқSb p hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” h)
        (qвӮҖ x x#S)
        (liftSbвҒ» h hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О”))})
  (sbJg h hвӮҖ)
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B вҲүвҲӘ x#b) вҶ’
    subst (О» B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSb h hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg h hвӮҖ))
        (hвӮҒ x x#S))})

пјқsbTm{Пғ = Пғ}{Пғ'}{О”} p (вҠўвҲҷ{l}{l'}{A}{B}{a}{b} S qвӮҖ qвӮҒ qвӮӮ hвӮҖ) h
  rewrite sb[] Пғ B a = вҲҷCong
  (S вҲӘ supp (О” , B))
  (пјқsbTm p hвӮҖ h)
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B) вҶ’
    substвӮӮ (О» C C' вҶ’ О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вҠў C пјқ C' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbUpdate[] Пғ' x (рқҗҜ x) B x#B)
      (пјқsbTm
        (liftпјқSb p hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮӮ x x#S)))) x#О” h)
        (qвӮӮ x x#S)
        (liftSbвҒ» h hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮӮ x x#S)))) x#О”))})
  (пјқsbTm p qвӮҖ h)
  (пјқsbTm p qвӮҒ h)
  (sbJg h hвӮҖ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#B) вҶ’
    subst (О» B' вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў B' вҰӮ l')
      (sbUpdate[] Пғ x (рқҗҜ x) B x#B)
      (sbJg
        (liftSbвҒ» h hвӮҖ (ПҖвӮҒ([]вҒ»В№(вҠўok (qвӮӮ x x#S)))) x#О”)
        (qвӮӮ x x#S))}

пјқsbTm p (вҠўрқҗҲрқҗқ qвӮҖ qвӮҒ hвӮҖ) h = рқҗҲрқҗқCong
  (пјқsbTm p hвӮҖ h)
  (пјқsbTm p qвӮҖ h)
  (пјқsbTm p qвӮҒ h)

пјқsbTm p (вҠўрқҗ«рқҗһрқҗҹрқҗҘ q hвӮҖ) h = рқҗ«рқҗһрқҗҹрқҗҘCong
  (пјқsbTm p q h)
  (sbJg h hвӮҖ)

пјқsbTm{Пғ = Пғ}{Пғ'}{О”} p (вҠўрқҗү{l}{l'}{A}{C}{a}{b}{c}{e}
  S qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ hвӮҖ hвӮҒ) h
  rewrite sb[]ВІ Пғ C b e = рқҗүCong{l = l}{A = Пғ * A}
  (S вҲӘ supp (О” , C))
  (О»{x y
    (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C)
    (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C) ##в—Ү)) вҶ’
    substвӮӮ (О» D D' вҶ’
      (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вЁҹ y вҲ¶ рқҗҲрқҗқ (Пғ * A) (Пғ * a) (рқҗҜ x) вҰӮ l) вҠў D пјқ D' вҰӮ l')
      (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) C x#C (y#C вҲүвҲӘ (#symm x#y)))
      (sbUpdate[]ВІ Пғ' x y (рқҗҜ x) (рқҗҜ y) C x#C (y#C вҲүвҲӘ (#symm x#y)))
      (пјқsbTm
        (liftпјқSbВІ p hвӮҖ (hвӮҒ x x#S) x#О”
          (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ y y#S))) вҲүвҲӘ #symm x#y)
          (y#О” вҲүвҲӘ (#symm x#y)) refl (eq x x#S x#О” x#C) h)
        (qвӮҖ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү)))
        (liftSbВІ h hвӮҖ (hвӮҒ x x#S) x#О”
          (ПҖвӮҒ([]вҒ»В№(вҠўok (hвӮҒ y y#S))) вҲүвҲӘ #symm x#y) (y#О” вҲүвҲӘ (#symm x#y))
          refl (eq x x#S x#О” x#C) (sbJg h hвӮҖ) (hвӮҒ' x x#S x#О” x#C)))})
  (пјқsbTm p qвӮҒ h)
  (пјқsbTm p qвӮӮ h)
  (subst (О» C' вҶ’ О”  вҠў Пғ * c пјқ Пғ' * c вҲ¶ C' вҰӮ l')
    (sb[]ВІ Пғ C a (рқҗ«рқҗһрқҗҹрқҗҘ a))
    (пјқsbTm p qвӮғ h))
  (пјқsbTm p qвӮ„ h)
  (sbJg h hвӮҖ)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C) вҶ’ hвӮҒ' x x#S x#О” x#C}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)(x#C : x # C) where
    eq : (Пғ вҲҳ/ x := рқҗҜ x) * рқҗҲрқҗқ A a (рқҗҜ x) вүЎ рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x)
    eq rewrite  updateFresh Пғ x (рқҗҜ x) A
                (вҲүвҲӘвӮӮ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S))))))
      | updateFresh Пғ x (рқҗҜ x) a (вҲүвҲӘвӮҒ (вҠў# qвӮҒ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S))))))
      | :=Eq{f = Пғ}{рқҗҜ x} x = refl

    hвӮҒ' : (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў рқҗҲрқҗқ(Пғ * A)(Пғ * a)(рқҗҜ x) вҰӮ l
    hвӮҒ' = subst (О» I вҶ’ (О” вЁҹ x вҲ¶ Пғ * A вҰӮ l) вҠў I вҰӮ l)
      eq
      (sbJg
        (liftSb h hвӮҖ (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҒ x x#S)))) x#О” (sbJg h hвӮҖ))
        (hвӮҒ x x#S))

пјқsbTm p (вҠўрқҗҚрқҗҡрқҗӯ _) _ = Refl (вҠўрқҗҚрқҗҡрқҗӯ (okSbпјқ p))

пјқsbTm p (вҠўрқҗірқҗһрқҗ«рқҗЁ _) _ = Refl (вҠўрқҗірқҗһрқҗ«рқҗЁ (okSbпјқ p))

пјқsbTm p (вҠўрқҗ¬рқҗ®рқҗңрқҗң q) h = рқҗ¬рқҗ®рқҗңрқҗңCong (пјқsbTm p q h)

пјқsbTm{Пғ = Пғ}{Пғ'}{О”} p (вҠўрқҗ§рқҗ«рқҗһрқҗң{l}{C}{cвӮҖ}{a}{cвӮҠ} S qвӮҖ qвӮҒ qвӮӮ hвӮҖ) h
  rewrite sb[] Пғ C a = рқҗ§рқҗ«рқҗһрқҗңCong
  (S вҲӘ supp (О” , C , cвӮҠ))
  (О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) вҶ’ qвӮҖ' x x#S x#О” x#C x#cвӮҠ})
  (subst (О» D вҶ’ О” вҠў Пғ * cвӮҖ пјқ Пғ' * cвӮҖ вҲ¶ D вҰӮ l)
    (sb[] Пғ C рқҗірқҗһрқҗ«рқҗЁ)
    (пјқsbTm p qвӮҖ h))
  (О»{x y
    (##:: (y#S вҲүвҲӘ y#О” вҲүвҲӘ y#C вҲүвҲӘ y#cвӮҠ)
    (##:: (x#y вҲүвҲӘ x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) ##в—Ү)) вҶ’
    qвӮӮ' x x#S x#О” x#C x#cвӮҠ y y#S y#О” y#C y#cвӮҠ x#y})
  (пјқsbTm p qвӮӮ h)
  О»{x (x#S вҲүвҲӘ x#О” вҲүвҲӘ x#C вҲүвҲӘ x#cвӮҠ) вҶ’ h' x x#S x#О” x#C x#cвӮҠ}
  where
  module _ (x : рқ”ё)(x#S : x # S)(x#О” : x # О”)
    (x#C : x # C)(x#cвӮҠ : x # cвӮҠ)
    where
    h' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x ] вҰӮ l
    h' = subst (О» C' вҶ’ (О”  вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў C' вҰӮ l)
      (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
      (sbJg (liftSb h (вҠўрқҗҚрқҗҡрқҗӯ (вҠўok qвӮҖ)) (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҖ x x#S)))) x#О”
        (вҠўрқҗҚрқҗҡрқҗӯ (okSb h))) (hвӮҖ x x#S))

    qвӮҖ' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў (Пғ * C) [ x ] пјқ (Пғ' * C) [ x ] вҰӮ l
    qвӮҖ' = substвӮӮ (О» D D' вҶ’ (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0) вҠў D пјқ D' вҰӮ l)
      (sbUpdate[] Пғ x (рқҗҜ x) C x#C)
      (sbUpdate[] Пғ' x (рқҗҜ x) C x#C)
      (пјқsbTm
        (liftпјқSb p (вҠўрқҗҚрқҗҡрқҗӯ (sbOk h)) (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҖ x x#S)))) x#О” h)
        (hвӮҖ x x#S)
        (liftSb h (вҠўрқҗҚрқҗҡрқҗӯ (sbOk h))
          (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҖ x x#S)))) x#О” (вҠўрқҗҚрқҗҡрқҗӯ (okSb h))))
    module _
      (y : рқ”ё)(y#S : y # S)(y#О” : y # О”)
      (y#C : y # C)(y#cвӮҠ : y # cвӮҠ)(x#y : x # y)
      where
      eq : ((Пғ вҲҳ/ x := рқҗҜ x) вҲҳ/ y := рқҗҜ y)* C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вүЎ
           (Пғ * C)[ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ]
      eq rewrite sb[] ((Пғ вҲҳ/ x := рқҗҜ x) вҲҳ/ y := рқҗҜ y) C (рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x))
         | updateFresh ((Пғ вҲҳ/ x := рқҗҜ x)) y (рқҗҜ y) C y#C
         | updateFresh Пғ x (рқҗҜ x) C x#C
         | :=Neq{f = (Пғ вҲҳ/ x := рқҗҜ x)}{рқҗҜ y} y x
           (О»{refl вҶ’ вү рқ”ёirrefl (вҲүпҪӣпҪқвҒ»В№ x#y)})
         | :=Eq{f = Пғ}{рқҗҜ x} x = refl
      qвӮӮ' : (О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C)[ x ] вҰӮ l) вҠў
        (Пғ * cвӮҠ)[ x ][ y ]  пјқ
        (Пғ' * cвӮҠ)[ x ][ y ] вҲ¶ (Пғ * C) [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ] вҰӮ l
      qвӮӮ' = substвӮғ (О» d d' D вҶ’
        О” вЁҹ x вҲ¶ рқҗҚрқҗҡрқҗӯ вҰӮ 0 вЁҹ y вҲ¶ (Пғ * C) [ x ] вҰӮ l вҠў d пјқ d' вҲ¶ D вҰӮ l)
        (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ (#symm x#y)))
        (sbUpdate[]ВІ Пғ' x y (рқҗҜ x) (рқҗҜ y) cвӮҠ x#cвӮҠ (y#cвӮҠ вҲүвҲӘ (#symm x#y)))
        eq
        (пјқsbTm
          (liftпјқSbВІ p (вҠўрқҗҚрқҗҡрқҗӯ (sbOk h)) (hвӮҖ x x#S) x#О”
            (ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҖ y y#S))) вҲүвҲӘ #symm x#y) (y#О” вҲүвҲӘ (#symm x#y))
            refl (sbUpdate[] Пғ x (рқҗҜ x) C x#C) h)
          (qвӮҒ x y (##:: y#S (##:: (x#y вҲүвҲӘ x#S) ##в—Ү)))
          (liftSbВІ h (вҠўрқҗҚрқҗҡрқҗӯ (sbOk h)) (hвӮҖ x x#S) x#О”
            ((ПҖвӮҒ ([]вҒ»В№(вҠўok (hвӮҖ y y#S))) вҲүвҲӘ #symm x#y)) (y#О” вҲүвҲӘ (#symm x#y))
            refl (sbUpdate[] Пғ x (рқҗҜ x) C x#C) (вҠўрқҗҚрқҗҡрқҗӯ (okSb h)) h'))

----------------------------------------------------------------------
-- Renaming provable judgements is a special case of substitution
----------------------------------------------------------------------
rnJg :
  {ПҒ : Rn}
  {О” О“ : Cx}
  {J : Jg}
  (_ : О” вҠўКі ПҒ вҲ¶ О“)
  (_ : О“ вҠў J)
  вҶ’ --------------
  О” вҠў ПҒ * J

rnJg = sbJg

rnвЁҹ :
  {О“ : Cx}
  {x x' : рқ”ё}
  {A : Ty}
  {l : Lvl}
  {J : Jg}
  (_ : О“ вЁҹ x вҲ¶ A вҰӮ l вҠў J)
  (_ : x' # О“)
  вҶ’ ----------------------------
  О“ вЁҹ x' вҲ¶ A вҰӮ l вҠў (x := рқҗҜ x') * J

rnвЁҹ{О“}{x}{x'}{A}{l} q x'#О“
  with okвЁҹ q' x#О“ okО“ вҶҗ вҠўok q = sbJg
    (subst (О» A' вҶ’
      (О“ вЁҹ x' вҲ¶ A' вҰӮ l) вҠўЛў (x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l))
      (sbUnit A)
      (liftSbвҒ» (вҠўidЛў okО“) q' x#О“ x'#О“))
    q

rnвЁҹВІ :
  {О“ : Cx}
  {x x' y y' : рқ”ё}
  {A B : Ty}
  {l l' : Lvl}
  {J : Jg}
  (_ : О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l' вҠў J)
  (_ : x' # О“)
  (_ : y' # (x' , О“))
  вҶ’ -------------------------------------------
  О“ вЁҹ x' вҲ¶ A вҰӮ l вЁҹ y' вҲ¶ (x := рқҗҜ x') * B вҰӮ l' вҠў
    (x := рқҗҜ x' вҲҳ/ y := рқҗҜ y') * J

rnвЁҹВІ{О“}{x}{x'}{y}{y'}{A}{B}{l}{l'} q x'#О“ (y'#x' вҲүвҲӘ y'#О“)
  with okвЁҹ q' (y#О“ вҲүвҲӘ y#x) (okвЁҹ q'' x#О“ okО“) вҶҗ вҠўok q =
  sbJg p' q
  where
  p : О“ вЁҹ x' вҲ¶ A вҰӮ l вҠўЛў x := рқҗҜ x' вҲ¶ О“ вЁҹ x вҲ¶ A вҰӮ l
  p = subst (О» A' вҶ’
    О“ вЁҹ x' вҲ¶ A' вҰӮ l вҠўЛў x := рқҗҜ x' вҲ¶ О“ вЁҹ x вҲ¶ A вҰӮ l)
    (sbUnit A)
    (liftSbвҒ» (вҠўidЛў okО“) q'' x#О“ x'#О“)

  p' : (О“ вЁҹ x' вҲ¶ A вҰӮ l вЁҹ y' вҲ¶ (x := рқҗҜ x') * B вҰӮ l') вҠўЛў
    (x := рқҗҜ x' вҲҳ/ y := рқҗҜ y') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l')
  p' = liftSbВІ
    (вҠўidЛў okО“) q'' q'
    x'#О“ (y#О“ вҲүвҲӘ y#x) (y'#О“ вҲүвҲӘ y'#x') (sbUnit A)
    refl q'' (sbJg p q')
