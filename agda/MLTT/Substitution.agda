        (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) C x#C (y#C вҲүвҲӘ #symm x#y))
        (sbUpdate[]ВІ Пғ x y (рқҗҜ x) (рқҗҜ y) C' x#C' (y#C' вҲүвҲӘ #symm x#y))
